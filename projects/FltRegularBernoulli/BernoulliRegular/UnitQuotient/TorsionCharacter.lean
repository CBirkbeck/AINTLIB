module

public import BernoulliRegular.UnitQuotient.TorsionQuotient

/-!
# Unit quotients: the character of the cyclotomic torsion line

This file proves the second half of `REF-07b`.  The torsion image in `E/E^p`
was already identified with the cyclic subgroup generated by the class of
`zeta_p`; here we prove that the actual `Delta = (ZMod p)^*` action on that
generator is the Teichmuller action:

```text
sigma_a([zeta_p]) = [zeta_p]^a.
```

Thus the torsion line is the `j = 1` line.  Later component files can use this
with their chosen idempotent/eigenspace API to exclude this torsion line from
the even components `2 <= j <= p - 3`.
-/

@[expose] public section

noncomputable section

open NumberField IsCyclotomicExtension
open scoped NumberField

namespace BernoulliRegular

set_option linter.unusedSectionVars false

variable (p : ℕ) [hp : Fact p.Prime]
variable (K : Type*) [Field K] [NumberField K] [IsCyclotomicExtension {p} ℚ K]

/-- The actual cyclotomic automorphism indexed by `a` sends the distinguished
unit `zeta_p` to `zeta_p^a`. -/
@[simp]
theorem cyclotomicUnitEquiv_zetaUnit (a : CyclotomicUnitDelta p) :
    cyclotomicUnitEquiv (p := p) K a (cyclotomicZetaUnit (p := p) K) =
      cyclotomicZetaUnit (p := p) K ^ (a : ZMod p).val := by
  apply Units.ext
  change cyclotomicRingOfIntegersEquiv (p := p) K a
      ((cyclotomicZetaUnit (p := p) K : CyclotomicUnitGroup K) : 𝓞 K) =
    ((cyclotomicZetaUnit (p := p) K ^ (a : ZMod p).val : CyclotomicUnitGroup K) : 𝓞 K)
  change cyclotomicSigmaOfUnit (p := p) K a • cyclotomicZetaInteger (p := p) K =
    cyclotomicZetaInteger (p := p) K ^ (a : ZMod p).val
  exact cyclotomicSigmaOfUnit_smul_zetaInteger (p := p) (K := K) a

/-- The class of `zeta_p` in `E/E^p` transforms by the Teichmuller character. -/
@[simp]
theorem cyclotomicUnitModPDeltaAction_act_zetaPowerClass
    (a : CyclotomicUnitDelta p) :
    (cyclotomicUnitModPDeltaAction (p := p) K).act a
        (cyclotomicZetaPowerClass (p := p) K) =
      cyclotomicZetaPowerClass (p := p) K ^ (a : ZMod p).val := by
  rw [cyclotomicZetaPowerClass, cyclotomicUnitPowerQuotientDeltaAction_act_mk,
    cyclotomicUnitEquiv_zetaUnit (p := p) (K := K) a, map_pow]

/-- The same Teichmuller action on every power of the `zeta_p` class. -/
theorem cyclotomicUnitModPDeltaAction_act_zetaPowerClass_pow
    (a : CyclotomicUnitDelta p) (m : ℕ) :
    (cyclotomicUnitModPDeltaAction (p := p) K).act a
        (cyclotomicZetaPowerClass (p := p) K ^ m) =
      cyclotomicZetaPowerClass (p := p) K ^ ((a : ZMod p).val * m) := by
  change (cyclotomicUnitModPDeltaAction (p := p) K).toMulAut a
      (cyclotomicZetaPowerClass (p := p) K ^ m) = _
  rw [map_pow]
  have h := cyclotomicUnitModPDeltaAction_act_zetaPowerClass (p := p) (K := K) a
  change (cyclotomicUnitModPDeltaAction (p := p) K).toMulAut a
      (cyclotomicZetaPowerClass (p := p) K) =
    cyclotomicZetaPowerClass (p := p) K ^ (a : ZMod p).val at h
  rw [h, pow_mul]

/-- The `zeta_p` line in `E/E^p`. -/
abbrev cyclotomicZetaPowerLine :
    Subgroup (CyclotomicUnitPowerQuotient (p := p) (N := 1) K) :=
  Subgroup.zpowers (cyclotomicZetaPowerClass (p := p) K)

/-- The `zeta_p` line is stable under the actual cyclotomic `Delta` action. -/
theorem cyclotomicZetaPowerLine_act_mem
    (a : CyclotomicUnitDelta p)
    {x : CyclotomicUnitPowerQuotient (p := p) (N := 1) K}
    (hx : x ∈ cyclotomicZetaPowerLine (p := p) K) :
    (cyclotomicUnitModPDeltaAction (p := p) K).act a x ∈
      cyclotomicZetaPowerLine (p := p) K := by
  obtain ⟨n, rfl⟩ := Subgroup.mem_zpowers_iff.mp hx
  change (cyclotomicUnitModPDeltaAction (p := p) K).toMulAut a
      (cyclotomicZetaPowerClass (p := p) K ^ n) ∈
    cyclotomicZetaPowerLine (p := p) K
  rw [map_zpow]
  have h := cyclotomicUnitModPDeltaAction_act_zetaPowerClass (p := p) (K := K) a
  change (cyclotomicUnitModPDeltaAction (p := p) K).toMulAut a
      (cyclotomicZetaPowerClass (p := p) K) =
    cyclotomicZetaPowerClass (p := p) K ^ (a : ZMod p).val at h
  rw [h]
  exact (cyclotomicZetaPowerLine (p := p) K).zpow_mem
    (Subgroup.npow_mem_zpowers (cyclotomicZetaPowerClass (p := p) K) (a : ZMod p).val) n

/-- Equivalently, the torsion image in `E/E^p` is stable under `Delta`. -/
theorem cyclotomicTorsionPowerClassSubgroup_act_mem
    (hp_odd : p ≠ 2) (a : CyclotomicUnitDelta p)
    {x : CyclotomicUnitPowerQuotient (p := p) (N := 1) K}
    (hx : x ∈ cyclotomicTorsionPowerClassSubgroup (p := p) K) :
    (cyclotomicUnitModPDeltaAction (p := p) K).act a x ∈
      cyclotomicTorsionPowerClassSubgroup (p := p) K := by
  rw [cyclotomicTorsionPowerClassSubgroup_eq_zpowers_zeta
    (p := p) (K := K) hp_odd] at hx ⊢
  exact cyclotomicZetaPowerLine_act_mem (p := p) (K := K) a hx

end BernoulliRegular

end
