import BernoulliRegular.FLT37.PrimaryUnits
import Mathlib.NumberTheory.NumberField.CMField

/-!
# Cyclotomic-unit subgroup of `(рќ“ћ K)ЛЈ`

For `K = в„љ(О¶_p)` (`p` an odd prime), Sinnott's index formula relates the
"cyclotomic units" subgroup `C вЉ† (рќ“ћ K)ЛЈ` (Washington Definition 8.1)
to the class number `h(K)`: `[(рќ“ћ K)ЛЈ : C] = h(K)`.

This file defines:
* `cyclotomicUnitsSubgroup` вЂ” `C вЉ† (рќ“ћ K)ЛЈ`, the subgroup generated by
  the cyclotomic units `(1-О¶^k)/(1-О¶)` (`k` coprime to `p`) and the
  torsion subgroup (= roots of unity in `рќ“ћ K`).
* `cyclotomicUnitsPlus` вЂ” `CвЃє = C в€© realUnits K`, the real cyclotomic
  units subgroup.

This is **Step (A)** of the Sinnott / Cor 8.19 bridge construction.
The generating elements `cyclotomicUnitUnit p K k` are already defined
in `BernoulliRegular/FLT37/PrimaryUnits.lean`.

## References

* Washington, *Introduction to Cyclotomic Fields*, 2nd ed., В§8.1.
* Sinnott, *On the Stickelberger ideal and the circular units of a
  cyclotomic field*, Annals of Math. 108 (1978).
-/

@[expose] public section

noncomputable section

open NumberField NumberField.IsCMField

namespace BernoulliRegular

namespace FLT37

namespace Sinnott

variable (p : в„•) [hp : Fact p.Prime]
variable (K : Type*) [Field K] [NumberField K] [IsCyclotomicExtension {p} в„љ K]

/-- The set of cyclotomic units in `(рќ“ћ K)ЛЈ`: the units
`cyclotomicUnitUnit p K k = (1 - О¶^k)/(1 - О¶)` for `1 в‰¤ k < p` (with
`k.Coprime p` automatic for `1 в‰¤ k < p` and `p` prime).

The bound `k < p` avoids redundancy: `cyclotomicUnit k = cyclotomicUnit
(k mod p)` as elements of `рќ“ћ K` since `О¶^p = 1`. -/
def cyclotomicUnitsSet (hp_two : 2 в‰¤ p) : Set (рќ“ћ K)ЛЈ :=
  {u : (рќ“ћ K)ЛЈ | в€ѓ (k : в„•) (hk : k.Coprime p) (_ : 1 в‰¤ k) (_ : k < p),
    u = cyclotomicUnitUnit p K k hk hp_two}

/-- **The cyclotomic-units subgroup `C вЉ† (рќ“ћ K)ЛЈ`** (Washington Def 8.1):
the subgroup generated by the cyclotomic units `(1-О¶^k)/(1-О¶)` for
`k.Coprime p`, together with the torsion subgroup (roots of unity).

For `K = в„љ(О¶_p)` with `p` odd, the torsion subgroup is generated by
`-1` and `О¶`, both of which are products of cyclotomic units up to
sign. Including torsion explicitly makes the index formula
`[(рќ“ћ K)ЛЈ : C] = h(K)` (Sinnott / Washington Thm 8.2) state cleanly. -/
def cyclotomicUnitsSubgroup (hp_two : 2 в‰¤ p) : Subgroup (рќ“ћ K)ЛЈ :=
  Subgroup.closure (cyclotomicUnitsSet p K hp_two) вЉ” NumberField.Units.torsion K

/-- **The real cyclotomic-units subgroup `CвЃє вЉ† (рќ“ћ K)ЛЈ`**:
the Пѓ-fixed (= real) elements of `cyclotomicUnitsSubgroup`. By
`unitsComplexConj_eq_self_iff`, an element of `(рќ“ћ K)ЛЈ` is Пѓ-fixed iff
it lies in `realUnits K = image of (рќ“ћ KвЃє)ЛЈ`.

The Sinnott-style real index formula (Washington Thm 8.2) is
`[realUnits K : CвЃє] = hвЃє(K)`. -/
def cyclotomicUnitsPlus [IsCMField K] (hp_two : 2 в‰¤ p) : Subgroup (рќ“ћ K)ЛЈ :=
  cyclotomicUnitsSubgroup p K hp_two вЉ“ realUnits K

/-- Membership in `cyclotomicUnitsSubgroup`: a cyclotomic unit
`cyclotomicUnitUnit p K k` is in `C` for `1 в‰¤ k < p` and `k.Coprime p`. -/
theorem cyclotomicUnitUnit_mem_cyclotomicUnitsSubgroup
    {k : в„•} (hk : k.Coprime p) (hk_pos : 1 в‰¤ k) (hk_lt : k < p) (hp_two : 2 в‰¤ p) :
    cyclotomicUnitUnit p K k hk hp_two в€€ cyclotomicUnitsSubgroup p K hp_two :=
  Subgroup.mem_sup_left <| Subgroup.subset_closure вџЁk, hk, hk_pos, hk_lt, rflвџ©

/-- Membership: torsion units are in `C`. -/
theorem torsion_le_cyclotomicUnitsSubgroup (hp_two : 2 в‰¤ p) :
    NumberField.Units.torsion K в‰¤ cyclotomicUnitsSubgroup p K hp_two :=
  le_sup_right

end Sinnott

end FLT37

end BernoulliRegular

end
