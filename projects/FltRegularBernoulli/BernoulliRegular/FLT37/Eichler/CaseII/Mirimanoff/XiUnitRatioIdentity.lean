import BernoulliRegular.FLT37.LehmerVandiver.PollaczekUnit

/-!
# Washington В§8.1 Lemma 8.1: the real cyclotomic generators `Оѕ_a`, for `p = 37`

This file builds **Washington's Lemma 8.1(a)** (Washington *Introduction to Cyclotomic Fields*,
2nd ed., GTM 83, В§8.1, p. 144) for the cyclotomic field `K = в„љ(О¶_p)` with `p` an odd prime: the
real cyclotomic units of `в„љ(О¶_p)вЃє` are generated by `-1` and the units

  `Оѕ_a = О¶^{(1-a)/2} В· (1 - О¶^a)/(1 - О¶)`,    `1 < a < ВЅp`, `(a, p) = 1`.

Here `О¶ = О¶_p = zeta p в„љ K` is the canonical primitive root (the one underlying `cyclotomicUnit`),
and the half-integer exponent `(1-a)/2` is interpreted in `в„¤/pв„¤` via the inverse `2вЃ»В№ = (p+1)/2` of
`2` (legitimate since `p` is odd): we realise `О¶^{(1-a)/2}` as the genuine unit power
`(zeta_spec p в„љ K).unit'^{(1-a)В·2вЃ»В№}` of the root-of-unity unit `О¶_p`.  The "real units" observation
of Washington p. 144 is that `Оѕ_a = О¶^{(1-a)/2}(1-О¶^a)/(1-О¶)` is real (totally real), because
`О¶^{(1-a)/2}(1-О¶^a)/(1-О¶) = В± sin(ПЂa/n)/sin(ПЂ/n)`.

The arithmetic content we need downstream (Washington Lemma 9.8, В§9.1) is the **Lemma 8.1 ratio
identity** (Washington p. 179):

  `(О¶^a - О¶^j)/(1 - О¶^{a+j}) = -Оѕ_{a-j} / Оѕ_{a+j} = -Оѕ_{a+j}^{-1} В· Оѕ_{a-j}`,

which we prove in the cross-multiplied (division-free) form

  `(О¶^a - О¶^j) В· Оѕ_{a+j} = -(1 - О¶^{a+j}) В· Оѕ_{a-j}`   in `рќ“ћ K`,

valid for all integer shifts `a, j` (the indices being interpreted mod `p`).  This is the bridge by
which Washington's cyclic-group `p`-th-power congruence on `(О¶^a-О¶^j)/(1-О¶^{a+j})` transfers to the
`Оѕ` units and telescopes (Lemma 9.8 steps 5вЂ“7).

## What is proven here (axiom-clean Lean)

* `xiUnit` вЂ” the unit `Оѕ_a в€€ (рќ“ћ K)ЛЈ` of Lemma 8.1 (the `О¶`-power prefactor times the cyclotomic
  unit `(1-О¶^a)/(1-О¶)`), for `a` coprime to `p`.
* `xiUnit_val`, `xiUnit_val'` вЂ” its underlying ring element.
* `zetaPow`, `zetaPow_add`, `zetaPow_congr` вЂ” integer `О¶`-powers (taken in `(рќ“ћ K)ЛЈ`) and their
  multiplicativity / mod-`p` exponent reduction.
* `halfExp_shift` вЂ” the half-power exponent shift `halfExp d в‰Ў halfExp s + j (mod p)`.
* `xi_ratio_identity` вЂ” the **Lemma 8.1 ratio identity** in cross-multiplied form (the bridge to
  Lemma 9.8).

## References
* Washington, *Introduction to Cyclotomic Fields*, 2nd ed., GTM 83, В§8.1, Lemma 8.1 (p. 144), and
  В§9.1вЂ“9.2, Lemma 9.8 (p. 178вЂ“179, the `Оѕ`-identity / telescoping).
-/

@[expose] public section

noncomputable section

open NumberField IsCyclotomicExtension

namespace BernoulliRegular.FLT37

variable (p : в„•) [hp : Fact p.Prime]
  (K : Type*) [Field K] [NumberField K] [IsCyclotomicExtension {p} в„љ K]

section Lemma81

variable {p K}

/-- The half-power exponent `(1 - a)В·2вЃ»В№` interpreted as an integer.  We use the explicit inverse
`2вЃ»В№ = (p+1)/2` of `2` modulo `p` (`p` odd), so that `2В·((p+1)/2) в‰Ў 1 (mod p)` and
`(О¶^{halfExp a})^2 = О¶^{1-a}`. -/
def halfExp (a : в„¤) : в„¤ := (1 - a) * ((p + 1) / 2 : в„•)

/-- `2 В· ((p+1)/2) = p + 1` for `p` odd, so `(p+1)/2` is a genuine inverse of `2` mod `p`. -/
theorem two_mul_succ_div_two (hp_odd : p в‰  2) : 2 * ((p + 1) / 2) = p + 1 := by
  have hodd : Odd p := hp.1.odd_of_ne_two hp_odd
  obtain вџЁr, hrвџ© := hodd
  omega

end Lemma81

section XiUnit

variable [NeZero p]

/-- The canonical root-of-unity unit `О¶_p в€€ (рќ“ћ K)ЛЈ`
(`((zeta_spec p в„љ K).toInteger_isPrimitiveRoot.isUnit (NeZero.ne p)).unit`), the same `О¶`
underlying `cyclotomicUnit`. -/
noncomputable abbrev zetaU : (рќ“ћ K)ЛЈ :=
  ((zeta_spec p в„љ K).toInteger_isPrimitiveRoot.isUnit (NeZero.ne p)).unit

/-- **Washington's Lemma 8.1 unit `Оѕ_a`.**  For `a` coprime to `p`,

  `Оѕ_a = О¶^{(1-a)/2} В· (1 - О¶^a)/(1 - О¶) в€€ (рќ“ћ K)ЛЈ`,

realised as the unit power `О¶^{halfExp a}` of the canonical root-of-unity unit `О¶_p` times the
cyclotomic unit `cyclotomicUnitUnit p K a`.  The exponent `halfExp a = (1-a)В·(p+1)/2` realises the
half-integer `О¶`-power.  We use the canonical `О¶ = zeta p в„љ K` (matching `cyclotomicUnit`). -/
noncomputable def xiUnit (a : в„•) (ha : a.Coprime p) : (рќ“ћ K)ЛЈ :=
  zetaU p K ^ (halfExp (p := p) (a : в„¤)) * cyclotomicUnitUnit p K a ha hp.1.two_le

/-- The underlying ring element of `Оѕ_a` is `О¶^{halfExp a} В· (1-О¶^a)/(1-О¶)`. -/
theorem xiUnit_val (a : в„•) (ha : a.Coprime p) :
    (xiUnit p K a ha : рќ“ћ K) =
      (zetaU p K ^ (halfExp (p := p) (a : в„¤)) : (рќ“ћ K)ЛЈ) * cyclotomicUnit p K a := by
  unfold xiUnit
  rw [Units.val_mul, cyclotomicUnitUnit_val]

/-! ### `О¶`-power exponent reduction modulo `p`

The root-of-unity unit `О¶_p` has order exactly `p` in `(рќ“ћ K)ЛЈ`, so two `О¶`-powers agree iff the
exponents are congruent mod `p`.  This is the engine for the half-power exponent arithmetic in the
Lemma 8.1 ratio identity. -/

omit hp in
/-- `О¶_p` is a primitive `p`-th root of unity *in the unit group* `(рќ“ћ K)ЛЈ`. -/
theorem unit'_isPrimitiveRoot : IsPrimitiveRoot (zetaU p K) p :=
  IsPrimitiveRoot.coe_units_iff.mp <| by
    rw [zetaU, IsUnit.unit_spec]; exact (zeta_spec p в„љ K).toInteger_isPrimitiveRoot

omit hp in
/-- The order of the root-of-unity unit `О¶_p` is exactly `p`. -/
theorem orderOf_unit' : orderOf (zetaU p K) = p :=
  (unit'_isPrimitiveRoot p K).eq_orderOf.symm

omit hp in
/-- **`О¶`-power exponent congruence:** if `a в‰Ў b (mod p)` then `О¶^a = О¶^b`. -/
theorem unit'_zpow_congr {a b : в„¤} (h : (p : в„¤) в€Ј a - b) : (zetaU p K) ^ a = (zetaU p K) ^ b := by
  have hord : (orderOf (zetaU p K) : в„¤) в€Ј a - b := by rw [orderOf_unit' p K]; exact h
  exact (orderOf_dvd_sub_iff_zpow_eq_zpow).mp hord

/-- The element `О¶^e в€€ рќ“ћ K` for an *integer* exponent `e`, realised as the value of the unit power
`О¶_p^e`.  (The ring `рќ“ћ K` has no `в„¤`-power, so integer `О¶`-powers are taken in the unit group and
coerced.)  Mod `p` the exponent is irrelevant: `zetaPow` only depends on `e mod p`. -/
noncomputable def zetaPow (e : в„¤) : рќ“ћ K := (((zetaU p K) ^ e : (рќ“ћ K)ЛЈ) : рќ“ћ K)

omit hp in
/-- `О¶^{eв‚Ѓ+eв‚‚} = О¶^{eв‚Ѓ}В·О¶^{eв‚‚}` (multiplicativity of `zetaPow`). -/
theorem zetaPow_add (eв‚Ѓ eв‚‚ : в„¤) :
    zetaPow p K (eв‚Ѓ + eв‚‚) = zetaPow p K eв‚Ѓ * zetaPow p K eв‚‚ := by
  unfold zetaPow; rw [zpow_add, Units.val_mul]

omit hp in
/-- `О¶^{(k : в„¤)} = О¶^k` (the integer power of the unit value agrees with the natural power). -/
theorem zetaPow_natCast (k : в„•) :
    zetaPow p K (k : в„¤) = ((zetaU p K) : рќ“ћ K) ^ k := by
  unfold zetaPow; rw [zpow_natCast, Units.val_pow_eq_pow_val]

omit hp in
/-- `О¶^e в‰  0` (it is a unit). -/
theorem zetaPow_ne_zero (e : в„¤) : zetaPow p K e в‰  0 := by
  unfold zetaPow; exact ((zetaU p K) ^ e).ne_zero

omit hp in
/-- **`О¶`-power exponent congruence (element form):** `О¶^{eв‚Ѓ} = О¶^{eв‚‚}` if `eв‚Ѓ в‰Ў eв‚‚ (mod p)`. -/
theorem zetaPow_congr {eв‚Ѓ eв‚‚ : в„¤} (h : (p : в„¤) в€Ј eв‚Ѓ - eв‚‚) :
    zetaPow p K eв‚Ѓ = zetaPow p K eв‚‚ := by
  unfold zetaPow; rw [unit'_zpow_congr p K h]

/-- The underlying ring element of `Оѕ_a`, written via `zetaPow`:
`Оѕ_a = О¶^{halfExp a} В· cyclotomicUnit a`. -/
theorem xiUnit_val' (a : в„•) (ha : a.Coprime p) :
    (xiUnit p K a ha : рќ“ћ K) = zetaPow p K (halfExp (p := p) (a : в„¤)) * cyclotomicUnit p K a := by
  rw [xiUnit_val]; rfl

/-! ### The Lemma 8.1 ratio identity (the bridge to Lemma 9.8)

Washington (p. 179) records the identity

  `(О¶^a - О¶^j)/(1 - О¶^{a+j}) = -Оѕ_{a-j}/Оѕ_{a+j}`.

We prove its cross-multiplied (division-free) form

  `(О¶^a - О¶^j)В·Оѕ_{a+j} = -(1 - О¶^{a+j})В·Оѕ_{a-j}`   in `рќ“ћ K`,

parametrised by integer exponents `a, j` and concrete coprime natural indices `s в‰Ў a+j`,
`d в‰Ў a-j (mod p)` realising the residues `О¶^{a+j} = О¶^s`, `О¶^{a-j} = О¶^d`.

The proof multiplies through by `О¶ - 1` (a non-zero-divisor in the domain `рќ“ћ K`), uses
`(О¶-1)В·cyclotomicUnit k = О¶^k - 1`, and reduces the resulting `О¶`-power identity to the single
fact `О¶^{2В·2вЃ»В№} = О¶`, i.e. `2В·((p+1)/2) в‰Ў 1 (mod p)`.  -/

omit hp in
/-- The integer-exponent congruence underlying `О¶^e = О¶^d`: from the unit equality
`О¶_p^e = О¶_p^d` we extract `p в€Ј d - e`. -/
theorem dvd_of_unit'_zpow_eq {e : в„¤} {d : в„•}
    (h : (zetaU p K) ^ e = (zetaU p K) ^ (d : в„¤)) :
    (p : в„¤) в€Ј (d : в„¤) - e := by
  have hord : (orderOf (zetaU p K) : в„¤) в€Ј e - (d : в„¤) :=
    orderOf_dvd_sub_iff_zpow_eq_zpow.mpr h
  rw [orderOf_unit' p K] at hord
  rwa [в†ђ dvd_neg, neg_sub] at hord

omit [NeZero p] in
/-- `2В·((p+1)/2) = p+1` over `в„¤` (the cast of the natural identity). -/
theorem two_mul_inv2_int (hp_odd : p в‰  2) :
    (2 : в„¤) * ((p + 1) / 2 : в„•) = (p : в„¤) + 1 := by
  have hnat := two_mul_succ_div_two (p := p) hp_odd
  omega

omit [NeZero p] in
/-- The half-power exponent shift `halfExp d в‰Ў halfExp s + j (mod p)` whenever `s - d в‰Ў 2j (mod p)`.
This is the single arithmetic fact (`(s-d)В·2вЃ»В№ в‰Ў j`) driving the Lemma 8.1 ratio cancellation:
`halfExp d - halfExp s - j = (s-d)*2вЃ»В№ - j`, and `(s-d)*2вЃ»В№ в‰Ў j` since `2*2вЃ»В№ в‰Ў 1` and
`s-d в‰Ў 2j`. -/
theorem halfExp_shift (hp_odd : p в‰  2) {j : в„¤} {s d : в„•}
    (hdvd : (p : в„¤) в€Ј ((s : в„¤) - (d : в„¤)) - 2 * j) :
    (p : в„¤) в€Ј halfExp (p := p) (d : в„¤) - (halfExp (p := p) (s : в„¤) + j) := by
  have h2 := two_mul_inv2_int (p := p) hp_odd
  obtain вџЁt, htвџ© := hdvd
  -- `s - d = 2j + pВ·t`.  Then `2В·(halfExp d - halfExp s - j) = (s-d)(p+1) - 2j = pВ·(...)`.
  unfold halfExp
  -- `(1-d)c - ((1-s)c + j) = (s-d)c - j = (2j+pt)c - j = j(2c-1) + ptc = pВ·(j + tc)`,
  -- using `2c = p+1` (so `2c - 1 = p`).  Witness: `j + tВ·c`.
  refine вџЁj + t * ((p + 1) / 2 : в„•), ?_вџ©
  have hsd : (s : в„¤) - (d : в„¤) = 2 * j + (p : в„¤) * t := by linarith [ht]
  -- (1-d)c - ((1-s)c + j) - p(j + tc) = cВ·((s-d) - 2j - pt) + jВ·(2c - (p+1)) = 0.
  linear_combination ((p + 1) / 2 : в„•) * hsd + j * h2

set_option maxHeartbeats 800000 in
-- The final `ring` over the many distinct `О¶`-power atoms is heartbeat-heavy; raise the limit.
/-- **Washington's Lemma 8.1 ratio identity, cross-multiplied (general odd prime `p`).**

For integers `a, j` and natural numbers `s, d` coprime to `p` with
`О¶^{a+j} = О¶^s`, `О¶^{a-j} = О¶^d` (i.e. `s в‰Ў a+j`, `d в‰Ў a-j (mod p)`),

  `(О¶^a - О¶^j) В· Оѕ_s = -(1 - О¶^s) В· Оѕ_d`     in `рќ“ћ K`,

where `Оѕ_s, Оѕ_d` are Washington's real cyclotomic units (`xiUnit`) and `О¶^e = zetaPow e`.  This is
the bridge that transfers the cyclic-group `p`-th-power congruence on `(О¶^a-О¶^j)/(1-О¶^{a+j})` to the
`Оѕ` units (Washington Lemma 9.8, steps 5вЂ“7, p. 179).

The proof multiplies both sides by `О¶ - 1` (a non-zero-divisor in the domain `рќ“ћ K`), telescopes the
cyclotomic factors via `(О¶-1)В·cyclotomicUnit k = О¶^k - 1`, and the resulting pure `О¶`-power identity
collapses using the single shift `halfExp d в‰Ў halfExp s + j (mod p)` (`halfExp_shift`). -/
theorem xi_ratio_identity (hp_odd : p в‰  2) (a j : в„¤) (s d : в„•)
    (hs : s.Coprime p) (hd : d.Coprime p)
    (hs_eq : (zetaU p K) ^ (a + j) = (zetaU p K) ^ (s : в„¤))
    (hd_eq : (zetaU p K) ^ (a - j) = (zetaU p K) ^ (d : в„¤)) :
    (zetaPow p K a - zetaPow p K j) * (xiUnit p K s hs : рќ“ћ K) =
      -(1 - zetaPow p K (s : в„¤)) * (xiUnit p K d hd : рќ“ћ K) := by
  -- `О¶ - 1` is a non-zero-divisor.
  have hne : (((zetaU p K) : рќ“ћ K) - 1) в‰  0 := (zeta_spec p в„љ K).zeta_sub_one_prime'.ne_zero
  -- Abbreviations for the half-power exponents of the two `Оѕ` factors.
  set Hs : в„¤ := halfExp (p := p) (s : в„¤) with hHs
  set Hd : в„¤ := halfExp (p := p) (d : в„¤) with hHd
  -- The `О¶`-power residue facts.
  have hsval : zetaPow p K (a + j) = zetaPow p K (s : в„¤) := by unfold zetaPow; rw [hs_eq]
  have hdval : zetaPow p K (a - j) = zetaPow p K (d : в„¤) := by unfold zetaPow; rw [hd_eq]
  -- It suffices after right-multiplication by `О¶ - 1`.
  apply mul_right_cancelв‚Ђ hne
  -- Expand `Оѕ` values.
  rw [xiUnit_val', xiUnit_val']
  -- Telescope the cyclotomic factors: `(О¶-1)В·cyc k = О¶^k - 1 = О¶^{(k:в„¤)} - 1`.
  have hcyc_s : (((zetaU p K) : рќ“ћ K) - 1) * cyclotomicUnit p K s = zetaPow p K (s : в„¤) - 1 := by
    rw [zetaPow_natCast]; exact zeta_sub_one_mul_cyclotomicUnit p K s
  have hcyc_d : (((zetaU p K) : рќ“ћ K) - 1) * cyclotomicUnit p K d = zetaPow p K (d : в„¤) - 1 := by
    rw [zetaPow_natCast]; exact zeta_sub_one_mul_cyclotomicUnit p K d
  -- Push `(О¶-1)` inside to hit the telescopes; rewrite `О¶^s`, `О¶^d` by the residues.
  rw [show (zetaPow p K a - zetaPow p K j) * (zetaPow p K Hs * cyclotomicUnit p K s) *
        (((zetaU p K) : рќ“ћ K) - 1) =
        (zetaPow p K a - zetaPow p K j) * zetaPow p K Hs *
          ((((zetaU p K) : рќ“ћ K) - 1) * cyclotomicUnit p K s) by ring,
    show -(1 - zetaPow p K (s : в„¤)) * (zetaPow p K Hd * cyclotomicUnit p K d) *
        (((zetaU p K) : рќ“ћ K) - 1) =
        -(1 - zetaPow p K (s : в„¤)) * zetaPow p K Hd *
          ((((zetaU p K) : рќ“ћ K) - 1) * cyclotomicUnit p K d) by ring,
    hcyc_s, hcyc_d, в†ђ hsval, в†ђ hdval]
  -- The residue `s - d в‰Ў 2j (mod p)`, from `s в‰Ў a+j`, `d в‰Ў a-j`.
  have hsd2j : (p : в„¤) в€Ј ((s : в„¤) - (d : в„¤)) - 2 * j := by
    have hs1 : (p : в„¤) в€Ј (s : в„¤) - (a + j) := dvd_of_unit'_zpow_eq p K hs_eq
    have hd1 : (p : в„¤) в€Ј (d : в„¤) - (a - j) := dvd_of_unit'_zpow_eq p K hd_eq
    have : ((s : в„¤) - (d : в„¤)) - 2 * j = ((s : в„¤) - (a + j)) - ((d : в„¤) - (a - j)) := by ring
    rw [this]; exact dvd_sub hs1 hd1
  -- The half-power shift `Hd в‰Ў Hs + j (mod p)`.
  have hshift : (p : в„¤) в€Ј Hd - (Hs + j) := by
    rw [hHd, hHs]; exact halfExp_shift (p := p) hp_odd hsd2j
  -- Master `О¶`-power facts:
  --   MS : О¶^{a+j} = О¶^a В· О¶^j
  --   MF : О¶^{Hd}        = О¶^{Hs} В· О¶^j        (halfExp shift)
  --   MG : О¶^{Hd}В·О¶^{a-j} = О¶^{Hs} В· О¶^a       (halfExp shift)
  have MS : zetaPow p K (a + j) = zetaPow p K a * zetaPow p K j := zetaPow_add p K a j
  have MF : zetaPow p K Hd = zetaPow p K Hs * zetaPow p K j := by
    rw [в†ђ zetaPow_add p K]; exact zetaPow_congr p K hshift
  have MG : zetaPow p K Hd * zetaPow p K (a - j) = zetaPow p K Hs * zetaPow p K a := by
    rw [в†ђ zetaPow_add p K, в†ђ zetaPow_add p K]
    apply zetaPow_congr p K
    -- (Hd + (a-j)) - (Hs + a) = Hd - (Hs+j) в‰Ў 0 (mod p)
    have : Hd + (a - j) - (Hs + a) = Hd - (Hs + j) := by ring
    rw [this]; exact hshift
  -- Finish: expand `О¶^{a+j}`, the `О¶^{Hd}` terms, then `ring`.
  rw [MS, show -(1 - zetaPow p K a * zetaPow p K j) * zetaPow p K Hd * (zetaPow p K (a - j) - 1) =
        -(1 - zetaPow p K a * zetaPow p K j) *
          (zetaPow p K Hd * zetaPow p K (a - j) - zetaPow p K Hd) by ring,
    MG, MF]
  ring

end XiUnit

end BernoulliRegular.FLT37

end
