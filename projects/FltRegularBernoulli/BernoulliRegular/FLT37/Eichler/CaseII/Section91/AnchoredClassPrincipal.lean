    (ő∑ : nthRootsFinset 37 (1 : ūĚďě (CyclotomicField 37 ‚Ąö))),
    ő∑ ‚Č† D.etaZero ‚Üí
    ClassGroup.mk0 ‚ü®D.rootIdeal ő∑,
        mem_nonZeroDivisors_iff_ne_zero.mpr
          (by rw [Ideal.zero_eq_bot]
              exact caseII_rootIdeal_ne_bot D (by decide : (37 : ‚Ąē) ‚Č† 2) ő∑)‚ü© =
