theorem stickelbergerOrbitFaithful_of_split
    (he : (S.concrete.descentPrime.under ℤ).ramificationIdxIn (𝓞 K) = 1)
    (hf : (S.concrete.descentPrime.under ℤ).inertiaDegIn (𝓞 K) = 1) :
    S.StickelbergerOrbitFaithful := by
