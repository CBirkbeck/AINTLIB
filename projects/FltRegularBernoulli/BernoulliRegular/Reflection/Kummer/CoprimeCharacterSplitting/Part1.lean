theorem coprimeCanonicalClassGroupModPHom_ne_one_of_not_isPow_badSet_of_locallyPrimaryPseudoUnit
    (hp_ne_two : p ≠ 2) (hp_odd : Odd p)
    (η : 𝓞 K) (hη_ne : η ≠ 0)
