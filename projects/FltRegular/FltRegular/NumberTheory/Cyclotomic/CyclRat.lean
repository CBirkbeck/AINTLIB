set_option backward.isDefEq.respectTransparency false in
theorem zeta_sub_one_dvb_p [Fact p.Prime] {О· : R} (hО· : О· вҲҲ nthRootsFinset p 1)
    (hne1 : О· вү  1) : 1 - О· вҲЈ (p : R) := by
  have hО· : IsPrimitiveRoot (О· : CyclotomicField p в„ҡ) (p ^ 1) := by
    simpa using prim_coe О· (isPrimitiveRoot_of_mem_nthRootsFinset Fact.out hО· hne1)
  have : IsCyclotomicExtension {p ^ (0 + 1)} в„ҡ (CyclotomicField p в„ҡ) := by
    simp only [zero_add, pow_one]
    infer_instance
  convert neg_dvd.2 <| mem_span_singleton.1 <| Rat.p_mem_span_zeta_sub_one p 0 hО· using 1
  ext
  simp

set_option backward.isDefEq.respectTransparency false in
theorem one_sub_zeta_prime [Fact p.Prime] {О· : R} (hО· : О· вҲҲ nthRootsFinset p 1)
    (hne1 : О· вү  1) : Prime (1 - О·) := by
  have h := prim_coe О· (isPrimitiveRoot_of_mem_nthRootsFinset Fact.out hО· hne1)
  simpa using! h.zeta_sub_one_prime'.neg

theorem diff_of_roots [hp : Fact p.Prime] (ph : 5 вүӨ p) {О·вӮҒ О·вӮӮ : R}
    (hО·вӮҒ : О·вӮҒ вҲҲ nthRootsFinset p 1) (hО·вӮӮ : О·вӮӮ вҲҲ nthRootsFinset p 1) (hdiff : О·вӮҒ вү  О·вӮӮ)
    (hwlog : О·вӮҒ вү  1) : вҲғ u : RЛЈ, О·вӮҒ - О·вӮӮ = u * (1 - О·вӮҒ) := by
  have _ : 2 вүӨ p := le_trans (by decide) ph
  have h := isPrimitiveRoot_of_mem_nthRootsFinset Fact.out hО·вӮҒ hwlog
  rcases h.nthRootsFinset_pairwise_associated_sub_one_sub_of_prime hp.out hО·вӮҒ hО·вӮӮ hdiff with вҹЁu, huвҹ©
  refine вҹЁ-u, by grind [Units.val_neg]вҹ©

theorem diff_of_roots2 [Fact p.Prime] (ph : 5 вүӨ p) {О·вӮҒ О·вӮӮ : R} (hО·вӮҒ : О·вӮҒ вҲҲ nthRootsFinset p 1)
    (hО·вӮӮ : О·вӮӮ вҲҲ nthRootsFinset p 1) (hdiff : О·вӮҒ вү  О·вӮӮ) (hwlog : О·вӮҒ вү  1) :
    вҲғ u : RЛЈ, О·вӮӮ - О·вӮҒ = u * (1 - О·вӮҒ) := by
  obtain вҹЁu, huвҹ© := diff_of_roots ph hО·вӮҒ hО·вӮӮ hdiff hwlog
  exact вҹЁ-u, by simp [вҶҗ hu]вҹ©

lemma fltIdeals_coprime2_lemma [Fact p.Prime] (ph : 5 вүӨ p) {x y : в„Ө} {О·вӮҒ О·вӮӮ : R}
    (hО·вӮҒ : О·вӮҒ вҲҲ nthRootsFinset p 1)
    (hО·вӮӮ : О·вӮӮ вҲҲ nthRootsFinset p 1) (hdiff : О·вӮҒ вү  О·вӮӮ) (hp : IsCoprime x y)
    (hp2 : В¬(p : в„Ө) вҲЈ (x + y : в„Ө)) (hwlog : О·вӮҒ вү  1) :
    (fltIdeals p x y hО·вӮҒ) вҠ” (fltIdeals p x y hО·вӮӮ) = вҠӨ := by
  apply by_contradiction
  intro h
  let I := fltIdeals p x y hО·вӮҒ вҠ” fltIdeals p x y hО·вӮӮ
  obtain вҹЁP, hP1, hP2вҹ© := exists_le_maximal I h
  have hiP : fltIdeals p x y hО·вӮҒ вүӨ P := le_trans le_sup_left hP2
  have hel1 : вҲғ v : RЛЈ, (v : R) * y * (1 - О·вӮҒ) вҲҲ I := by
    obtain вҹЁv, hvвҹ© := diff_of_roots ph hО·вӮҒ hО·вӮӮ hdiff hwlog
    refine вҹЁv, ?_вҹ©
    have := Ideal.sub_mem _
      (mem_sup_left (mem_fltIdeals x y hО·вӮҒ)) (mem_sup_right (mem_fltIdeals x y hО·вӮӮ))
    rwa [add_sub_add_left_eq_sub, вҶҗ sub_mul, hv, mul_right_comm] at this
  have hel2 : вҲғ v : RЛЈ, (v : R) * x * (1 - О·вӮҒ) вҲҲ I := by
    obtain вҹЁv, hvвҹ© := diff_of_roots2 ph hО·вӮҒ hО·вӮӮ hdiff hwlog
    refine вҹЁv, ?_вҹ©
    have := Ideal.add_mem _ (mul_mem_left _ О·вӮӮ (mem_sup_left (mem_fltIdeals x y hО·вӮҒ)))
        (mul_mem_left _ (-О·вӮҒ) (mem_sup_right (mem_fltIdeals x y hО·вӮӮ)))
    have h1 : О·вӮӮ * (вҶ‘x + О·вӮҒ * вҶ‘y) + -О·вӮҒ * (вҶ‘x + О·вӮӮ * вҶ‘y) = (О·вӮӮ - О·вӮҒ) * x := by ring
    rwa [h1, hv, mul_right_comm] at this
  have hel11 : (y : R) * (1 - О·вӮҒ) вҲҲ P := by
    obtain вҹЁv, hvвҹ© := hel1
    rw [mul_assoc] at hv
    exact (unit_mul_mem_iff_mem P v.isUnit).1 (hP2 hv)
  have hel22 : (x : R) * (1 - О·вӮҒ) вҲҲ P := by
    obtain вҹЁv, hvвҹ© := hel2
    rw [mul_assoc] at hv
    exact (unit_mul_mem_iff_mem P v.isUnit).1 (hP2 hv)
  have hPrime := hP1.isPrime
  have hprime2 := IsPrime.mem_or_mem hPrime hel11
  have hprime3 := IsPrime.mem_or_mem hPrime hel22
  have HC : 1 - О·вӮҒ вҲҲ P вҶ’ False := by
    intro h
    have eta_sub_one_ne_zero := sub_ne_zero.mpr (Ne.symm hwlog)
    have hО·prime : IsPrime (Ideal.span ({1 - О·вӮҒ} : Set R)) := by
      rw [span_singleton_prime eta_sub_one_ne_zero]
      apply one_sub_zeta_prime hО·вӮҒ hwlog
    have H5 : IsPrime (Ideal.span ({(p : в„Ө)} : Set в„Ө)) := by
      have h2 : (p : в„Ө) вү  0 := by simp [NeZero.ne p]
      have h1 : Prime (p : в„Ө) := by
        rw [вҶҗ prime_iff_prime_int]
        exact Fact.out
      rw [span_singleton_prime h2]
      apply h1
    have hО·P : Ideal.span ({1 - О·вӮҒ} : Set R) = P := by
      have hle : Ideal.span ({1 - О·вӮҒ} : Set R) вүӨ P := by
        rw [span_le]
        simp [h]
      apply (@Ring.DimensionLeOne.prime_le_prime_iff_eq _ _ _ _ _ hО·prime hPrime _).1 hle
      intro hbot
      rw [span_eq_bot] at hbot
      simp only [Set.mem_singleton_iff, forall_eq, sub_eq_zero] at hbot
      exact hwlog hbot.symm
    have hcapZ : P.comap (Int.castRingHom R) = Ideal.span ({(p : в„Ө)} : Set в„Ө) := by
      have H1 : Ideal.span ({(p : в„Ө)} : Set в„Ө) вүӨ P.comap (Int.castRingHom R) := by
        rw [вҶҗ hО·P]
        apply le_comap_of_map_le _
        rw [map_span]
        simp only [eq_intCast, Set.image_singleton, Int.cast_natCast]
        rw [span_singleton_le_span_singleton]
        apply zeta_sub_one_dvb_p hО·вӮҒ hwlog
      have H2 : IsPrime (P.comap (Int.castRingHom R)) := IsPrime.comap _
      have H4 : Ideal.span ({(p : в„Ө)} : Set в„Ө) вү  вҠҘ := by simp [NeZero.ne p]
      apply ((@Ring.DimensionLeOne.prime_le_prime_iff_eq _ _ _ _ _ H5 H2 H4).1 H1).symm
    have hxyinP : (x + y : R) вҲҲ P := by
      have H1 : (x : R) + О·вӮҒ * y вҲҲ P := by
        apply hiP
        apply Submodule.mem_span_singleton_self
      have H2 : О·вӮҒ * y = y - y * (1 - О·вӮҒ) := by ring
      rw [H2] at H1
      have H3 : вҶ‘x + (вҶ‘y - вҶ‘y * (1 - О·вӮҒ)) = вҶ‘x + вҶ‘y + -вҶ‘y * (1 - О·вӮҒ) := by ring
      rw [H3] at H1
      have H4 : -вҶ‘y * (1 - О·вӮҒ) вҲҲ P := by
        rw [вҶҗ hО·P, Ideal.mem_span_singleton']
        exact вҹЁ-(y : R), rflвҹ©
      apply (Ideal.add_mem_iff_left P H4).1 H1
    have hxyinP2 : x + y вҲҲ Ideal.span ({(p : в„Ө)} : Set в„Ө) := by
      rw [вҶҗ hcapZ]
      simp [hxyinP]
    rw [mem_span_singleton] at hxyinP2
    apply absurd hxyinP2 hp2
  rcases hprime2 with hprime2 | hprime2
  В· rcases hprime3 with hprime3 | hprime3
    В· obtain вҹЁa, b, habвҹ© := hp
      have hone := P.add_mem (Ideal.mul_mem_left P a hprime3) (Ideal.mul_mem_left P b hprime2)
      norm_cast at hone
      rw [hab] at hone
      norm_cast at hone
      rw [вҶҗ eq_top_iff_one] at hone
      have hcontra := IsPrime.ne_top hPrime
      rw [hone] at hcontra
      simp only [Ne, not_true] at hcontra
    apply HC hprime3
  В· apply HC hprime2

theorem fltIdeals_coprime2 [Fact p.Prime] (ph : 5 вүӨ p) {x y : в„Ө} {О·вӮҒ О·вӮӮ : R}
    (hО·вӮҒ : О·вӮҒ вҲҲ nthRootsFinset p 1)
    (hО·вӮӮ : О·вӮӮ вҲҲ nthRootsFinset p 1) (hdiff : О·вӮҒ вү  О·вӮӮ) (hp : IsCoprime x y)
    (hp2 : В¬(p : в„Ө) вҲЈ (x + y : в„Ө)) (hwlog : О·вӮҒ вү  1) :
    IsCoprime (fltIdeals p x y hО·вӮҒ) (fltIdeals p x y hО·вӮӮ) := by
  rw [Ideal.isCoprime_iff_add]
  simpa using fltIdeals_coprime2_lemma ph hО·вӮҒ hО·вӮӮ hdiff hp hp2 hwlog

theorem fltIdeals_coprime (hpri : p.Prime) (p5 : 5 вүӨ p) {x y z : в„Ө}
    (H : x ^ p + y ^ p = z ^ p) {О·вӮҒ О·вӮӮ : R} (hxy : IsCoprime x y)
    (hО·вӮҒ : О·вӮҒ вҲҲ nthRootsFinset p 1) (hО·вӮӮ : О·вӮӮ вҲҲ nthRootsFinset p 1) (hdiff : О·вӮҒ вү  О·вӮӮ)
    (caseI : В¬вҶ‘p вҲЈ x * y * z) :
    have : Fact p.Prime := вҹЁhpriвҹ©
    IsCoprime (fltIdeals p x y hО·вӮҒ) (fltIdeals p x y hО·вӮӮ) := by
  have : Fact p.Prime := вҹЁhpriвҹ©
  by_cases h : О·вӮҒ вү  1
  В· apply fltIdeals_coprime2 p5 hО·вӮҒ hО·вӮӮ hdiff hxy (aux_lem_flt H caseI) h
  В· have h2 : О·вӮӮ вү  1 := by
      simp only [ne_eq, not_not] at h
      rw [h] at hdiff
      exact hdiff.symm
    have := fltIdeals_coprime2 p5 hО·вӮӮ hО·вӮҒ hdiff.symm hxy (aux_lem_flt H caseI) h2
    exact this.symm

variable {L}

theorem dvd_last_coeff_cycl_integer [hp : Fact p.Prime] {О¶ : рқ“һ L}
    (hО¶ : IsPrimitiveRoot О¶ p) {f : Fin p вҶ’ в„Ө}
    (hf : вҲғ i, f i = 0) {m : в„Ө} (hdiv : вҶ‘m вҲЈ вҲ‘ j, f j вҖў О¶ ^ (j : в„•)) :
    m вҲЈ f вҹЁp.pred, pred_lt hp.out.ne_zeroвҹ© := by
  obtain вҹЁi, Hiвҹ© := hf
  have hlast :
    (Fin.castOrderIso (succ_pred_prime hp.out)) (Fin.last p.pred) =
    вҹЁp.pred, pred_lt hp.out.ne_zeroвҹ© := Fin.ext rfl
  let О¶' := (О¶ : L)
  have hО¶' : IsPrimitiveRoot О¶' p := IsPrimitiveRoot.coe_submonoidClass_iff.2 hО¶
  set b := hО¶'.integralPowerBasis with hb
  have hdim : b.dim = p.pred := by rw [hО¶'.integralPowerBasis_dim, totient_prime hp.out,
    pred_eq_sub_one]
  by_cases H : i = вҹЁp - 1, pred_lt hp.out.ne_zeroвҹ©
  В· simp [H.symm, Hi]
  have hi : вҶ‘i < p - 1 := by
    by_contra! habs
    simp [le_antisymm habs (le_pred_of_lt (Fin.is_lt i))] at H
  obtain вҹЁy, hyвҹ© := hdiv
  rw [вҶҗ Equiv.sum_comp (Fin.castOrderIso (succ_pred_prime hp.out)).toEquiv,
    Fin.sum_univ_castSucc] at hy
  simp only [hlast, RelIso.coe_fn_toEquiv, Fin.val_mk] at hy
  rw [hО¶.pow_sub_one_eq hp.out.one_lt, вҶҗ sum_neg_distrib, smul_sum, sum_range, вҶҗ sum_add_distrib,
    вҶҗ (Fin.castOrderIso hdim).toEquiv.sum_comp] at hy
  simp only [RelIso.coe_fn_toEquiv, Fin.val_castSucc, Fin.coe_orderIso_apply] at hy
  conv_lhs at hy =>
    congr; rfl; ext x
    rw [smul_neg]
    congr; congr; rfl; congr
    rw [show О¶ = hО¶'.toInteger from rfl, вҶҗ hО¶'.integralPowerBasis_gen, вҶҗ hb]
    rfl; rfl; congr; congr; rfl; congr
    rw [show О¶ = hО¶'.toInteger from rfl, вҶҗ hО¶'.integralPowerBasis_gen, вҶҗ hb]
  conv_lhs at hy =>
    congr; rfl; ext x
    rw [вҶҗ show вҲҖ y, _ = _ from fun y => congr_fun b.coe_basis y, вҶҗ sub_eq_add_neg]
  rw [sum_sub_distrib] at hy
  replace hy := congr_arg (b.basis.coord ((Fin.castOrderIso hdim.symm) вҹЁi, hiвҹ©)) hy
  rw [вҶҗ b.basis.equivFun_symm_apply, вҶҗ b.basis.equivFun_symm_apply, LinearMap.map_sub,
    b.basis.coord_equivFun_symm, b.basis.coord_equivFun_symm, вҶҗ smul_eq_mul,
    Int.cast_smul_eq_zsmul] at hy
  obtain вҹЁn, hnвҹ© := b.basis.dvd_coord_smul ((Fin.castOrderIso hdim.symm) вҹЁi, hiвҹ©) y m
  rw [hn] at hy
  simp only [Fin.castOrderIso_apply, Fin.cast_mk, Fin.castSucc_mk, Fin.eta, Hi, zero_sub,
    neg_eq_iff_eq_neg] at hy
  rw [hy]
  simp [dvd_neg]

theorem dvd_coeff_cycl_integer (hp : p.Prime) {О¶ : рқ“һ L} (hО¶ : IsPrimitiveRoot О¶ p)
    {f : Fin p вҶ’ в„Ө} (hf : вҲғ i, f i = 0) {m : в„Ө} (hdiv : вҶ‘m вҲЈ вҲ‘ j, f j вҖў О¶ ^ (j : в„•)) :
    вҲҖ j, m вҲЈ f j := by
  let О¶' := (О¶ : L)
  have : Fact p.Prime := вҹЁhpвҹ©
  have hО¶' : IsPrimitiveRoot О¶' p := IsPrimitiveRoot.coe_submonoidClass_iff.2 hО¶
  have hlast : (Fin.castOrderIso (succ_pred_prime hp)) (Fin.last p.pred) =
      вҹЁp.pred, pred_lt hp.ne_zeroвҹ© := Fin.ext rfl
  set b := hО¶'.integralPowerBasis with hb
  have hdim : b.dim = p.pred := by rw [hО¶'.integralPowerBasis_dim, totient_prime hp,
    pred_eq_sub_one]
  have last_dvd := dvd_last_coeff_cycl_integer hО¶ hf hdiv
  intro j
  by_cases H : j = вҹЁp - 1, pred_lt hp.ne_zeroвҹ©
  В· simpa [H] using last_dvd
  have hj : вҶ‘j < p - 1 := by
    by_contra! habs
    simp [le_antisymm habs (le_pred_of_lt (Fin.is_lt j))] at H
  obtain вҹЁy, hyвҹ© := hdiv
  rw [вҶҗ Equiv.sum_comp (Fin.castOrderIso (succ_pred_prime hp)).toEquiv, Fin.sum_univ_castSucc] at hy
  simp only [hlast, RelIso.coe_fn_toEquiv, Fin.val_mk] at hy
  rw [hО¶.pow_sub_one_eq hp.one_lt, вҶҗ sum_neg_distrib, smul_sum, sum_range, вҶҗ sum_add_distrib,
    вҶҗ (Fin.castOrderIso hdim).toEquiv.sum_comp] at hy
  simp only [RelIso.coe_fn_toEquiv, Fin.val_castSucc, Fin.coe_orderIso_apply] at hy
  conv_lhs at hy =>
    congr; rfl; ext x
    rw [smul_neg]
    congr; congr; rfl; congr
    rw [show О¶ = hО¶'.toInteger from rfl, вҶҗ hО¶'.integralPowerBasis_gen, вҶҗ hb]
    rfl; rfl; congr; congr; rfl; congr
    rw [show О¶ = hО¶'.toInteger from rfl, вҶҗ hО¶'.integralPowerBasis_gen, вҶҗ hb]
  conv_lhs at hy =>
    congr; rfl; ext x
    rw [вҶҗ show вҲҖ y, _ = _ from fun y => congr_fun b.coe_basis y, вҶҗ sub_eq_add_neg]
  rw [sum_sub_distrib] at hy
  replace hy := congr_arg (b.basis.coord ((Fin.castOrderIso hdim.symm) вҹЁj, hjвҹ©)) hy
  rw [вҶҗ b.basis.equivFun_symm_apply, вҶҗ b.basis.equivFun_symm_apply, LinearMap.map_sub,
    b.basis.coord_equivFun_symm, b.basis.coord_equivFun_symm] at hy
  simp only [Fin.castOrderIso_apply, Fin.cast_mk, Fin.castSucc_mk, Fin.eta,
    Module.Basis.coord_apply, sub_eq_iff_eq_add] at hy
  obtain вҹЁn, hnвҹ© := b.basis.dvd_coord_smul ((Fin.cast hdim.symm) вҹЁj, hjвҹ©) y m
  rw [hy, вҶҗ smul_eq_mul, Int.cast_smul_eq_zsmul, вҶҗ b.basis.coord_apply, вҶҗ Fin.cast_mk hdim.symm _
    hj, hn]
  exact dvd_add (dvd_mul_right _ _) last_dvd

end IntFacts
