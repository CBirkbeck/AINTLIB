open Ideal IsCyclotomicExtension

theorem exists_int_sub_pow_prime_dvd {A : Type*} [CommRing A] [IsCyclotomicExtension {p} в„Ө A]
    [hp : Fact p.Prime] (a : A) : вҲғ m : в„Ө, a ^ p - m вҲҲ span ({(p : A)} : Set A) := by
  refine Algebra.adjoin_induction ?_ ?_ ?_ ?_ (adjoin_roots (S := {p}) (A := в„Ө) a)
  В· intro x hx
    use 1
    simp_all
  В· intro r
    use r ^ p
    simp
  В· rintro x y _ _ вҹЁb, hbвҹ© вҹЁc, hcвҹ©
    obtain вҹЁr, hrвҹ© := exists_add_pow_prime_eq hp.out x y
    rw [mul_assoc, mul_assoc] at hr
    rw [hr]
    use c + b
    push_cast
    rw [sub_add_eq_sub_sub, sub_eq_add_neg, sub_eq_add_neg, add_comm (x ^ p + _), add_assoc,
      add_assoc]
    apply Ideal.add_mem _ _
    В· convert Ideal.add_mem _ hb hc using 1
      ring
    В· rw [mem_span_singleton]
      exact dvd_mul_right _ _
  В· rintro x y _ _ вҹЁb, hbвҹ© вҹЁc, hcвҹ©
    rw [mul_pow]
    use b * c
    have := Ideal.mul_mem_left _ (x ^ p) hc
    rw [mul_sub] at this
    rw [вҶҗ Ideal.Quotient.eq_zero_iff_mem, map_sub] at this hb вҠў
    convert this using 2
    rw [Int.cast_mul, _root_.map_mul, _root_.map_mul]
    congr 1
    exact (sub_eq_zero.mp hb).symm

local notation "R" => рқ“һ (CyclotomicField p в„ҡ)

/-- The principal ideal generated by `x + y О¶^i` for integer `x` and `y` -/
@[nolint unusedArguments]
noncomputable
def fltIdeals [Fact p.Prime] (x y : в„Ө) {О· : R} (_ : О· вҲҲ nthRootsFinset p 1) : Ideal R :=
  Ideal.span ({x + О· * y} : Set R)

variable {p}

theorem mem_fltIdeals [Fact p.Prime] (x y : в„Ө) {О· : R} (hО· : О· вҲҲ nthRootsFinset p 1) :
    вҶ‘x + О· * вҶ‘y вҲҲ fltIdeals p x y hО· :=
  mem_span_singleton.mpr dvd_rfl

open IsPrimitiveRoot

theorem prim_coe (О¶ : R) (hО¶ : IsPrimitiveRoot О¶ p) :
    IsPrimitiveRoot (О¶ : CyclotomicField p в„ҡ) p :=
  coe_submonoidClass_iff.mpr hО¶

theorem aux_lem_flt [Fact p.Prime] {x y z : в„Ө} (H : x ^ p + y ^ p = z ^ p)
    (caseI : В¬вҶ‘p вҲЈ x * y * z) : В¬(p : в„Ө) вҲЈ (x + y : в„Ө) := by
  intro habs
  replace habs : вҶ‘p вҲЈ (x + y : в„Ө) := by simpa using habs
  rw [вҶҗ ZMod.intCast_zmod_eq_zero_iff_dvd, Int.cast_add] at habs
  replace H := congr_arg (fun x : в„Ө => (x : ZMod p)) H.symm
  simp only [Int.cast_add, Int.cast_pow, ZMod.pow_card, habs,
    ZMod.intCast_zmod_eq_zero_iff_dvd] at H
  exact caseI (Dvd.dvd.mul_left H _)

