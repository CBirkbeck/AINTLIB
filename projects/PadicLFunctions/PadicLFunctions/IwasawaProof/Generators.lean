import PadicLFunctions.IwasawaProof.GaloisAction
import PadicLFunctions.IwasawaProof.FundamentalSequence
import PadicLFunctions.Iwasawa.CyclotomicUnits
import PadicLFunctions.Iwasawa.ZetaGalois

/-!
# Generators for the cyclotomic units (RJW В§12.3вҖ“12.4, TeX 3450вҖ“3578) вҖ” E12.4

The conjugation-fixed units `Оі_{n,a} = Оҫ^{(1вҲ’a)/2} c_n(a) вҲҲ рқ’ҹ_n^+`; the global generator
lemmas (`lem:cyc units gen`, `cor:cyc units gen 2`); the closure lemma
(`lem:closure`, p-adic closure of a `в„Ө`-span = `в„Ө_p`-span); and `LemmaGeneratorCinfty1`
(`рқ’һ_{вҲһ,1}^+` cyclic over `Оӣ(рқ’ў^+)`, generated by `(wОі_{n,a})_n`). This cluster natively
resolves the В§11 b2-logged `a вүЎ 1 mod p` note: `w вҲҲ Ој_{pвҲ’1}` is the TeichmГјller
correction making `wОі_{n,a} вүЎ 1 mod рқ”ӯ_n`. Skeleton.
-/

open PadicLFunctions PadicLFunctions.Coleman

noncomputable section

namespace PadicLFunctions.Coleman

variable (p : в„•) [hp : Fact p.Prime]

/-! ## Half-powers of `Оҫ_{p^n}` (the `Оҫ^{c/2}` arithmetic, `p` odd)

The exponents `(1вҲ’a)/2`, `a/2`, `1/2` of RJW TeX 3458 are read in `ZMod (p^n)` (`p`
odd вҹ№ `2` invertible), realised concretely as `Оҫ_{p^n}^{(c : ZMod (p^n)).val}`. The
`modEq`-engine `zetaSys_pow_eq_pow_of_modEq` (GaloisAction) turns the exponent ring
arithmetic into root-of-unity identities. -/

/-- `Оҫ_{p^n}^{(c : ZMod (p^n)).val}` вҖ” the root of unity with exponent the `ZMod`
element `c` (a total realisation of `Оҫ^c` for `c вҲҲ ZMod (p^n)`). -/
def zhp {n : в„•} (c : ZMod (p ^ n)) : в„Ӯ_[p] := zetaSys p n ^ c.val

/-- `zhp` on a natural cast is the plain power `Оҫ^k` (the `.val` differs by a
multiple of `p^n`, killed by `zetaSys_pow_eq_pow_of_modEq`). -/
theorem zhp_natCast {n : в„•} (k : в„•) : zhp p (k : ZMod (p ^ n)) = zetaSys p n ^ k :=
  zetaSys_pow_eq_pow_of_modEq p (by
    rw [вҶҗ ZMod.natCast_eq_natCast_iff, ZMod.natCast_val, ZMod.cast_id])

/-- `zhp` is additive in the exponent: `zhp (c + d) = zhp c В· zhp d`. -/
theorem zhp_add {n : в„•} (c d : ZMod (p ^ n)) : zhp p (c + d) = zhp p c * zhp p d := by
  rw [zhp, zhp, zhp, вҶҗ pow_add]
  refine zetaSys_pow_eq_pow_of_modEq p ?_
  rw [вҶҗ ZMod.natCast_eq_natCast_iff, Nat.cast_add, ZMod.natCast_val, ZMod.natCast_val,
    ZMod.natCast_val, ZMod.cast_id, ZMod.cast_id, ZMod.cast_id]

/-- `zhp 0 = 1`. -/
@[simp] theorem zhp_zero {n : в„•} : zhp p (0 : ZMod (p ^ n)) = 1 := by
  rw [show (0 : ZMod (p ^ n)) = ((0 : в„•) : ZMod (p ^ n)) by norm_cast, zhp_natCast, pow_zero]

/-- `zhp c В· zhp (вҲ’c) = 1`. -/
theorem zhp_mul_neg {n : в„•} (c : ZMod (p ^ n)) : zhp p c * zhp p (-c) = 1 := by
  rw [вҶҗ zhp_add, add_neg_cancel, zhp_zero]

/-- `zhp c вү  0` (it is a power of the nonzero `Оҫ`). -/
theorem zhp_ne_zero {n : в„•} (c : ZMod (p ^ n)) : zhp p c вү  0 := fun h => by
  have := zhp_mul_neg p c
  rw [h, zero_mul] at this
  exact one_ne_zero this.symm

/-- `вҖ–zhp cвҖ– = 1` (`Оҫ` has norm `1`). -/
theorem norm_zhp {n : в„•} (c : ZMod (p ^ n)) : вҖ–zhp p cвҖ– = 1 := by
  have hОҫ : вҖ–zetaSys p nвҖ– = 1 := by
    have h1 : вҖ–zetaSys p nвҖ– ^ (p ^ n) = 1 := by
      rw [вҶҗ norm_pow, (zetaSys_primitiveRoot p n).pow_eq_one, norm_one]
    have hne : p ^ n вү  0 := (pow_pos hp.out.pos n).ne'
    refine le_antisymm ?_ ?_
    В· by_contra h; rw [not_le] at h; exact absurd h1 (one_lt_powвӮҖ h hne).ne'
    В· by_contra h; rw [not_le] at h
      exact absurd h1 (pow_lt_oneвӮҖ (norm_nonneg _) h hne).ne
  rw [zhp, norm_pow, hОҫ, one_pow]

/-- The half-power exponent `(1вҲ’a)/2 вҲҲ ZMod (p^n)` of `Оі_{n,a}` (RJW TeX 3458). -/
def halfExp (a n : в„•) : ZMod (p ^ n) := (1 - (a : ZMod (p ^ n))) * (2 : ZMod (p ^ n))вҒ»В№

/-- **RJW TeX 3458**: the conjugation-fixed cyclotomic unit
`Оі_{n,a} = Оҫ_{p^n}^{(1вҲ’a)/2} c_n(a)` (half-power via `(2 : ZMod (p^n))вҒ»В№`, `p` odd). -/
def gammaUnit (a n : в„•) : в„Ӯ_[p] := zhp p (halfExp p a n) * cycloUnit p a n

/-! ## The real subfield `F_nвҒә` membership (the `Оҫ^m + Оҫ^{вҲ’m}` Chebyshev tower)

`F_nвҒә = в„ҡ(Оҫ + ОҫвҒ»В№)` contains every "cosine power" `Оҫ^m + Оҫ^{вҲ’m}` (a `в„Ө`-polynomial in
the generator `Оҫ + ОҫвҒ»В№` by the Chebyshev recurrence). This is the concrete route to
the conjugation-fixedness `Оі_{n,a} вҲҲ рқ’ҹ_n^+` (RJW TeX 3459): `Оі_{n,a}` is the
geometric sum `вҲ‘_{i<a} Оҫ^{(1вҲ’a)/2+i}`, symmetric under `i вҶҰ aвҲ’1вҲ’i`, hence a sum of
half the `cosPow` terms `Оҫ^j + Оҫ^{вҲ’j}`. -/

/-- `Оҫ_{p^n} + Оҫ_{p^n}вҒ»В№` lies in `F_nвҒә` (it is the chosen generator). -/
private theorem zetaSys_add_inv_mem_FglobalPlus (n : в„•) :
    zetaSys p n + (zetaSys p n)вҒ»В№ вҲҲ FglobalPlus p n :=
  IntermediateField.mem_adjoin_simple_self в„ҡ _

/-- `Оҫ_{p^n}^m + (Оҫ_{p^n}^m)вҒ»В№ вҲҲ F_nвҒә` for every `m` (Chebyshev recurrence
`c_{m+2} = c_1В·c_{m+1} вҲ’ c_m`). -/
private theorem cosPow_mem_FglobalPlus (n : в„•) (m : в„•) :
    zetaSys p n ^ m + (zetaSys p n ^ m)вҒ»В№ вҲҲ FglobalPlus p n := by
  have hОҫ0 : zetaSys p n вү  0 :=
    (zetaSys_primitiveRoot p n).ne_zero (pow_pos hp.out.pos n).ne'
  induction m using Nat.twoStepInduction with
  | zero => simpa using (FglobalPlus p n).add_mem (one_mem _) (one_mem _)
  | one => simpa using zetaSys_add_inv_mem_FglobalPlus p n
  | more m ih1 ih2 =>
    -- `c_{m+2} = c_1В·c_{m+1} вҲ’ c_m`
    have hrec : zetaSys p n ^ (m + 2) + (zetaSys p n ^ (m + 2))вҒ»В№
        = (zetaSys p n + (zetaSys p n)вҒ»В№)
            * (zetaSys p n ^ (m + 1) + (zetaSys p n ^ (m + 1))вҒ»В№)
          - (zetaSys p n ^ m + (zetaSys p n ^ m)вҒ»В№) := by
      field_simp
      ring
    rw [hrec]
    exact sub_mem (mul_mem (zetaSys_add_inv_mem_FglobalPlus p n) ih2) ih1

/-- `Оі_{n,a}` as a geometric sum of half-power roots:
`Оі_{n,a} = вҲ‘_{i<a} Оҫ^{(1вҲ’a)/2 + i}` (`= zhp(halfExp + i)`). -/
private theorem cycloUnit_eq_geomSum {a : в„•} {n : в„•} (hn : 1 вүӨ n) :
    cycloUnit p a n = вҲ‘ i вҲҲ Finset.range a, zetaSys p n ^ i := by
  have hne : zetaSys p n - 1 вү  0 :=
    sub_ne_zero_of_ne ((zetaSys_primitiveRoot p n).ne_one (one_lt_powвӮҖ hp.out.one_lt (by omega)))
  rw [cycloUnit, div_eq_iff hne, geom_sum_mul]

private theorem gammaUnit_eq_sum (a : в„•) {n : в„•} (hn : 1 вүӨ n) :
    gammaUnit p a n = вҲ‘ i вҲҲ Finset.range a, zhp p (halfExp p a n + (i : ZMod (p ^ n))) := by
  rw [gammaUnit, cycloUnit_eq_geomSum p hn, Finset.mul_sum]
  exact Finset.sum_congr rfl fun i _ => by rw [zhp_add, zhp_natCast]

/-- `2` is a unit of `ZMod (p^n)` for `p` odd (`p` coprime to `2`, so `p^n` is). -/
private theorem isUnit_two_zmod (hp2 : p вү  2) (n : в„•) : IsUnit (2 : ZMod (p ^ n)) := by
  rw [show (2 : ZMod (p ^ n)) = ((2 : в„•) : ZMod (p ^ n)) by norm_cast, ZMod.isUnit_iff_coprime]
  exact Nat.Coprime.pow_right _ ((Nat.coprime_primes hp.out Nat.prime_two).2 hp2).symm

/-- `2 В· 2вҒ»В№ = 1` in `ZMod (p^n)` (`p` odd). -/
private theorem two_mul_inv_two (hp2 : p вү  2) (n : в„•) :
    (2 : ZMod (p ^ n)) * (2 : ZMod (p ^ n))вҒ»В№ = 1 :=
  ZMod.mul_inv_of_unit _ (isUnit_two_zmod p hp2 n)

/-- The reindexing symmetry of the half-exponents: `halfExp a n + (aвҲ’1вҲ’i)
= вҲ’(halfExp a n + i)` (the sum `Оі_{n,a}` is invariant under `i вҶҰ aвҲ’1вҲ’i`). -/
private theorem halfExp_add_symm (hp2 : p вү  2) {a : в„•} (n : в„•) {i : в„•}
    (hi : i < a) :
    halfExp p a n + ((a - 1 - i : в„•) : ZMod (p ^ n))
      = -(halfExp p a n + (i : ZMod (p ^ n))) := by
  -- `(aвҲ’1вҲ’i : в„•) = (aвҲ’1 : в„•) вҲ’ i` as `ZMod`-casts (since `i вүӨ aвҲ’1`)
  have hcast : ((a - 1 - i : в„•) : ZMod (p ^ n))
      = ((a - 1 : в„•) : ZMod (p ^ n)) - (i : ZMod (p ^ n)) := by
    rw [Nat.cast_sub (by omega : i вүӨ a - 1)]
  -- `2В·halfExp = 1 вҲ’ a` (cancel `2В·2вҒ»В№ = 1`)
  have htwo : (2 : ZMod (p ^ n)) * halfExp p a n = 1 - (a : ZMod (p ^ n)) := by
    rw [halfExp, вҶҗ mul_assoc, mul_comm (2 : ZMod (p ^ n)) (1 - (a : ZMod (p ^ n))),
      mul_assoc, two_mul_inv_two p hp2 n, mul_one]
  have ha1 : ((a - 1 : в„•) : ZMod (p ^ n)) = (a : ZMod (p ^ n)) - 1 := by
    rw [Nat.cast_sub (by omega : 1 вүӨ a), Nat.cast_one]
  rw [hcast, ha1]
  -- now a pure `ZMod`-equation; clear via `2В·(LHS) = 2В·(RHS)` using `2` a unit
  refine (isUnit_two_zmod p hp2 n).mul_left_cancel ?_
  rw [mul_add, mul_neg, mul_add, htwo]
  ring

/-- `zhp (вҲ’c) = (zhp c)вҒ»В№` (the inverse half-power). -/
private theorem zhp_neg {n : в„•} (c : ZMod (p ^ n)) : zhp p (-c) = (zhp p c)вҒ»В№ :=
  eq_inv_of_mul_eq_one_left (by rw [mul_comm]; exact zhp_mul_neg p c)

/-- **The conjugation-fixedness `Оі_{n,a} вҲҲ F_nвҒә`** (RJW TeX 3459): `Оі_{n,a}` is the
symmetric geometric sum `вҲ‘_{i<a} Оҫ^{(1вҲ’a)/2+i}`; reflecting `i вҶҰ aвҲ’1вҲ’i` and averaging
expresses `2Оі_{n,a}` as a sum of `cosPow` terms `Оҫ^j + Оҫ^{вҲ’j} вҲҲ F_nвҒә`. -/
private theorem gammaUnit_mem_FglobalPlus {a : в„•} (hp2 : p вү  2) {n : в„•} (hn : 1 вүӨ n) :
    gammaUnit p a n вҲҲ FglobalPlus p n := by
  set S : в„Ӯ_[p] := вҲ‘ i вҲҲ Finset.range a, zhp p (halfExp p a n + (i : ZMod (p ^ n))) with hS
  have hОіS : gammaUnit p a n = S := gammaUnit_eq_sum p a hn
  -- the reflected sum equals `S`
  have hrefl : S = вҲ‘ i вҲҲ Finset.range a, zhp p (-(halfExp p a n + (i : ZMod (p ^ n)))) := by
    rw [hS, вҶҗ Finset.sum_range_reflect
      (fun i => zhp p (halfExp p a n + (i : ZMod (p ^ n)))) a]
    refine Finset.sum_congr rfl fun i hi => ?_
    rw [Finset.mem_range] at hi
    congr 1
    exact halfExp_add_symm p hp2 n hi
  -- `2S = вҲ‘ (zhp c + zhp (вҲ’c))`, each summand a `cosPow вҲҲ F_nвҒә`
  have h2S : (2 : в„Ӯ_[p]) * S
      = вҲ‘ i вҲҲ Finset.range a, (zhp p (halfExp p a n + (i : ZMod (p ^ n)))
          + (zhp p (halfExp p a n + (i : ZMod (p ^ n))))вҒ»В№) := by
    rw [two_mul]
    nth_rewrite 2 [hrefl]
    rw [вҶҗ Finset.sum_add_distrib]
    exact Finset.sum_congr rfl fun i _ => by rw [zhp_neg]
  have h2Smem : (2 : в„Ӯ_[p]) * S вҲҲ FglobalPlus p n := by
    rw [h2S]
    refine sum_mem fun i _ => ?_
    rw [zhp, show (zetaSys p n ^ (halfExp p a n + (i : ZMod (p ^ n))).val)вҒ»В№
        = ((zetaSys p n) ^ (halfExp p a n + (i : ZMod (p ^ n))).val)вҒ»В№ from rfl]
    exact cosPow_mem_FglobalPlus p n _
  -- `Оі = 2вҒ»В№В·(2S) вҲҲ F_nвҒә` (`2вҒ»В№ вҲҲ в„ҡ вҠҶ F_nвҒә`)
  rw [hОіS, show S = (2 : в„Ӯ_[p])вҒ»В№ * ((2 : в„Ӯ_[p]) * S) by
    rw [вҶҗ mul_assoc, inv_mul_cancelвӮҖ two_ne_zero, one_mul]]
  refine mul_mem ?_ h2Smem
  rw [show ((2 : в„Ӯ_[p])вҒ»В№) = ((2вҒ»В№ : в„ҡ) : в„Ӯ_[p]) by push_cast; ring]
  exact SubfieldClass.ratCast_mem (FglobalPlus p n) (2вҒ»В№ : в„ҡ)

/-- `Оі_{n,a} вҲҲ рқ’ҹ_n^+` (conjugation-fixed, RJW TeX 3458вҖ“3459). -/
theorem gammaUnit_mem_cycloUnitsPlus {a : в„•} (ha : В¬ (p : в„•) вҲЈ a) (hp2 : p вү  2)
    {n : в„•} (hn : 1 вүӨ n) :
    вҲғ g : в„Ӯ_[p]ЛЈ, (g : в„Ӯ_[p]) = gammaUnit p a n вҲ§ g вҲҲ cycloUnitsPlus p n := by
  -- `Оі вү  0` (product of nonzero `zhp` and the nonzero `cycloUnit`)
  have hОі0 : gammaUnit p a n вү  0 := by
    rw [gammaUnit]
    exact mul_ne_zero (zhp_ne_zero p _) (cycloUnit_ne_zero p ha hn)
  refine вҹЁUnits.mk0 (gammaUnit p a n) hОі0, Units.val_mk0 _, ?_, ?_вҹ©
  В· -- membership in `рқ’ҹ_n = closure(cycloGenSet) вҠ“ globalUnits`
    rw [cycloUnits, Subgroup.mem_inf]
    -- `c_n(a) вҲҲ рқ’ҹ_n` (the existing milestone)
    have hcD := cyclo_elems_mem_cycloUnits p ha hp2 hn
    have hcval : ((cyclo p ha hp2).elems n : в„Ӯ_[p]) = cycloUnit p a n := by
      change ((if hn : 1 вүӨ n then Units.mk0 (cycloUnit p a n)
        (cycloUnit_ne_zero p ha hn) else 1 : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]) = _
      rw [dif_pos hn, Units.val_mk0]
    rw [cycloUnits, Subgroup.mem_inf] at hcD
    obtain вҹЁhcClosure, hcGlobalвҹ© := hcD
    -- the `Оҫ`-power half-factor as a unit in the closure: `zhp (halfExp) = Оҫ^{val}`
    set О¶u : в„Ӯ_[p]ЛЈ := Units.mk0 (zetaSys p n)
      ((zetaSys_primitiveRoot p n).ne_zero (pow_pos hp.out.pos n).ne') with hО¶u
    have hО¶uGen : О¶u вҲҲ cycloGenSet p n := Or.inl (Units.val_mk0 _)
    -- `zhp (halfExp) = О¶u ^ (halfExp.val)` as a unit
    set hu : в„Ӯ_[p]ЛЈ := О¶u ^ (halfExp p a n).val with hhu
    have hhuval : (hu : в„Ӯ_[p]) = zhp p (halfExp p a n) := by
      rw [hhu, Units.val_pow_eq_pow_val, hО¶u, Units.val_mk0, zhp]
    refine вҹЁ?_, ?_вҹ©
    В· -- closure membership: `Оі = hu * (cyclo).elems n`
      have hword : Units.mk0 (gammaUnit p a n) hОі0 = hu * (cyclo p ha hp2).elems n := by
        refine Units.ext ?_
        rw [Units.val_mk0, Units.val_mul, hhuval, hcval, gammaUnit]
      rw [hword]
      exact mul_mem (pow_mem (Subgroup.subset_closure hО¶uGen) _) hcClosure
    В· -- global-unit membership: `Оі вҲҲ F_n`, integral with integral inverse
      have hОіF : gammaUnit p a n вҲҲ Fglobal p n := by
        rw [gammaUnit]
        refine mul_mem ?_ ?_
        В· rw [zhp]; exact pow_mem (IntermediateField.mem_adjoin_simple_self в„ҡ _) _
        В· rw [cycloUnit_eq_geomSum p hn]
          exact sum_mem fun i _ =>
            pow_mem (IntermediateField.mem_adjoin_simple_self в„ҡ _) i
      refine вҹЁ?_, ?_, ?_вҹ©
      В· rw [Units.val_mk0]; exact hОіF
      В· rw [Units.val_mk0, gammaUnit]
        refine (?_ : IsIntegral в„Ө (zhp p (halfExp p a n))).mul ?_
        В· rw [zhp]
          exact IsIntegral.pow (show IsIntegral в„Ө (zetaSys p n) from вҹЁPolynomial.X ^ p ^ n - Polynomial.C 1, Polynomial.monic_X_pow_sub_C 1 (pow_ne_zero _ hp.out.ne_zero), by simp [(zetaSys_primitiveRoot p n).pow_eq_one]вҹ©) _
        В· exact isIntegral_cycloUnit p a n
      В· rw [show (((Units.mk0 (gammaUnit p a n) hОі0)вҒ»В№ : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p])
            = (gammaUnit p a n)вҒ»В№ from rfl, gammaUnit, mul_inv]
        refine (?_ : IsIntegral в„Ө (zhp p (halfExp p a n))вҒ»В№).mul ?_
        В· rw [вҶҗ zhp_neg]; rw [zhp]
          exact IsIntegral.pow (show IsIntegral в„Ө (zetaSys p n) from вҹЁPolynomial.X ^ p ^ n - Polynomial.C 1, Polynomial.monic_X_pow_sub_C 1 (pow_ne_zero _ hp.out.ne_zero), by simp [(zetaSys_primitiveRoot p n).pow_eq_one]вҹ©) _
        В· exact isIntegral_inv_cycloUnit p ha hn
  В· -- `Оі вҲҲ F_nвҒә`
    rw [Units.val_mk0]; exact gammaUnit_mem_FglobalPlus p hp2 hn

/-- `вҲ’1` (as a unit) lies in `рқ’ҹ_n^+`: it is `(вҲ’Оҫ)В·ОҫвҒ»В№ вҲҲ closure(cycloGenSet)`, a global
unit (root of unity), and rational hence in `F_nвҒә`. -/
private theorem neg_one_mem_cycloUnitsPlus {n : в„•} :
    (-1 : в„Ӯ_[p]ЛЈ) вҲҲ cycloUnitsPlus p n := by
  refine вҹЁ?_, ?_вҹ©
  В· -- `вҲ’1 вҲҲ рқ’ҹ_n = closure(cycloGenSet) вҠ“ globalUnits`
    rw [cycloUnits, Subgroup.mem_inf]
    have hОҫ0 : zetaSys p n вү  0 :=
      (zetaSys_primitiveRoot p n).ne_zero (pow_pos hp.out.pos n).ne'
    set О¶u : в„Ӯ_[p]ЛЈ := Units.mk0 (zetaSys p n) hОҫ0 with hО¶u
    set negО¶u : в„Ӯ_[p]ЛЈ := Units.mk0 (-zetaSys p n) (neg_ne_zero.mpr hОҫ0) with hnegО¶u
    refine вҹЁ?_, ?_вҹ©
    В· -- `вҲ’1 = (вҲ’Оҫ)В·ОҫвҒ»В№` lies in `closure(cycloGenSet)`
      have hword : (-1 : в„Ӯ_[p]ЛЈ) = negО¶u * О¶uвҒ»В№ := by
        refine Units.ext ?_
        rw [Units.val_mul, hnegО¶u, Units.val_mk0,
          show ((О¶uвҒ»В№ : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]) = (zetaSys p n)вҒ»В№ from by rw [hО¶u]; rfl,
          Units.val_neg, Units.val_one]
        field_simp
      rw [hword]
      exact mul_mem (Subgroup.subset_closure (Or.inr (Or.inl (by rw [hnegО¶u, Units.val_mk0]))))
        (Subgroup.inv_mem _ (Subgroup.subset_closure (Or.inl (by rw [hО¶u, Units.val_mk0]))))
    В· -- `вҲ’1 вҲҲ рқ’ұ_n` (rational, integral both ways)
      refine вҹЁ?_, ?_, ?_вҹ©
      В· rw [Units.val_neg, Units.val_one]
        exact neg_mem (one_mem _)
      В· rw [Units.val_neg, Units.val_one]; exact (isIntegral_one).neg
      В· rw [show (((-1 : в„Ӯ_[p]ЛЈ)вҒ»В№ : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]) = -1 from by simp]
        exact (isIntegral_one).neg
  В· -- `вҲ’1 вҲҲ F_nвҒә` (rational)
    rw [Units.val_neg, Units.val_one]
    exact neg_mem (one_mem _)

/-! ## The valuation homomorphism and the conjugation reality (RJW TeX 3470вҖ“3482)

Two pieces of structure feed the normal-form argument for `lem:cyc units gen (i)`:

* the additive valuation `V u = вҲ’logвҖ–uвҖ–` as a `MonoidHom в„Ӯ_[p]ЛЈ вҶ’ Multiplicative в„қ`
  (norm is multiplicative); it vanishes on global units (norm `1`) and on every
  `Оі_{n,a}`/`Вұ1` (norm `1`), and is *strictly positive* on the uniformiser `Оҫ вҲ’ 1`
  (`вҖ–ОҫвҲ’1вҖ– < 1`). This forces the `(ОҫвҲ’1)`-exponent of a global unit to be `0`.
* complex conjugation `Пғ_{вҲ’1}` (`galAut p (вҲ’1) n`, the cyclotomic-character value `вҲ’1`)
  fixes `F_nвҒә = в„ҡ(Оҫ+ОҫвҒ»В№)` pointwise and sends `Оҫ вҶҰ ОҫвҒ»В№`; reality of `Оҫ^m` then forces
  `Оҫ^{2m} = 1`, i.e. `Оҫ^m = 1` (`p` odd), killing the `Оҫ`-power exponent. -/

/-- `вҖ–Оҫ_{p^n}вҖ– = 1` (a primitive `p^n`-th root of unity). -/
private theorem norm_zetaSys_eq_one (n : в„•) : вҖ–zetaSys p nвҖ– = 1 := by
  rw [вҶҗ pow_one (zetaSys p n), вҶҗ zhp_natCast p 1, norm_zhp]

/-- `Оҫ_{p^n} вү  0`. -/
private theorem zetaSys_ne_zero (n : в„•) : zetaSys p n вү  0 :=
  norm_ne_zero_iff.mp (by rw [norm_zetaSys_eq_one]; exact one_ne_zero)

/-- The additive valuation `V u = вҲ’logвҖ–uвҖ–` as a `MonoidHom` into `Multiplicative в„қ`
(the `в„Ӯ_[p]`-norm is multiplicative). -/
private def valHom : в„Ӯ_[p]ЛЈ вҶ’* Multiplicative в„қ where
  toFun u := Multiplicative.ofAdd (-Real.log вҖ–(u : в„Ӯ_[p])вҖ–)
  map_one' := by simp
  map_mul' u v := by
    show Multiplicative.ofAdd (-Real.log вҖ–((u * v : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p])вҖ–)
      = Multiplicative.ofAdd _ * Multiplicative.ofAdd _
    rw [вҶҗ ofAdd_add]
    congr 1
    rw [Units.val_mul, norm_mul, Real.log_mul (norm_ne_zero_iff.mpr u.ne_zero)
      (norm_ne_zero_iff.mpr v.ne_zero)]
    ring

/-- `V` vanishes on norm-`1` units. -/
private theorem valHom_eq_one_of_norm_one {u : в„Ӯ_[p]ЛЈ} (h : вҖ–(u : в„Ӯ_[p])вҖ– = 1) :
    valHom p u = 1 := by
  show Multiplicative.ofAdd (-Real.log вҖ–(u : в„Ӯ_[p])вҖ–) = 1
  rw [h, Real.log_one, neg_zero]; rfl

/-- Conjugation `Пғ_{вҲ’1}` sends `Оҫ_{p^n} вҶҰ Оҫ_{p^n}вҒ»В№` (the cyclotomic-character value `вҲ’1`,
read through `unitsToZModPow (вҲ’1) = вҲ’1` and `Оҫ^{(вҲ’1).val} = ОҫвҒ»В№`). -/
private theorem galAutNegOne_zetaSys {n : в„•} (hn : 1 вүӨ n) :
    (galAut p (-1) n вҹЁzetaSys p n, zetaSys_mem_K p nвҹ© : в„Ӯ_[p]) = (zetaSys p n)вҒ»В№ := by
  rw [galAut_zetaSys p (-1) hn]
  have hneg : (PadicMeasure.unitsToZModPow p n (-1) : (ZMod (p ^ n))ЛЈ) = -1 := by
    apply Units.ext; rw [PadicMeasure.unitsToZModPow_coe]; push_cast; simp
  rw [hneg]
  refine eq_inv_of_mul_eq_one_left ?_
  rw [вҶҗ pow_succ]
  refine (zetaSys_pow_eq_pow_of_modEq p
    (i := (((-1 : (ZMod (p ^ n))ЛЈ) : ZMod (p ^ n))).val + 1) (j := 0) ?_).trans ?_
  В· rw [вҶҗ ZMod.natCast_eq_natCast_iff]; push_cast [ZMod.natCast_val, ZMod.cast_id]; ring
  В· rw [pow_zero]

/-- Conjugation `Пғ_{вҲ’1}` fixes the generator `Оҫ + ОҫвҒ»В№` of `F_nвҒә`. -/
private theorem galAutNegOne_gen {n : в„•} (hn : 1 вүӨ n)
    (hzK : zetaSys p n + (zetaSys p n)вҒ»В№ вҲҲ K p n) :
    (galAut p (-1) n вҹЁzetaSys p n + (zetaSys p n)вҒ»В№, hzKвҹ© : в„Ӯ_[p])
      = zetaSys p n + (zetaSys p n)вҒ»В№ := by
  rw [show (вҹЁzetaSys p n + (zetaSys p n)вҒ»В№, hzKвҹ© : K p n)
      = вҹЁzetaSys p n, zetaSys_mem_K p nвҹ© + (вҹЁzetaSys p n, zetaSys_mem_K p nвҹ©)вҒ»В№ from
    Subtype.ext (by push_cast [Subtype.coe_mk]; rfl), map_add, map_invвӮҖ,
    show ((galAut p (-1) n вҹЁzetaSys p n, zetaSys_mem_K p nвҹ©
        + (galAut p (-1) n вҹЁzetaSys p n, zetaSys_mem_K p nвҹ©)вҒ»В№ : K p n) : в„Ӯ_[p])
        = (galAut p (-1) n вҹЁzetaSys p n, zetaSys_mem_K p nвҹ© : в„Ӯ_[p])
          + ((galAut p (-1) n вҹЁzetaSys p n, zetaSys_mem_K p nвҹ© : в„Ӯ_[p]))вҒ»В№ from by
      push_cast; ring,
    galAutNegOne_zetaSys p hn, inv_inv, add_comm]

/-- **Reality of `F_nвҒә`**: conjugation `Пғ_{вҲ’1}` fixes every element of `F_nвҒә` pointwise.
`F_nвҒә = в„ҡ(Оҫ+ОҫвҒ»В№)`, and `Пғ_{вҲ’1}` (a `в„ҡ_p`-algebra automorphism of `K_n вҠҮ F_nвҒә`) fixes the
generator `Оҫ+ОҫвҒ»В№` and all of `в„ҡ`; closure under the field operations is the induction. -/
private theorem galAutNegOne_fixes_FglobalPlus {n : в„•} (hn : 1 вүӨ n) {x : в„Ӯ_[p]}
    (hx : x вҲҲ FglobalPlus p n) (hxK : x вҲҲ K p n) :
    (galAut p (-1) n вҹЁx, hxKвҹ© : в„Ӯ_[p]) = x := by
  have toK : вҲҖ {y : в„Ӯ_[p]}, y вҲҲ FglobalPlus p n вҶ’ y вҲҲ K p n :=
    fun hy => Fglobal_le_K p (FglobalPlus_le_Fglobal p n hy)
  have key : вҲҖ y вҲҲ FglobalPlus p n, вҲҖ (hyK : y вҲҲ K p n),
      (galAut p (-1) n вҹЁy, hyKвҹ© : в„Ӯ_[p]) = y := by
    intro y hy
    rw [FglobalPlus] at hy
    induction hy using IntermediateField.adjoin_induction with
    | mem z hz =>
        obtain rfl := hz
        intro hzK
        exact galAutNegOne_gen p hn hzK
    | algebraMap q =>
        intro hqK
        have hval : ((q : K p n) : в„Ӯ_[p]) = (algebraMap в„ҡ в„Ӯ_[p]) q := by
          rw [eq_ratCast (algebraMap в„ҡ в„Ӯ_[p]) q]; push_cast; ring
        rw [show (вҹЁ(algebraMap в„ҡ в„Ӯ_[p]) q, hqKвҹ© : K p n) = (q : K p n) from
          Subtype.ext (by rw [hval]), map_ratCast, hval]
    | add y z hy hz ihy ihz =>
        intro hyzK
        rw [show (вҹЁy + z, hyzKвҹ© : K p n) = вҹЁy, toK hyвҹ© + вҹЁz, toK hzвҹ© from rfl, map_add]
        push_cast
        rw [ihy (toK hy), ihz (toK hz)]
    | inv y hy ihy =>
        intro hyinvK
        rw [show (вҹЁyвҒ»В№, hyinvKвҹ© : K p n) = (вҹЁy, toK hyвҹ©)вҒ»В№ from rfl, map_invвӮҖ]
        push_cast
        rw [ihy (toK hy)]
    | mul y z hy hz ihy ihz =>
        intro hyzK
        rw [show (вҹЁy * z, hyzKвҹ© : K p n) = вҹЁy, toK hyвҹ© * вҹЁz, toK hzвҹ© from rfl, map_mul]
        push_cast
        rw [ihy (toK hy), ihz (toK hz)]
  exact key x hx hxK

/-- For `p` odd, a `Оҫ`-power that is real (`Оҫ^{2m} = 1`) is trivial. -/
private theorem zpow_eq_one_of_two_mul {n : в„•} (hp2 : p вү  2) (О¶u : в„Ӯ_[p]ЛЈ)
    (hord : orderOf О¶u = p ^ n) (m : в„Ө) (h2m : О¶u ^ (2 * m) = 1) : О¶u ^ m = 1 := by
  rw [вҶҗ orderOf_dvd_iff_zpow_eq_one, hord] at h2m вҠў
  rw [show ((p ^ n : в„•) : в„Ө) = (p : в„Ө) ^ n by push_cast; ring] at h2m вҠў
  have hcop : IsCoprime ((p : в„Ө) ^ n) (2 : в„Ө) := by
    have := (Nat.Coprime.pow_left n ((Nat.coprime_primes hp.out Nat.prime_two).2 hp2)).isCoprime
    push_cast at this
    exact this
  exact hcop.dvd_of_dvd_mul_left h2m

/-- `Оҫ_{p^n}` packaged as a unit of `в„Ӯ_[p]ЛЈ`. -/
private def zetaSysUnit (n : в„•) : в„Ӯ_[p]ЛЈ := Units.mk0 (zetaSys p n) (zetaSys_ne_zero p n)

private theorem zetaSysUnit_val (n : в„•) : (zetaSysUnit p n : в„Ӯ_[p]) = zetaSys p n :=
  Units.val_mk0 _

/-- `orderOf (Оҫ_{p^n} : в„Ӯ_[p]ЛЈ) = p^n`. -/
private theorem orderOf_zetaSysUnit (n : в„•) : orderOf (zetaSysUnit p n) = p ^ n := by
  have hprim : IsPrimitiveRoot (zetaSysUnit p n) (p ^ n) := by
    rw [вҶҗ IsPrimitiveRoot.coe_units_iff, zetaSysUnit_val]
    exact zetaSys_primitiveRoot p n
  exact hprim.eq_orderOf.symm

/-- `(Оҫ^m : в„Ӯ_[p]ЛЈ)` coerces to `Оҫ^m` in `в„Ӯ_[p]`. -/
private theorem zetaSysUnit_zpow_val (n : в„•) (m : в„Ө) :
    ((zetaSysUnit p n ^ m : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]) = (zetaSys p n) ^ m := by
  rw [Units.val_zpow_eq_zpow_val, zetaSysUnit_val]

/-- **Reality kills the `Оҫ`-power** (RJW TeX 3478вҖ“3482): if a power `Оҫ^m` of the
root of unity lies in `F_nвҒә` (is real), then `Оҫ^m = 1`. Conjugation `Пғ_{вҲ’1}` fixes
`F_nвҒә` (`galAutNegOne_fixes_FglobalPlus`) and sends `Оҫ вҶҰ ОҫвҒ»В№`, so `Оҫ^{вҲ’m} = Оҫ^m`,
i.e. `Оҫ^{2m} = 1`, i.e. `Оҫ^m = 1` (`p` odd). -/
private theorem zetaSysUnit_zpow_eq_one_of_mem_FglobalPlus {n : в„•} (hp2 : p вү  2)
    (hn : 1 вүӨ n) (m : в„Ө) (hmem : ((zetaSysUnit p n ^ m : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]) вҲҲ FglobalPlus p n) :
    zetaSysUnit p n ^ m = 1 := by
  -- `Оҫ^m вҲҲ K_n`
  have hmemK : ((zetaSysUnit p n ^ m : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]) вҲҲ K p n :=
    Fglobal_le_K p (FglobalPlus_le_Fglobal p n hmem)
  -- conjugation fixes it (reality) and equals `Оҫ^{вҲ’m}` (character `вҲ’1`)
  have hfix := galAutNegOne_fixes_FglobalPlus p hn hmem hmemK
  -- `Пғ_{вҲ’1}(Оҫ^m) = Оҫ^{вҲ’m}` at the `в„Ӯ_[p]` level
  -- the subtype element is `вҹЁОҫ,_вҹ©^m` (equal `.val`, proof-irrelevant membership)
  have hsub : (вҹЁ((zetaSysUnit p n ^ m : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]), hmemKвҹ© : K p n)
      = (вҹЁzetaSys p n, zetaSys_mem_K p nвҹ© : K p n) ^ m :=
    Subtype.ext ((zetaSysUnit_zpow_val p n m).trans
      (map_zpowвӮҖ (K p n).val (вҹЁzetaSys p n, zetaSys_mem_K p nвҹ© : K p n) m).symm)
  have hconj : (galAut p (-1) n вҹЁ((zetaSysUnit p n ^ m : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]), hmemKвҹ© : в„Ӯ_[p])
      = (zetaSys p n) ^ (-m) := by
    rw [hsub, map_zpowвӮҖ,
      show ((galAut p (-1) n вҹЁzetaSys p n, zetaSys_mem_K p nвҹ© ^ m : K p n) : в„Ӯ_[p])
          = ((galAut p (-1) n вҹЁzetaSys p n, zetaSys_mem_K p nвҹ© : в„Ӯ_[p])) ^ m from
        map_zpowвӮҖ (K p n).val _ m,
      galAutNegOne_zetaSys p hn, inv_zpow, zpow_neg]
  rw [hconj] at hfix
  -- `hfix : Оҫ^{вҲ’m} = вҶ‘(Оҫu^m)`, i.e. `Оҫ^{вҲ’m} = Оҫ^m`; lift to units
  have hfix' : (zetaSys p n) ^ (-m) = (zetaSys p n) ^ m := by
    rw [hfix, zetaSysUnit_zpow_val]
  have hunit : zetaSysUnit p n ^ (-m) = zetaSysUnit p n ^ m :=
    Units.ext (by rw [zetaSysUnit_zpow_val, zetaSysUnit_zpow_val]; exact hfix')
  have h2m : zetaSysUnit p n ^ (2 * m) = 1 := by
    rw [show (2 * m) = m + m by ring, zpow_add]
    nth_rewrite 1 [вҶҗ hunit]
    rw [вҶҗ zpow_add, neg_add_cancel, zpow_zero]
  exact zpow_eq_one_of_two_mul p hp2 (zetaSysUnit p n) (orderOf_zetaSysUnit p n) m h2m

/-- `вҖ–Оҫ_{p^n}^k вҲ’ 1вҖ– < 1` for every `k` (a conjugate uniformiser, dominated by
`вҖ–ПҖ_nвҖ– < 1`). -/
private theorem norm_zetaSys_pow_sub_one_lt {n : в„•} (hn : 1 вүӨ n) (k : в„•) :
    вҖ–zetaSys p n ^ k - 1вҖ– < 1 := by
  have hОҫ1 : вҖ–zetaSys p nвҖ– = 1 := norm_zetaSys_eq_one p n
  have hbound : вҖ–zetaSys p n ^ k - 1вҖ– вүӨ вҖ–zetaSys p n - 1вҖ– := by
    rw [show zetaSys p n ^ k - 1
        = (вҲ‘ i вҲҲ Finset.range k, zetaSys p n ^ i) * (zetaSys p n - 1) from
      (geom_sum_mul _ k).symm, norm_mul]
    have hgeom : вҖ–вҲ‘ i вҲҲ Finset.range k, zetaSys p n ^ iвҖ– вүӨ 1 :=
      IsUltrametricDist.norm_sum_le_of_forall_le_of_nonneg zero_le_one
        (fun i _ => by rw [norm_pow, hОҫ1, one_pow])
    nlinarith [norm_nonneg (zetaSys p n - 1), hgeom]
  refine lt_of_le_of_lt hbound ?_
  have := norm_pi_lt_one p hn
  rwa [pi] at this

/-- `Пү = Оҫ_{p^n}^{p^{nвҲ’1}}` is a primitive `p`-th root of unity. -/
private theorem zetaSys_pow_isPrimitiveRoot_p {n : в„•} (hn : 1 вүӨ n) :
    IsPrimitiveRoot (zetaSys p n ^ (p ^ (n - 1))) p := by
  refine (zetaSys_primitiveRoot p n).pow (pow_pos hp.out.pos n) ?_
  rw [вҶҗ pow_succ]
  congr 1
  omega

/-- **The `p`-fold reduction identity (RJW TeX 3471)**: `Оҫ^{kp} вҲ’ 1 = вҲҸ_{i<p}
(Оҫ^{k + iВ·p^{nвҲ’1}} вҲ’ 1)`. (Factor `X^p вҲ’ Оҫ^{kp}` over the `p`-th roots `Пү^i` via
`X_pow_sub_C_eq_prod`, evaluate at `X = 1`, multiply by `(вҲ’1)^p = вҲ’1`.) -/
private theorem zetaSys_pow_mul_sub_one_prod (hp2 : p вү  2) {n : в„•} (hn : 1 вүӨ n) (k : в„•) :
    zetaSys p n ^ (k * p) - 1
      = вҲҸ i вҲҲ Finset.range p, (zetaSys p n ^ (k + i * p ^ (n - 1)) - 1) := by
  have hПү := zetaSys_pow_isPrimitiveRoot_p p hn
  have he : (zetaSys p n ^ k) ^ p = zetaSys p n ^ (k * p) := by rw [вҶҗ pow_mul]
  have hpoly := X_pow_sub_C_eq_prod hПү hp.out.pos he
  apply_fun (Polynomial.eval (1 : в„Ӯ_[p])) at hpoly
  simp only [Polynomial.eval_sub, Polynomial.eval_pow, Polynomial.eval_X, Polynomial.eval_C,
    Polynomial.eval_prod, one_pow] at hpoly
  -- `hpoly : 1 вҲ’ Оҫ^{kp} = вҲҸ_{i<p}(1 вҲ’ Пү^i В· Оҫ^k)`
  have hsign : ((-1 : в„Ӯ_[p]) ^ p) = -1 := Odd.neg_one_pow (hp.out.odd_of_ne_two hp2)
  have hfac : вҲҖ i вҲҲ Finset.range p,
      zetaSys p n ^ (k + i * p ^ (n - 1)) - 1
        = (-1) * (1 - (zetaSys p n ^ p ^ (n - 1)) ^ i * zetaSys p n ^ k) := by
    intro i _
    rw [pow_add, вҶҗ pow_mul, mul_comm i (p ^ (n - 1))]; ring
  rw [Finset.prod_congr rfl hfac, Finset.prod_mul_distrib, Finset.prod_const,
    Finset.card_range, hsign, вҶҗ hpoly]
  ring

/-! ## The target generating set and its two invariants (`valHom`, `FglobalPlus`)

Write `H = closure({Оі_{n,b} : (b,p)=1} вҲӘ {вҲ’1})` for the target subgroup. Both the
valuation `valHom` and reality (`вҶ‘В· вҲҲ F_nвҒә`) vanish on every generator (norm `1`,
real), hence on all of `H`. These two facts are what the normal-form argument exploits:
the `(ОҫвҲ’1)`-exponent is killed by `valHom`, the `Оҫ`-exponent by reality. -/

/-- The target generating set `{Оі_{n,b} : (b,p)=1} вҲӘ {вҲ’1}`. -/
private def gammaGenSet (n : в„•) : Set в„Ӯ_[p]ЛЈ :=
  {g : в„Ӯ_[p]ЛЈ | вҲғ b : в„•, В¬ (p : в„•) вҲЈ b вҲ§ (g : в„Ӯ_[p]) = gammaUnit p b n} вҲӘ
    {g : в„Ӯ_[p]ЛЈ | (g : в„Ӯ_[p]) = -1}

/-- Every element of the closure of `gammaGenSet` is real (lies in `F_nвҒә`). -/
private theorem coe_mem_FglobalPlus_of_mem_closure_gammaGenSet (hp2 : p вү  2) {n : в„•}
    (hn : 1 вүӨ n) {u : в„Ӯ_[p]ЛЈ} (hu : u вҲҲ Subgroup.closure (gammaGenSet p n)) :
    (u : в„Ӯ_[p]) вҲҲ FglobalPlus p n := by
  induction hu using Subgroup.closure_induction with
  | mem x hx =>
      rcases hx with вҹЁb, _, hvalвҹ© | hval
      В· rw [hval]; exact gammaUnit_mem_FglobalPlus p hp2 hn
      В· rw [hval]; exact neg_mem (one_mem _)
  | one => rw [Units.val_one]; exact one_mem _
  | mul x y _ _ ihx ihy => rw [Units.val_mul]; exact mul_mem ihx ihy
  | inv x _ ihx => rw [Units.val_inv_eq_inv_val]; exact (FglobalPlus p n).inv_mem ihx

/-- `valHom` vanishes on every generator of `gammaGenSet`, hence on the whole closure. -/
private theorem valHom_eq_one_of_mem_closure_gammaGenSet {n : в„•}
    (hn : 1 вүӨ n) {u : в„Ӯ_[p]ЛЈ} (hu : u вҲҲ Subgroup.closure (gammaGenSet p n)) :
    valHom p u = 1 := by
  induction hu using Subgroup.closure_induction with
  | mem x hx =>
      rcases hx with вҹЁb, hb, hvalвҹ© | hval
      В· refine valHom_eq_one_of_norm_one p ?_
        rw [hval, gammaUnit, norm_mul, norm_zhp, one_mul, norm_cycloUnit p hb hn]
      В· refine valHom_eq_one_of_norm_one p ?_
        rw [hval, norm_neg, norm_one]
  | one => exact map_one _
  | mul x y _ _ ihx ihy => rw [map_mul, ihx, ihy, one_mul]
  | inv x _ ihx => rw [map_inv, ihx, inv_one]

/-! ## The uniformiser `Оҙ = Оҫ вҲ’ 1` as a unit, and `valHom Оҙ вү  1`

`Оҙ = Оҫ_{p^n} вҲ’ 1` is a nonzero element of the field `в„Ӯ_[p]`, hence a unit. Its norm
is `< 1` (`norm_zetaSys_pow_sub_one_lt`), so `valHom Оҙ = ofAdd(вҲ’logвҖ–ОҙвҖ–)` with
`вҲ’logвҖ–ОҙвҖ– > 0`, i.e. `valHom Оҙ вү  1`; this kills the `Оҙ`-exponent in the normal form. -/

/-- `Оҙ = Оҫ_{p^n} вҲ’ 1` packaged as a unit of `в„Ӯ_[p]ЛЈ` (`n вүҘ 1`, so `Оҫ вү  1`). -/
private def deltaUnit {n : в„•} (hn : 1 вүӨ n) : в„Ӯ_[p]ЛЈ :=
  Units.mk0 (zetaSys p n - 1)
    (sub_ne_zero_of_ne
      ((zetaSys_primitiveRoot p n).ne_one (one_lt_powвӮҖ hp.out.one_lt (by omega))))

private theorem deltaUnit_val {n : в„•} (hn : 1 вүӨ n) :
    (deltaUnit p hn : в„Ӯ_[p]) = zetaSys p n - 1 :=
  Units.val_mk0 _

/-- `0 < вҲ’logвҖ–ОҙвҖ–`, i.e. `valHom Оҙ вү  1` (the uniformiser has norm `< 1`). -/
private theorem valHom_deltaUnit_ne_one {n : в„•} (hn : 1 вүӨ n) :
    valHom p (deltaUnit p hn) вү  1 := by
  have hlt : вҖ–(deltaUnit p hn : в„Ӯ_[p])вҖ– < 1 := by
    rw [deltaUnit_val, show zetaSys p n - 1 = zetaSys p n ^ 1 - 1 by rw [pow_one]]
    exact norm_zetaSys_pow_sub_one_lt p hn 1
  have hpos : 0 < вҖ–(deltaUnit p hn : в„Ӯ_[p])вҖ– :=
    norm_pos_iff.mpr (deltaUnit p hn).ne_zero
  have hlog : Real.log вҖ–(deltaUnit p hn : в„Ӯ_[p])вҖ– < 0 := Real.log_neg hpos hlt
  intro h
  have hz : (-Real.log вҖ–(deltaUnit p hn : в„Ӯ_[p])вҖ–) = 0 := ofAdd_eq_one.mp h
  linarith

/-! ## The normal form: `closure(cycloGenSet) вүӨ closure({Оҫ, Оҙ} вҲӘ gammaGenSet)`

Every generator of `рқ’ҹ_n` (`ВұОҫ` and `Оҫ^aвҲ’1`) lies in the closure `M` of
`{Оҫ} вҲӘ {Оҙ} вҲӘ gammaGenSet`. The only nontrivial case is `Оҫ^aвҲ’1`: for `(a,p)=1` it is
`ОҙВ·Оҫ^{c}В·Оі_{n,a}` (the `c_n(a)`-factorisation), and the `pвҲЈa` case reduces to coprime
exponents by the `p`-fold identity (`zetaSys_pow_mul_sub_one_prod`), inducting on
`v_p(a)`. -/

/-- The augmented generating set `{Оҫ} вҲӘ {Оҙ} вҲӘ gammaGenSet`. -/
private def augGenSet {n : в„•} (hn : 1 вүӨ n) : Set в„Ӯ_[p]ЛЈ :=
  ({zetaSysUnit p n} вҲӘ {deltaUnit p hn}) вҲӘ gammaGenSet p n

private theorem zetaSysUnit_mem_aug {n : в„•} (hn : 1 вүӨ n) :
    zetaSysUnit p n вҲҲ Subgroup.closure (augGenSet p hn) :=
  Subgroup.subset_closure (Or.inl (Or.inl rfl))

private theorem deltaUnit_mem_aug {n : в„•} (hn : 1 вүӨ n) :
    deltaUnit p hn вҲҲ Subgroup.closure (augGenSet p hn) :=
  Subgroup.subset_closure (Or.inl (Or.inr rfl))

private theorem gammaGenSet_le_aug {n : в„•} (hn : 1 вүӨ n) {g : в„Ӯ_[p]ЛЈ}
    (hg : g вҲҲ gammaGenSet p n) : g вҲҲ Subgroup.closure (augGenSet p hn) :=
  Subgroup.subset_closure (Or.inr hg)

/-- `Оҫ^a вҲ’ 1 вү  0` for `1 вүӨ a < p^n` (`Оҫ^a вү  1`, since `Оҫ` has order `p^n`). -/
private theorem zetaSys_pow_sub_one_ne_zero {n a : в„•} (ha1 : 1 вүӨ a) (ha2 : a < p ^ n) :
    zetaSys p n ^ a - 1 вү  0 := by
  refine sub_ne_zero_of_ne fun h => ?_
  have hdvd : p ^ n вҲЈ a := (zetaSys_primitiveRoot p n).pow_eq_one_iff_dvd a |>.mp h
  exact absurd (Nat.le_of_dvd (by omega) hdvd) (by omega)

/-- The base case `(a,p)=1`: `Оҫ^a вҲ’ 1 = вҶ‘(Оҙ В· Оҫ^{(вҲ’halfExp).val} В· Оі_{n,a})`, so the
generator unit lies in `M`. -/
private theorem zetaSys_pow_sub_one_mem_aug_coprime (_hp2 : p вү  2) {n : в„•} (hn : 1 вүӨ n)
    {a : в„•} (ha : В¬ (p : в„•) вҲЈ a) (_ha1 : 1 вүӨ a) (_ha2 : a < p ^ n) {g : в„Ӯ_[p]ЛЈ}
    (hgv : (g : в„Ӯ_[p]) = zetaSys p n ^ a - 1) :
    g вҲҲ Subgroup.closure (augGenSet p hn) := by
  have hОі0 : gammaUnit p a n вү  0 :=
    mul_ne_zero (zhp_ne_zero p _) (cycloUnit_ne_zero p ha hn)
  set Оіu : в„Ӯ_[p]ЛЈ := Units.mk0 (gammaUnit p a n) hОі0 with hОіu
  have hОіuGen : Оіu вҲҲ gammaGenSet p n := Or.inl вҹЁa, ha, Units.val_mk0 _вҹ©
  -- `Оҫ^a вҲ’ 1 = (ОҫвҲ’1)В·c_n(a)` and `c_n(a) = Оҫ^{(вҲ’halfExp).val}В·Оі_{n,a}`
  have hword : g = deltaUnit p hn * zetaSysUnit p n ^ ((-halfExp p a n).val) * Оіu := by
    refine Units.ext ?_
    rw [Units.val_mul, Units.val_mul, deltaUnit_val, Units.val_pow_eq_pow_val,
      zetaSysUnit_val, hОіu, Units.val_mk0, hgv, gammaUnit,
      show zetaSys p n ^ ((-halfExp p a n).val) = zhp p (-halfExp p a n) from rfl,
      zhp_neg, cycloUnit]
    have hzhpne : zhp p (halfExp p a n) вү  0 := zhp_ne_zero p _
    have hОҙne : zetaSys p n - 1 вү  0 :=
      sub_ne_zero_of_ne
        ((zetaSys_primitiveRoot p n).ne_one (one_lt_powвӮҖ hp.out.one_lt (by omega)))
    field_simp
  rw [hword]
  exact mul_mem (mul_mem (deltaUnit_mem_aug p hn)
    (pow_mem (zetaSysUnit_mem_aug p hn) _)) (gammaGenSet_le_aug p hn hОіuGen)

/-- **The full `Оҫ^a вҲ’ 1` case (RJW TeX 3471вҖ“3472)**: for every `1 вүӨ a < p^n`, the
generator unit `Оҫ^a вҲ’ 1` lies in `M = closure({Оҫ, Оҙ} вҲӘ gammaGenSet)`. Strong induction
on `v_p(a)`: the base `(a,p)=1` is `zetaSys_pow_sub_one_mem_aug_coprime`; for `pвҲЈa` the
`p`-fold identity `zetaSys_pow_mul_sub_one_prod` writes `Оҫ^aвҲ’1` as a product of factors
`Оҫ^{a/p + iВ·p^{nвҲ’1}} вҲ’ 1`, each of strictly smaller `v_p`. -/
private theorem zetaSys_pow_sub_one_mem_aug (hp2 : p вү  2) {n : в„•} (hn : 1 вүӨ n) :
    вҲҖ m : в„•, вҲҖ a : в„•, padicValNat p a = m вҶ’ 1 вүӨ a вҶ’ a < p ^ n вҶ’ вҲҖ g : в„Ӯ_[p]ЛЈ,
      (g : в„Ӯ_[p]) = zetaSys p n ^ a - 1 вҶ’ g вҲҲ Subgroup.closure (augGenSet p hn) := by
  intro m
  induction m using Nat.strong_induction_on with
  | _ m ih =>
    intro a ham ha1 ha2 g hgv
    by_cases hpa : (p : в„•) вҲЈ a
    В· -- `p вҲЈ a`: reduce via the `p`-fold identity
      have hppos : 0 < p := hp.out.pos
      set k : в„• := a / p with hk
      have hak : a = k * p := by rw [hk, Nat.div_mul_cancel hpa]
      have hk1 : 1 вүӨ k := by
        rw [hk, Nat.one_le_div_iff hppos]; exact Nat.le_of_dvd (by omega) hpa
      have hm1 : 1 вүӨ m := by
        rw [вҶҗ ham]; exact one_le_padicValNat_of_dvd (by omega) hpa
      have hvk : padicValNat p k = m - 1 := by rw [hk, padicValNat.div hpa, ham]
      have hmn : m < n := by
        rw [вҶҗ ham]
        have hle : p ^ padicValNat p a вүӨ a := Nat.le_of_dvd (by omega) pow_padicValNat_dvd
        exact (Nat.pow_lt_pow_iff_right hp.out.one_lt).mp (lt_of_le_of_lt hle ha2)
      -- each factor exponent `e i = k + iВ·p^{nвҲ’1}`: bounds and smaller `v_p`
      have hpsucc : p ^ (n - 1) * p = p ^ n := by rw [вҶҗ pow_succ]; congr 1; omega
      have hkb : k < p ^ (n - 1) := by
        rw [hk, Nat.div_lt_iff_lt_mul hppos, hpsucc]; exact ha2
      have he_range : вҲҖ i, i < p вҶ’ k + i * p ^ (n - 1) < p ^ n := by
        intro i hi
        have hib : i * p ^ (n - 1) вүӨ (p - 1) * p ^ (n - 1) :=
          Nat.mul_le_mul_right _ (by omega)
        have : k + i * p ^ (n - 1) < p ^ (n - 1) + (p - 1) * p ^ (n - 1) := by omega
        calc k + i * p ^ (n - 1) < p ^ (n - 1) + (p - 1) * p ^ (n - 1) := this
          _ = p ^ (n - 1) * p := by
              rw [Nat.sub_one_mul, mul_comm p (p ^ (n - 1))]
              have : p ^ (n - 1) вүӨ p ^ (n - 1) * p := Nat.le_mul_of_pos_right _ hppos
              omega
          _ = p ^ n := hpsucc
      have he1 : вҲҖ i, 1 вүӨ k + i * p ^ (n - 1) := fun i => by omega
      have he_ne : вҲҖ i, i < p вҶ’ zetaSys p n ^ (k + i * p ^ (n - 1)) - 1 вү  0 :=
        fun i hi => zetaSys_pow_sub_one_ne_zero p (he1 i) (he_range i hi)
      have he_vlt : вҲҖ i, i < p вҶ’ padicValNat p (k + i * p ^ (n - 1)) < m := by
        intro i hi
        rcases Nat.eq_zero_or_pos i with hi0 | hi0
        В· subst hi0; simp only [zero_mul, add_zero, hvk]; omega
        В· -- `p^m вҲЈ iВ·p^{n-1}` but `p^m вҲӨ k`, so `p^m вҲӨ e i`
          rw [вҶҗ not_le, вҶҗ padicValNat_dvd_iff_le (by omega : k + i * p ^ (n - 1) вү  0)]
          intro hcontra
          have hdvd2 : p ^ m вҲЈ i * p ^ (n - 1) :=
            Dvd.dvd.mul_left (pow_dvd_pow p (by omega)) i
          have hdvdk : p ^ m вҲЈ k := (Nat.dvd_add_right hdvd2).mp (by rwa [add_comm] at hcontra)
          rw [padicValNat_dvd_iff_le (by omega : k вү  0)] at hdvdk; omega
      -- the factor units, and `g = вҲҸ facU i`
      let facU : в„• вҶ’ в„Ӯ_[p]ЛЈ := fun i =>
        if hi : i < p then Units.mk0 _ (he_ne i hi) else 1
      have hfacU_val : вҲҖ i, i < p вҶ’
          (facU i : в„Ӯ_[p]) = zetaSys p n ^ (k + i * p ^ (n - 1)) - 1 := by
        intro i hi; simp only [facU, dif_pos hi, Units.val_mk0]
      have hgprod : g = вҲҸ i вҲҲ Finset.range p, facU i := by
        refine Units.ext ?_
        rw [hgv, hak, zetaSys_pow_mul_sub_one_prod p hp2 hn, Units.coe_prod]
        exact Finset.prod_congr rfl fun i hi =>
          (hfacU_val i (Finset.mem_range.mp hi)).symm
      rw [hgprod]
      refine prod_mem fun i hi => ?_
      rw [Finset.mem_range] at hi
      exact ih _ (he_vlt i hi) _ rfl (he1 i) (he_range i hi) _ (hfacU_val i hi)
    В· -- `(a,p)=1`: base case
      exact zetaSys_pow_sub_one_mem_aug_coprime p hp2 hn hpa ha1 ha2 hgv

/-- **The normal form (RJW TeX 3476)**: every `w вҲҲ M = closure({Оҫ, Оҙ} вҲӘ gammaGenSet)`
has the shape `w = Оҫ^D В· Оҙ^E В· h` with `D E : в„Ө` and `h вҲҲ closure(gammaGenSet)`.
(`в„Ӯ_[p]ЛЈ` is commutative, so the `Оҫ`- and `Оҙ`-powers collect; `gammaGenSet`-generators
go into `h`.) -/
private theorem mem_aug_normal_form {n : в„•} (hn : 1 вүӨ n) {w : в„Ӯ_[p]ЛЈ}
    (hw : w вҲҲ Subgroup.closure (augGenSet p hn)) :
    вҲғ (D E : в„Ө) (h : в„Ӯ_[p]ЛЈ), h вҲҲ Subgroup.closure (gammaGenSet p n) вҲ§
      w = zetaSysUnit p n ^ D * deltaUnit p hn ^ E * h := by
  induction hw using Subgroup.closure_induction with
  | mem x hx =>
      rcases hx with (hОҫ | hОҙ) | hg
      В· exact вҹЁ1, 0, 1, one_mem _, by rw [hОҫ, zpow_one, zpow_zero, mul_one, mul_one]вҹ©
      В· exact вҹЁ0, 1, 1, one_mem _, by rw [hОҙ, zpow_one, zpow_zero, one_mul, mul_one]вҹ©
      В· exact вҹЁ0, 0, x, Subgroup.subset_closure hg, by
          rw [zpow_zero, zpow_zero, mul_one, one_mul]вҹ©
  | one => exact вҹЁ0, 0, 1, one_mem _, by rw [zpow_zero, zpow_zero, mul_one, mul_one]вҹ©
  | mul x y _ _ ihx ihy =>
      obtain вҹЁDвӮҒ, EвӮҒ, hвӮҒ, hhвӮҒ, hxвҹ© := ihx
      obtain вҹЁDвӮӮ, EвӮӮ, hвӮӮ, hhвӮӮ, hyвҹ© := ihy
      refine вҹЁDвӮҒ + DвӮӮ, EвӮҒ + EвӮӮ, hвӮҒ * hвӮӮ, mul_mem hhвӮҒ hhвӮӮ, ?_вҹ©
      rw [hx, hy, zpow_add, zpow_add]; ac_rfl
  | inv x _ ihx =>
      obtain вҹЁD, E, h, hh, hxвҹ© := ihx
      refine вҹЁ-D, -E, hвҒ»В№, Subgroup.inv_mem _ hh, ?_вҹ©
      rw [hx, mul_inv, mul_inv, zpow_neg, zpow_neg]

/-- `closure(cycloGenSet) вүӨ M`: the three generator types `Оҫ`, `вҲ’Оҫ`, `Оҫ^aвҲ’1` of `рқ’ҹ_n`
all lie in `M = closure({Оҫ, Оҙ} вҲӘ gammaGenSet)`. -/
private theorem closure_cycloGenSet_le_aug (hp2 : p вү  2) {n : в„•} (hn : 1 вүӨ n) :
    Subgroup.closure (cycloGenSet p n) вүӨ Subgroup.closure (augGenSet p hn) := by
  rw [Subgroup.closure_le]
  rintro g (hОҫ | hОҫ | вҹЁa, ha1, ha2, hgvвҹ©)
  В· -- `g = Оҫ`
    rw [show g = zetaSysUnit p n from Units.ext (by rw [hОҫ, zetaSysUnit_val])]
    exact zetaSysUnit_mem_aug p hn
  В· -- `g = вҲ’Оҫ = (вҲ’1)В·Оҫ`
    have hword : g = (-1 : в„Ӯ_[p]ЛЈ) * zetaSysUnit p n := by
      refine Units.ext ?_
      rw [Units.val_mul, Units.val_neg, Units.val_one, zetaSysUnit_val, hОҫ, neg_one_mul]
    rw [hword]
    refine mul_mem (gammaGenSet_le_aug p hn (Or.inr ?_)) (zetaSysUnit_mem_aug p hn)
    change ((-1 : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]) = -1
    simp
  В· -- `g = Оҫ^a вҲ’ 1` with `1 вүӨ a вүӨ p^n вҲ’ 1`
    have hpn : 1 вүӨ p ^ n := Nat.one_le_pow _ _ hp.out.pos
    exact zetaSys_pow_sub_one_mem_aug p hp2 hn (padicValNat p a) a rfl ha1
      (by omega) g hgv

/-- **RJW lem:cyc units gen (i) (TeX 3461вҖ“3482)**: `рқ’ҹ_n^+` is generated by `вҲ’1` and the
`Оі_{n,a}` with `(a,p)=1`. (`cor:cyc units gen 2`, TeX 3484вҖ“3486: a single `Оі_{n,a}` with
`a` generating `(в„Ө/p^nв„Ө)^Г—` suffices as a `в„Ө[рқ’ў_n^+]`-module generator вҖ” its statement
needs the finite Galois action on units and is finalised in E12.4 at execution.) -/
theorem cycloUnitsPlus_eq_closure_gammas (hp2 : p вү  2) {n : в„•} (hn : 1 вүӨ n) :
    cycloUnitsPlus p n = Subgroup.closure
      ({g : в„Ӯ_[p]ЛЈ | вҲғ b : в„•, В¬ (p : в„•) вҲЈ b вҲ§ (g : в„Ӯ_[p]) = gammaUnit p b n} вҲӘ
        {g : в„Ӯ_[p]ЛЈ | (g : в„Ӯ_[p]) = -1}) := by
  refine le_antisymm ?_ ?_
  В· -- `вҠҶ`: the valuation/reality normal-form direction (RJW TeX 3474вҖ“3481)
    intro u hu
    obtain вҹЁhucyc, huRealвҹ© := hu
    rw [cycloUnits, Subgroup.mem_inf] at hucyc
    obtain вҹЁhuClosure, huGlobalвҹ© := hucyc
    -- `u вҲҲ M`, extract the normal form `u = Оҫ^D В· Оҙ^E В· h`
    have huAug : u вҲҲ Subgroup.closure (augGenSet p hn) :=
      closure_cycloGenSet_le_aug p hp2 hn huClosure
    obtain вҹЁD, E, h, hh, huDEhвҹ© := mem_aug_normal_form p hn huAug
    -- `h` is real, `valHom h = 1`
    have hhReal : (h : в„Ӯ_[p]) вҲҲ FglobalPlus p n :=
      coe_mem_FglobalPlus_of_mem_closure_gammaGenSet p hp2 hn hh
    have hhVal : valHom p h = 1 := valHom_eq_one_of_mem_closure_gammaGenSet p hn hh
    -- `valHom u = 1` (global unit вҹ№ norm 1)
    have huNorm : вҖ–(u : в„Ӯ_[p])вҖ– = 1 := by
      obtain вҹЁ_, hint, hintInvвҹ© := huGlobal
      have h1 : вҖ–(u : в„Ӯ_[p])вҖ– вүӨ 1 := norm_le_one_of_isIntegral_int p hint
      have h2 : вҖ–((uвҒ»В№ : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p])вҖ– вүӨ 1 := norm_le_one_of_isIntegral_int p hintInv
      rw [Units.val_inv_eq_inv_val, norm_inv] at h2
      have hpos : 0 < вҖ–(u : в„Ӯ_[p])вҖ– := norm_pos_iff.mpr u.ne_zero
      have hge : 1 вүӨ вҖ–(u : в„Ӯ_[p])вҖ– := (inv_le_oneвӮҖ hpos).mp h2
      exact le_antisymm h1 hge
    have huVal : valHom p u = 1 := valHom_eq_one_of_norm_one p huNorm
    have hОҫVal : valHom p (zetaSysUnit p n) = 1 :=
      valHom_eq_one_of_norm_one p (by rw [zetaSysUnit_val, norm_zetaSys_eq_one])
    -- kill the `Оҙ`-exponent: `valHom Оҙ ^ E = 1` with `valHom Оҙ вү  1` вҹ№ `E = 0`
    have hОҙpow : valHom p (deltaUnit p hn) ^ E = 1 := by
      have := congrArg (valHom p) huDEh
      rw [huVal, map_mul, map_mul, map_zpow, map_zpow, hОҫVal, hhVal, one_zpow, one_mul,
        mul_one] at this
      exact this.symm
    have hE0 : E = 0 := by
      by_contra hE
      apply valHom_deltaUnit_ne_one p hn
      -- `valHom Оҙ = ofAdd c`, `(ofAdd c)^E = ofAdd (EвҖўc) = 1 вҹ№ c = 0`
      set c : в„қ := -Real.log вҖ–(deltaUnit p hn : в„Ӯ_[p])вҖ– with hc
      have hval : valHom p (deltaUnit p hn) = Multiplicative.ofAdd c := rfl
      rw [hval, вҶҗ ofAdd_zsmul, ofAdd_eq_one, zsmul_eq_mul] at hОҙpow
      rw [hval, ofAdd_eq_one]
      rcases mul_eq_zero.mp hОҙpow with hEz | hcz
      В· exact absurd (by exact_mod_cast hEz) hE
      В· exact hcz
    -- kill the `Оҫ`-exponent: `Оҫ^D` is real вҹ№ `Оҫ^D = 1`
    rw [hE0, zpow_zero, mul_one] at huDEh
    have hОҫDReal : ((zetaSysUnit p n ^ D : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]) вҲҲ FglobalPlus p n := by
      rw [show zetaSysUnit p n ^ D = u * hвҒ»В№ from by rw [huDEh, mul_inv_cancel_right]]
      rw [Units.val_mul, Units.val_inv_eq_inv_val]
      exact mul_mem huReal ((FglobalPlus p n).inv_mem hhReal)
    have hОҫD1 : zetaSysUnit p n ^ D = 1 :=
      zetaSysUnit_zpow_eq_one_of_mem_FglobalPlus p hp2 hn D hОҫDReal
    -- conclude `u = h вҲҲ closure(gammaGenSet)`
    rw [huDEh, hОҫD1, one_mul]
    exact hh
  В· -- `вҠҮ`: every generator lies in `рқ’ҹ_n^+`
    rw [Subgroup.closure_le]
    rintro g (вҹЁb, hb, hvalвҹ© | hval)
    В· -- `Оі_b вҲҲ рқ’ҹ_n^+`
      obtain вҹЁg', hg'val, hg'memвҹ© := gammaUnit_mem_cycloUnitsPlus p hb hp2 hn
      rw [show g = g' from Units.ext (by rw [hval, hg'val])]
      exact hg'mem
    В· -- `вҲ’1 вҲҲ рқ’ҹ_n^+`
      rw [show g = (-1 : в„Ӯ_[p]ЛЈ) from Units.ext (by rw [hval]; simp)]
      exact neg_one_mem_cycloUnitsPlus p

/-- `zpPow y 0 = 1` (the `n = 0` natural power). -/
private theorem zpPow_zero' {y : в„Ӯ_[p]} (hy : вҖ–y - 1вҖ– < 1) : zpPow p y 0 = 1 := by
  rw [show (0 : в„Ө_[p]) = ((0 : в„•) : в„Ө_[p]) by norm_cast, zpPow_natCast p hy, pow_zero]

/-- `zpPow y (вҲ’a) = (zpPow y a)вҒ»В№`. -/
private theorem zpPow_neg' {y : в„Ӯ_[p]} (hy : вҖ–y - 1вҖ– < 1) (a : в„Ө_[p]) :
    zpPow p y (-a) = (zpPow p y a)вҒ»В№ :=
  eq_inv_of_mul_eq_one_left (by rw [вҶҗ zpPow_add p hy, neg_add_cancel, zpPow_zero' p hy])

/-- `zpPow y (k : в„Ө_[p]) = y ^ k` for integer `k` (matching the multiplicative
`в„Ө`-action on the `1`-unit `y`). -/
private theorem zpPow_intCast {y : в„Ӯ_[p]} (hy : вҖ–y - 1вҖ– < 1) (k : в„Ө) :
    zpPow p y ((k : в„Ө_[p])) = y ^ k := by
  obtain вҹЁm, rfl | rflвҹ© := Int.eq_nat_or_neg k
  В· rw [Int.cast_natCast, zpPow_natCast p hy, zpow_natCast]
  В· rw [Int.cast_neg, Int.cast_natCast, zpPow_neg' p hy, zpPow_natCast p hy, zpow_neg,
      zpow_natCast]

/-- **RJW lem:closure (TeX 3503вҖ“3505)**: for `g_1,вҖҰ,g_r вҲҲ рқ’°_{n,1}`, the p-adic closure of
the multiplicative `в„Ө`-span `вҹЁg_iвҹ©` is the `в„Ө_p`-span (the `zpPow` binomial converges,
`в„Ө_p^r` compact). Stated for a single generator `g` (the case used downstream).

Proof: the set `T = {y | вҶ‘y вҲҲ range (zpPow вҶ‘g)}` is closed (`range (zpPow вҶ‘g)` is the
continuous image of the compact `в„Ө_p`, hence closed) and contains `вҹЁgвҹ©_в„Ө`
(`zpPow_intCast`); the closure is therefore contained in `T`. -/
theorem closure_zspan_eq_zpspan {n : в„•} (hn : 1 вүӨ n) {g : в„Ӯ_[p]ЛЈ}
    (hg : g вҲҲ localUnitsOne p n)
    (x : в„Ӯ_[p]ЛЈ) (hx : x вҲҲ (Subgroup.zpowers g).topologicalClosure) :
    вҲғ a : в„Ө_[p], (x : в„Ӯ_[p]) = zpPow p (g : в„Ӯ_[p]) a := by
  have hgnorm : вҖ–(g : в„Ӯ_[p]) - 1вҖ– < 1 := ((mem_localUnitsOne_iff p).1 hg).2
  -- continuity of `c вҶҰ zpPow вҶ‘g c` on `в„Ө_p`
  have hcont : Continuous (zpPow p (g : в„Ӯ_[p])) := by
    have h : zpPow p (g : в„Ӯ_[p]) = (PadicInt.addChar_of_value_at_one ((g : в„Ӯ_[p]) - 1)
        (tendsto_pow_atTop_nhds_zero_iff_norm_lt_one.mpr hgnorm) : в„Ө_[p] вҶ’ в„Ӯ_[p]) := by
      funext c
      rw [zpPow, dif_pos (tendsto_pow_atTop_nhds_zero_iff_norm_lt_one.mpr hgnorm)]
    rw [h]; exact PadicInt.continuous_addChar_of_value_at_one _
  -- the target set `T`, closed (compact range of `zpPow`) and containing `вҹЁgвҹ©_в„Ө`
  set T : Set в„Ӯ_[p]ЛЈ := {y : в„Ӯ_[p]ЛЈ | вҲғ a : в„Ө_[p], (y : в„Ӯ_[p]) = zpPow p (g : в„Ӯ_[p]) a}
    with hT
  have hTeq : T = (Units.val вҒ»В№' (Set.range (zpPow p (g : в„Ӯ_[p])))) := by
    ext y; simp only [hT, Set.mem_setOf_eq, Set.mem_preimage, Set.mem_range, eq_comm]
  have hrangeClosed : IsClosed (Set.range (zpPow p (g : в„Ӯ_[p]))) :=
    (isCompact_range hcont).isClosed
  have hTclosed : IsClosed T := by
    rw [hTeq]; exact hrangeClosed.preimage Units.continuous_val
  -- `вҹЁgвҹ©_в„Ө вҠҶ T`
  have hsub : (Subgroup.zpowers g : Set в„Ӯ_[p]ЛЈ) вҠҶ T := by
    rintro y вҹЁk, rflвҹ©
    refine вҹЁ(k : в„Ө_[p]), ?_вҹ©
    rw [zpPow_intCast p hgnorm k, Units.val_zpow_eq_zpow_val]
  -- the closure of `вҹЁgвҹ©_в„Ө` is contained in `T`
  have hclosure : closure (Subgroup.zpowers g : Set в„Ӯ_[p]ЛЈ) вҠҶ T :=
    hTclosed.closure_subset_iff.mpr hsub
  exact hclosure hx

/-- `вҖ–zhp c вҲ’ 1вҖ– < 1` (a half-power root of unity is a principal unit). -/
private theorem norm_zhp_sub_one_lt {n : в„•} (hn : 1 вүӨ n) (c : ZMod (p ^ n)) :
    вҖ–zhp p c - 1вҖ– < 1 := by
  rw [zhp]; exact norm_zetaSys_pow_sub_one_lt p hn c.val

/-- `вҖ–c_n(a) вҲ’ aвҖ– < 1`: `c_n(a) вҲ’ a = вҲ‘_{i<a}(Оҫ^i вҲ’ 1)`, an ultrametric sum of
principal terms (unconditional in `a`; the В§11 T1113 hypothesis `a вүЎ 1 mod p` is only
needed for `вҖ–c_n(a)вҲ’1вҖ– < 1`, not this). -/
private theorem norm_cycloUnit_sub_natCast_lt {a : в„•} {n : в„•} (hn : 1 вүӨ n) :
    вҖ–cycloUnit p a n - (a : в„Ӯ_[p])вҖ– < 1 := by
  have hca : cycloUnit p a n - (a : в„Ӯ_[p])
      = вҲ‘ i вҲҲ Finset.range a, (zetaSys p n ^ i - 1) := by
    rw [cycloUnit_eq_geomSum p hn, Finset.sum_sub_distrib, Finset.sum_const,
      Finset.card_range, nsmul_eq_mul, mul_one]
  rw [hca]
  rcases Nat.eq_zero_or_pos a with ha0 | ha0
  В· subst ha0; simp
  refine lt_of_le_of_lt (IsUltrametricDist.norm_sum_le_of_forall_le_of_nonneg
    (norm_nonneg (pi p n)) (fun i _ => ?_)) (by rw [pi]; exact norm_pi_lt_one p hn)
  have := (norm_zetaSys_pow_sub_one_lt p hn i).le
  rw [pi]
  calc вҖ–zetaSys p n ^ i - 1вҖ– вүӨ вҖ–zetaSys p n - 1вҖ– := by
        rw [show zetaSys p n ^ i - 1
            = (вҲ‘ j вҲҲ Finset.range i, zetaSys p n ^ j) * (zetaSys p n - 1) from
          (geom_sum_mul _ i).symm, norm_mul]
        have hgeom : вҖ–вҲ‘ j вҲҲ Finset.range i, zetaSys p n ^ jвҖ– вүӨ 1 :=
          IsUltrametricDist.norm_sum_le_of_forall_le_of_nonneg zero_le_one
            (fun j _ => by rw [norm_pow, norm_zetaSys_eq_one, one_pow])
        nlinarith [norm_nonneg (zetaSys p n - 1), hgeom]
    _ = вҖ–zetaSys p n - 1вҖ– := rfl

/-- **The В§11 b2-note resolved (RJW TeX 3567)**: `Оі_{n,a} вүЎ a (mod рқ”ӯ_n)`, i.e.
`вҖ–Оі_{n,a} вҲ’ aвҖ– < 1`. From `Оі = Оҫ^{(1вҲ’a)/2} c_n(a)`: the half-power
`Оҫ^{(1вҲ’a)/2} вүЎ 1` (`norm_zhp_sub_one_lt`) and `c_n(a) вүЎ a`
(`norm_cycloUnit_sub_natCast_lt`), so `Оі вҲ’ a = (Оҫ^{(1вҲ’a)/2}вҲ’1) c_n(a) + (c_n(a)вҲ’a)`
has norm `< 1`. This is the fact making the TeichmГјller correction
`w` (with `aw вүЎ 1`) yield `wОі_{n,a} вүЎ 1 mod рқ”ӯ_n вҲҲ рқ’°_{n,1}`. -/
theorem gammaUnit_congr_natCast {a : в„•} (ha : В¬ (p : в„•) вҲЈ a) {n : в„•} (hn : 1 вүӨ n) :
    вҖ–gammaUnit p a n - (a : в„Ӯ_[p])вҖ– < 1 := by
  -- `c_n(a)` has norm `1`
  have hcnorm : вҖ–cycloUnit p a nвҖ– = 1 := norm_cycloUnit p ha hn
  -- `Оі вҲ’ a = (Оҫ^{(1вҲ’a)/2}вҲ’1)В·c_n(a) + (c_n(a)вҲ’a)`
  have hsplit : gammaUnit p a n - (a : в„Ӯ_[p])
      = (zhp p (halfExp p a n) - 1) * cycloUnit p a n + (cycloUnit p a n - (a : в„Ӯ_[p])) := by
    rw [gammaUnit]; ring
  rw [hsplit]
  refine lt_of_le_of_lt (IsUltrametricDist.norm_add_le_max _ _) (max_lt ?_ ?_)
  В· rw [norm_mul, hcnorm, mul_one]
    exact norm_zhp_sub_one_lt p hn _
  В· exact norm_cycloUnit_sub_natCast_lt p hn

/-- **The TeichmГјller-correction congruence** (RJW LemmaGeneratorCinfty1, TeX 3553вҖ“3567):
`Оі_{n,a} вүЎ a (mod рқ”ӯ_n)` for every level `n вүҘ 1` (`gammaUnit_congr_natCast`). This is the
fact making the TeichmГјller correction `w вҲҲ Ој_{pвҲ’1}` (with `aw вүЎ 1`) produce a *principal*
unit `wОі_{n,a} вүЎ 1 mod рқ”ӯ_n` вҖ” the В§11 b2 note resolved вҖ” feeding the principal generator
`wОі(aвӮҖ)` (`wGamma`) of the cyclic-`Оӣ(рқ’ў^+)`-module description of `рқ’һ_{вҲһ,1}^+`.

(The genuine level-`n` single-generator cyclicity `cor:cyc units gen 2`, RJW TeX 3484вҖ“3486,
is `cycloUnit_mem_cycloTranslateSubgroup` below: the single `c_n(aвӮҖ)` `в„Ө[рқ’ў_n]`-generates
every cyclotomic unit via the explicit telescoping `c_n(b') = вҲҸ_i Пғ_{aвӮҖ^i}(c_n(aвӮҖ))`. The
full inverse-limit `Оӣ(рқ’ў^+)`-cyclicity, TeX 3573вҖ“3578, additionally needs the `Оӣ(рқ’ў^+)`-module
structure on the unit tower `рқ’һ^+_{вҲһ,1}`, which is the В§13 module layer absent from the
project.) -/
theorem gammaUnit_congr_natCast_tower {a : в„•} (ha : В¬ (p : в„•) вҲЈ a) :
    вҲҖ n : в„•, 1 вүӨ n вҶ’ вҖ–gammaUnit p a n - (a : в„Ӯ_[p])вҖ– < 1 :=
  fun _ hn => gammaUnit_congr_natCast p ha hn

/-! ## The Galois `Пғ_a`-stability of the cyclotomic tower (RJW В§12.4 infrastructure)

The `рқ’ў`-action `Пғ_a = galNCU a` permutes the cyclotomic units, hence stabilises every
layer of the cyclotomic tower `рқ’һ_{вҲһ,1}`. This is the structural backbone of RJW's
inverse-limit `Оӣ(рқ’ў)`-module description of `рқ’һ_{вҲһ,1}` (TeX 3553вҖ“3578): the action is
levelwise the field automorphism `Пғ_a` of `K_n`, which sends the cyclotomic generators
`Оҫ_n, Оҫ_n^b вҲ’ 1` to cyclotomic words (`Пғ_a(Оҫ_n) = Оҫ_n^{t}`, `Пғ_a(Оҫ_n^bвҲ’1) = Оҫ_n^{tb}вҲ’1`),
preserves global integrality (it is a `в„ҡ`-algebra automorphism of `F_n = в„ҡ(Оҫ_n)`),
and is an isometry (`norm_galAut`), so it preserves both the principal-unit condition and
the `p`-adic closures. The homomorphism laws `galNCU_mul`/`galNCU_one` express that `Пғ_a`
is a group endomorphism of `рқ’°_вҲһ`. -/

/-- `Пғ_a` is a group homomorphism of `рқ’°_вҲһ`: `Пғ_a(uВ·v) = Пғ_a(u)В·Пғ_a(v)`. Levelwise this is
`map_mul` of the field automorphism `galAut p a n` (`galAutUnit_val`). -/
theorem galNCU_mul (a : в„Ө_[p]ЛЈ) (u v : NormCompatUnits p) :
    galNCU p a (u * v) = galNCU p a u * galNCU p a v := by
  refine NormCompatUnits.ext (funext fun n => Units.ext ?_)
  change ((galNCU p a (u * v)).elems n : в„Ӯ_[p])
    = ((galNCU p a u).elems n * (galNCU p a v).elems n : в„Ӯ_[p]ЛЈ)
  rw [Units.val_mul]
  change (galAut p a n вҹЁ((u * v).elems n : в„Ӯ_[p]), _вҹ© : в„Ӯ_[p])
    = (galAut p a n вҹЁ(u.elems n : в„Ӯ_[p]), _вҹ© : в„Ӯ_[p])
      * (galAut p a n вҹЁ(v.elems n : в„Ӯ_[p]), _вҹ© : в„Ӯ_[p])
  rw [show (вҹЁ((u * v).elems n : в„Ӯ_[p]), (Subring.mem_inf.1 ((u * v).mem n)).1вҹ© : K p n)
      = вҹЁ(u.elems n : в„Ӯ_[p]), (Subring.mem_inf.1 (u.mem n)).1вҹ©
        * вҹЁ(v.elems n : в„Ӯ_[p]), (Subring.mem_inf.1 (v.mem n)).1вҹ© from
    Subtype.ext (by change ((u.elems n * v.elems n : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]) = _; rw [Units.val_mul]; rfl),
    map_mul]
  rfl

/-- `Пғ_a(1) = 1` (the field automorphism fixes `1`). -/
theorem galNCU_one (a : в„Ө_[p]ЛЈ) : galNCU p a (1 : NormCompatUnits p) = 1 := by
  refine NormCompatUnits.ext (funext fun n => Units.ext ?_)
  -- the level-`n` value is `Пғ_a(вҹЁ1, _вҹ©) = Пғ_a(1) = 1`
  have hsub : (вҹЁ((1 : NormCompatUnits p).elems n : в„Ӯ_[p]),
      (Subring.mem_inf.1 ((1 : NormCompatUnits p).mem n)).1вҹ© : K p n) = 1 := Subtype.ext rfl
  calc ((galNCU p a (1 : NormCompatUnits p)).elems n : в„Ӯ_[p])
      = (galAut p a n вҹЁ((1 : NormCompatUnits p).elems n : в„Ӯ_[p]),
          (Subring.mem_inf.1 ((1 : NormCompatUnits p).mem n)).1вҹ© : в„Ӯ_[p]) := rfl
    _ = (galAut p a n (1 : K p n) : в„Ӯ_[p]) := by rw [hsub]
    _ = ((1 : NormCompatUnits p).elems n : в„Ӯ_[p]ЛЈ) := by rw [map_one]; rfl

/-- The level value of `Пғ_a u`: `(Пғ_a u)_n = Пғ_a(вҹЁu_n, _вҹ©)` as elements of `в„Ӯ_[p]` (the
defining levelwise application of the field automorphism `galAut`). -/
theorem galNCU_elems_val (a : в„Ө_[p]ЛЈ) (u : NormCompatUnits p) (n : в„•) :
    (((galNCU p a u).elems n : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p])
      = (galAut p a n вҹЁ(u.elems n : в„Ӯ_[p]), (Subring.mem_inf.1 (u.mem n)).1вҹ© : в„Ӯ_[p]) :=
  rfl

/-- **`Пғ_a` preserves the principal-unit tower `рқ’°_{вҲһ,1}`** (RJW В§12.4: the `рқ’ў`-action
stabilises the level filtration of the local units). Levelwise: `Пғ_a u_n` and its inverse
stay in `O_n` (the `NormCompatUnits` integrality of `Пғ_a u`), and `Пғ_a` is an isometry fixing
`1` (`norm_galAut`, `map_one`), so `вҖ–Пғ_a u_n вҲ’ 1вҖ– = вҖ–Пғ_a(u_n вҲ’ 1)вҖ– = вҖ–u_n вҲ’ 1вҖ– < 1`. -/
theorem galNCU_mem_unitsTower1 (a : в„Ө_[p]ЛЈ) {u : NormCompatUnits p}
    (hu : u вҲҲ unitsTower1 p) : galNCU p a u вҲҲ unitsTower1 p := by
  intro n hn
  have hone := ((mem_localUnitsOne_iff p).1 (hu n hn)).2
  set y : K p n := вҹЁ(u.elems n : в„Ӯ_[p]), (Subring.mem_inf.1 (u.mem n)).1вҹ© with hy
  have hval : (((galNCU p a u).elems n : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]) = (galAut p a n y : в„Ӯ_[p]) := rfl
  refine (mem_localUnitsOne_iff p).2 вҹЁ?_, ?_вҹ©
  В· -- `Пғ_a u_n вҲҲ рқ’°_n`: the value and inverse-value lie in `O_n` (the `NormCompatUnits` fields)
    exact (mem_localUnits_iff p).2 вҹЁ(galNCU p a u).mem n, by
      rw [Units.val_inv_eq_inv_val]; exact (galNCU p a u).inv_mem nвҹ©
  В· -- `вҖ–Пғ_a u_n вҲ’ 1вҖ– = вҖ–u_n вҲ’ 1вҖ– < 1` (isometry fixing `1`)
    rw [hval]
    have h1 : (galAut p a n y : в„Ӯ_[p]) - 1 = (galAut p a n (y - 1) : в„Ӯ_[p]) := by
      rw [map_sub, map_one]; rfl
    rw [h1, norm_galAut p a (y - 1),
      show ((y - 1 : K p n) : в„Ӯ_[p]) = (u.elems n : в„Ӯ_[p]) - 1 from by
        change ((y : K p n) : в„Ӯ_[p]) - ((1 : K p n) : в„Ӯ_[p]) = _; rw [hy]; rfl]
    exact hone

/-- The convolution form of the `Оӣ(рқ’ў)`-equivariance of `Col` (RJW cor:G-eq, TeX 3217вҖ“3243):
`Col(Пғ_a u) = [a]В·Col u`, the multiplication by the Dirac mass `[a] = dirac a` in the Iwasawa
algebra `Оӣ(в„Ө_p^Г—)`. This is `Col_galNCU` (`Col(Пғ_a u) = ПҖ_*(Col u)` for `ПҖ = (aВ·)`) rewritten
through `dirac a * Ој = pushforward (aВ·) Ој`: `dirac a` convolved with `Ој` integrates `f(aВ·)`,
exactly the pushforward along left multiplication. Together with `galNCU_mul`/`galNCU_one` this
is the scalar `[a]`-action of the cyclic-`Оӣ(рқ’ў)`-module description of `рқ’һ_{вҲһ,1}`. -/
theorem dirac_mul_eq_pushforward (a : в„Ө_[p]ЛЈ) (Ој : PadicMeasure p в„Ө_[p]ЛЈ) :
    (PadicMeasure.dirac p a) * Ој = PadicMeasure.pushforward p (unitsMulLeftCM p a) Ој := by
  refine LinearMap.ext fun f => ?_
  rw [PadicMeasure.pushforward_apply]
  change PadicMeasure.dirac p a
      (PadicMeasure.innerInt p Ој (f.comp (PadicMeasure.mulCMвӮӮ в„Ө_[p]ЛЈ))) = _
  rw [PadicMeasure.dirac_apply, PadicMeasure.innerInt_apply]
  congr 1

/-- **`Col(Пғ_a u) = [a]В·Col u`** (RJW cor:G-eq, convolution form): the `рқ’ў`-translate `Пғ_a u`
maps under `Col` to the Dirac translate `[a]В·Col u` in `Оӣ(в„Ө_p^Г—)`. Combines `Col_galNCU`
(pushforward form) with `dirac_mul_eq_pushforward`. The scalar `[a]` ranges over the group
elements `{[Пғ_a]}` whose `в„Ө_p`-span is dense in `Оӣ(рқ’ў)`; this is the generator-image identity
feeding the `I(рқ’ў)О¶_p`-image computation `Col(О»В·c) = О»В·Col(c)`. -/
theorem Col_galNCU_eq_dirac_mul (a : в„Ө_[p]ЛЈ) (u : NormCompatUnits p) :
    Col p (galNCU p a u) = (PadicMeasure.dirac p a) * Col p u := by
  rw [Col_galNCU p a u, dirac_mul_eq_pushforward]

/-! ## The `Пғ_a`-stability of the cyclotomic tower `рқ’һ_{вҲһ,1}` (RJW В§12.4, TeX 3201вҖ“3216)

The `рқ’ў`-action `Пғ_a = galNCU a` stabilises `рқ’һ_{вҲһ,1}` because it permutes the cyclotomic
units of every level: `Пғ_a(Оҫ_n) = Оҫ_n^t` (`galAut_zetaSys`, `t = (a mod p^n).val`) sends the
generators `ВұОҫ_n, Оҫ_n^bвҲ’1` to cyclotomic words, fixes `в„ҡ`, preserves global integrality
(it is a `в„ҡ`-algebra automorphism of `F_n = в„ҡ(Оҫ_n)`), and is a continuous isometry
(`norm_galAut`), so it preserves the `p`-adic closure `рқ’һ_{n,1}`. This is the levelwise
realisation of the `[Пғ_a]`-scalar action on the cyclic `Оӣ(рқ’ў)`-module `рқ’һ_{вҲһ,1}`. -/

/-- `Пғ_a` preserves `F_n = в„ҡ(Оҫ_n)`: if `x вҲҲ F_n` then `Пғ_a x вҲҲ F_n`. Levelwise the
generator goes to `Пғ_a(Оҫ_n) = Оҫ_n^t вҲҲ F_n` (`galAut_zetaSys`), `в„ҡ` is fixed, and the field
operations are closed; same `IntermediateField.adjoin_induction` as the reality lemma. -/
private theorem galAut_mem_Fglobal (a : в„Ө_[p]ЛЈ) {n : в„•} (hn : 1 вүӨ n) {x : в„Ӯ_[p]}
    (hx : x вҲҲ Fglobal p n) (hxK : x вҲҲ K p n) :
    (galAut p a n вҹЁx, hxKвҹ© : в„Ӯ_[p]) вҲҲ Fglobal p n := by
  have toK : вҲҖ {y : в„Ӯ_[p]}, y вҲҲ Fglobal p n вҶ’ y вҲҲ K p n := fun hy => Fglobal_le_K p hy
  have key : вҲҖ y вҲҲ Fglobal p n, вҲҖ (hyK : y вҲҲ K p n),
      (galAut p a n вҹЁy, hyKвҹ© : в„Ӯ_[p]) вҲҲ Fglobal p n := by
    intro y hy
    rw [Fglobal] at hy
    induction hy using IntermediateField.adjoin_induction with
    | mem z hz =>
        obtain rfl := hz
        intro hzK
        rw [show (вҹЁzetaSys p n, hzKвҹ© : K p n) = вҹЁzetaSys p n, zetaSys_mem_K p nвҹ© from rfl,
          galAut_zetaSys p a hn]
        exact pow_mem (IntermediateField.mem_adjoin_simple_self в„ҡ _) _
    | algebraMap q =>
        intro hqK
        have hval : ((q : K p n) : в„Ӯ_[p]) = (algebraMap в„ҡ в„Ӯ_[p]) q := by
          rw [eq_ratCast (algebraMap в„ҡ в„Ӯ_[p]) q]; push_cast; ring
        rw [show (вҹЁ(algebraMap в„ҡ в„Ӯ_[p]) q, hqKвҹ© : K p n) = (q : K p n) from
          Subtype.ext (by rw [hval]), map_ratCast, hval]
        exact (Fglobal p n).algebraMap_mem q
    | add y z hy hz ihy ihz =>
        intro hyzK
        rw [show (вҹЁy + z, hyzKвҹ© : K p n) = вҹЁy, toK hyвҹ© + вҹЁz, toK hzвҹ© from rfl, map_add]
        push_cast
        exact add_mem (ihy (toK hy)) (ihz (toK hz))
    | inv y hy ihy =>
        intro hyinvK
        rw [show (вҹЁyвҒ»В№, hyinvKвҹ© : K p n) = (вҹЁy, toK hyвҹ©)вҒ»В№ from rfl, map_invвӮҖ]
        push_cast
        exact (Fglobal p n).inv_mem (ihy (toK hy))
    | mul y z hy hz ihy ihz =>
        intro hyzK
        rw [show (вҹЁy * z, hyzKвҹ© : K p n) = вҹЁy, toK hyвҹ© * вҹЁz, toK hzвҹ© from rfl, map_mul]
        push_cast
        exact mul_mem (ihy (toK hy)) (ihz (toK hz))
  exact key x hx hxK

/-- `Пғ_a` preserves `в„Ө`-integrality of `K_n`-elements: if `x вҲҲ K_n` is integral over `в„Ө`
then so is `Пғ_a x`. `Пғ_a` is a `в„ҡ_p`-algebra automorphism of `K_n`, hence sends a root of a
monic `в„Ө`-polynomial to a root of the same polynomial (`IsIntegral.map_of_comp_eq` with
`ПҶ = id_в„Ө`, `ПҲ = (K_n).val вҲҳ Пғ_a`, which commutes with `algebraMap в„Ө`). -/
private theorem galAut_isIntegral (a : в„Ө_[p]ЛЈ) {n : в„•} {x : в„Ӯ_[p]} (hxK : x вҲҲ K p n)
    (hx : IsIntegral в„Ө x) :
    IsIntegral в„Ө (galAut p a n вҹЁx, hxKвҹ© : в„Ӯ_[p]) := by
  -- the injective ring hom `g = K_n вҶӘ в„Ӯ_p` and `f = algebraMap в„Ө K_n`
  have hginj : Function.Injective ((K p n).subtype : K p n вҶ’+* в„Ӯ_[p]) := Subtype.val_injective
  -- `x` integral over `в„Ө` as a `K_n`-element: `(g.comp f).IsIntegralElem (g вҹЁxвҹ©) вҶ” ...`
  have hxKint : IsIntegral в„Ө (вҹЁx, hxKвҹ© : K p n) := by
    have hcomp : ((K p n).subtype : K p n вҶ’+* в„Ӯ_[p]).comp (algebraMap в„Ө (K p n))
        = algebraMap в„Ө в„Ӯ_[p] := by ext m; simp
    have := (RingHom.IsIntegralElem.map_iff (f := algebraMap в„Ө (K p n))
      (g := ((K p n).subtype : K p n вҶ’+* в„Ӯ_[p])) hginj (x := вҹЁx, hxKвҹ©)).1
    rw [hcomp] at this
    exact this hx
  -- transport through the `в„Ө`-algebra ring hom `(K_n).val вҲҳ Пғ_a : K_n вҶ’ в„Ӯ_p`
  refine IsIntegral.map_of_comp_eq (RingHom.id в„Ө)
    ((K p n).subtype.comp (galAut p a n).toAlgHom.toRingHom) ?_ hxKint
  ext m
  simp

/-- `Пғ_a` of a power of `Оҫ_n`: `Пғ_a(Оҫ_n^k) = Оҫ_n^{tВ·k}` with `t = (a mod p^n).val`
(`galAut_zetaSys` + `map_pow`). The `K_n`-element `вҹЁОҫ_n^k, _вҹ©` is `вҹЁОҫ_n, _вҹ©^k`. -/
private theorem galAut_zetaSys_pow (a : в„Ө_[p]ЛЈ) {n : в„•} (hn : 1 вүӨ n) (k : в„•)
    (hk : zetaSys p n ^ k вҲҲ K p n) :
    (galAut p a n вҹЁzetaSys p n ^ k, hkвҹ© : в„Ӯ_[p])
      = zetaSys p n ^ (((PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ) :
          ZMod (p ^ n)).val * k) := by
  rw [show (вҹЁzetaSys p n ^ k, hkвҹ© : K p n) = (вҹЁzetaSys p n, zetaSys_mem_K p nвҹ© : K p n) ^ k from
    Subtype.ext (by push_cast; ring), map_pow, SubmonoidClass.coe_pow, galAut_zetaSys p a hn,
    вҶҗ pow_mul]

/-- `вҲ’1 вҲҲ closure(cycloGenSet n)`: `вҲ’1 = (вҲ’Оҫ_n)В·Оҫ_nвҒ»В№`, both factors generated. -/
private theorem neg_one_mem_closure_cycloGenSet {n : в„•} (hn : 1 вүӨ n) :
    вҲҖ x : в„Ӯ_[p]ЛЈ, (x : в„Ӯ_[p]) = -1 вҶ’ x вҲҲ Subgroup.closure (cycloGenSet p n) := by
  intro x hx
  have hОҫne : zetaSys p n вү  0 :=
    (zetaSys_primitiveRoot p n).ne_zero (pow_pos hp.out.pos n).ne'
  set Оҫ : в„Ӯ_[p]ЛЈ := Units.mk0 (zetaSys p n) hОҫne with hОҫ
  set nОҫ : в„Ӯ_[p]ЛЈ := Units.mk0 (-zetaSys p n) (neg_ne_zero.mpr hОҫne) with hnОҫ
  have hОҫmem : Оҫ вҲҲ cycloGenSet p n := Or.inl (by rw [hОҫ, Units.val_mk0])
  have hnОҫmem : nОҫ вҲҲ cycloGenSet p n := Or.inr (Or.inl (by rw [hnОҫ, Units.val_mk0]))
  have hxword : x = nОҫ * ОҫвҒ»В№ := by
    refine Units.ext ?_
    rw [hx, Units.val_mul, Units.val_inv_eq_inv_val, hnОҫ, hОҫ, Units.val_mk0, Units.val_mk0,
      neg_mul, mul_inv_cancelвӮҖ hОҫne]
  rw [hxword]
  exact mul_mem (Subgroup.subset_closure hnОҫmem)
    (Subgroup.inv_mem _ (Subgroup.subset_closure hОҫmem))

/-- `Оҫ_n^k вҲ’ 1 вҲҲ closure(cycloGenSet n)` for *any* `k : в„•` (reduce `k mod p^n`; if
`вүЎ 0` it is `0 = 1 вҲ’ 1`вҖҰ excluded since `Оҫ_n^k вҲ’ 1` is a unit only when `k вүў 0`, but we
state it for the unit `x` with that value, so `k вүў 0 mod p^n`). -/
private theorem zetaSys_pow_sub_one_mem_closure_cycloGenSet {n : в„•} (hn : 1 вүӨ n) (k : в„•)
    (hk : В¬ p ^ n вҲЈ k) :
    вҲҖ x : в„Ӯ_[p]ЛЈ, (x : в„Ӯ_[p]) = zetaSys p n ^ k - 1 вҶ’ x вҲҲ Subgroup.closure (cycloGenSet p n) := by
  intro x hx
  have hpn1 : 1 < p ^ n := one_lt_powвӮҖ hp.out.one_lt (by omega)
  have hmod_pos : 1 вүӨ k % p ^ n := by
    rcases Nat.eq_zero_or_pos (k % p ^ n) with h0 | h0
    В· exact absurd (Nat.dvd_of_mod_eq_zero h0) hk
    В· exact h0
  have hmodlt : k % p ^ n < p ^ n := Nat.mod_lt _ (by positivity)
  have hred : zetaSys p n ^ k = zetaSys p n ^ (k % p ^ n) :=
    zetaSys_pow_eq_pow_of_modEq p (Nat.mod_modEq k (p ^ n)).symm
  have hne : zetaSys p n ^ (k % p ^ n) - 1 вү  0 := by
    refine sub_ne_zero_of_ne fun h => ?_
    have := (zetaSys_primitiveRoot p n).pow_eq_one_iff_dvd _ |>.mp h
    exact absurd (Nat.eq_zero_of_dvd_of_lt this hmodlt) (by omega)
  have hmem : x вҲҲ cycloGenSet p n :=
    Or.inr (Or.inr вҹЁk % p ^ n, hmod_pos, by omega, by rw [hx, hred]вҹ©)
  exact Subgroup.subset_closure hmem

/-- Any power `Оҫ_n^k` is the value of an element of `closure(cycloGenSet n)`: `Оҫ_n` is a
generator, so `Оҫ_n^k = Оҫ_n^k` is in the closure (a unit since `Оҫ_n вү  0`). -/
private theorem zetaSys_pow_mem_closure_cycloGenSet {n : в„•} (k : в„•) :
    вҲғ w : в„Ӯ_[p]ЛЈ, w вҲҲ Subgroup.closure (cycloGenSet p n) вҲ§ (w : в„Ӯ_[p]) = zetaSys p n ^ k := by
  have hОҫne : zetaSys p n вү  0 :=
    (zetaSys_primitiveRoot p n).ne_zero (pow_pos hp.out.pos n).ne'
  set Оҫ : в„Ӯ_[p]ЛЈ := Units.mk0 (zetaSys p n) hОҫne with hОҫ
  have hОҫmem : Оҫ вҲҲ Subgroup.closure (cycloGenSet p n) :=
    Subgroup.subset_closure (Or.inl (by rw [hОҫ, Units.val_mk0]))
  exact вҹЁОҫ ^ k, pow_mem hОҫmem k, by rw [hОҫ]; push_cast; rw [Units.val_mk0]вҹ©

/-- Every unit in `closure(cycloGenSet n)` has value in `K_n`: the generators `ВұОҫ_n, Оҫ_n^bвҲ’1`
all lie in `K_n` (a field), closed under products/inverses. -/
private theorem mem_K_of_mem_closure_cycloGenSet {n : в„•} {v : в„Ӯ_[p]ЛЈ}
    (hv : v вҲҲ Subgroup.closure (cycloGenSet p n)) : (v : в„Ӯ_[p]) вҲҲ K p n := by
  induction hv using Subgroup.closure_induction with
  | mem z hz =>
      rcases hz with hОҫ | hОҫ | вҹЁb, _, _, hbvвҹ©
      В· rw [hОҫ]; exact zetaSys_mem_K p n
      В· rw [hОҫ]; exact neg_mem (zetaSys_mem_K p n)
      В· rw [hbv]; exact sub_mem (pow_mem (zetaSys_mem_K p n) b) (one_mem _)
  | one => rw [Units.val_one]; exact one_mem _
  | mul zвӮҒ zвӮӮ _ _ ihвӮҒ ihвӮӮ => rw [Units.val_mul]; exact mul_mem ihвӮҒ ihвӮӮ
  | inv z _ ih => rw [Units.val_inv_eq_inv_val]; exact (K p n).inv_mem ih

open scoped Classical in
/-- The total `Пғ_a`-on-values map: `galAut a n` on `K_n`, identity elsewhere. Decouples the
`K_n`-membership proof from the closure-induction variable (so the conclusion of
`galAut_mem_closure_cycloGenSet` is proof-irrelevant). -/
private noncomputable def galAutVal (a : в„Ө_[p]ЛЈ) (n : в„•) (x : в„Ӯ_[p]) : в„Ӯ_[p] :=
  if h : x вҲҲ K p n then (galAut p a n вҹЁx, hвҹ© : в„Ӯ_[p]) else x

private theorem galAutVal_mem (a : в„Ө_[p]ЛЈ) {n : в„•} {x : в„Ӯ_[p]} (h : x вҲҲ K p n) :
    galAutVal p a n x = (galAut p a n вҹЁx, hвҹ© : в„Ӯ_[p]) := by
  rw [galAutVal, dif_pos h]

/-- `galAutVal` is multiplicative on `K_n`: `Пғ_a(xy) = Пғ_a x В· Пғ_a y`. -/
private theorem galAutVal_mul (a : в„Ө_[p]ЛЈ) {n : в„•} {x y : в„Ӯ_[p]} (hx : x вҲҲ K p n)
    (hy : y вҲҲ K p n) : galAutVal p a n (x * y) = galAutVal p a n x * galAutVal p a n y := by
  rw [galAutVal_mem p a (mul_mem hx hy), galAutVal_mem p a hx, galAutVal_mem p a hy,
    show (вҹЁx * y, mul_mem hx hyвҹ© : K p n) = вҹЁx, hxвҹ© * вҹЁy, hyвҹ© from Subtype.ext rfl,
    map_mul, IntermediateField.coe_mul]

/-- `galAutVal` of an inverse: `Пғ_a(xвҒ»В№) = (Пғ_a x)вҒ»В№`. -/
private theorem galAutVal_inv (a : в„Ө_[p]ЛЈ) {n : в„•} {x : в„Ӯ_[p]} (hx : x вҲҲ K p n) :
    galAutVal p a n xвҒ»В№ = (galAutVal p a n x)вҒ»В№ := by
  rw [galAutVal_mem p a ((K p n).inv_mem hx), galAutVal_mem p a hx,
    show (вҹЁxвҒ»В№, (K p n).inv_mem hxвҹ© : K p n) = (вҹЁx, hxвҹ©)вҒ»В№ from
      Subtype.ext (by rw [IntermediateField.coe_inv]), map_invвӮҖ, IntermediateField.coe_inv]

/-- `galAutVal(Оҫ_n^k) = Оҫ_n^{tВ·k}` with `t = (a mod p^n).val` (`galAut_zetaSys_pow`). -/
private theorem galAutVal_zetaSys_pow (a : в„Ө_[p]ЛЈ) {n : в„•} (hn : 1 вүӨ n) (k : в„•) :
    galAutVal p a n (zetaSys p n ^ k)
      = zetaSys p n ^ (((PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ) :
          ZMod (p ^ n)).val * k) := by
  rw [galAutVal_mem p a (pow_mem (zetaSys_mem_K p n) k), galAut_zetaSys_pow p a hn k]

/-- `galAutVal(вҲ’1) = вҲ’1` (`Пғ_a` fixes `в„ҡ`). -/
private theorem galAutVal_neg_one (a : в„Ө_[p]ЛЈ) {n : в„•} :
    galAutVal p a n (-1) = -1 := by
  rw [galAutVal_mem p a (neg_mem (one_mem _)),
    show (вҹЁ(-1 : в„Ӯ_[p]), neg_mem (one_mem _)вҹ© : K p n) = -1 from
      Subtype.ext (by push_cast; ring),
    map_neg, map_one, IntermediateField.coe_neg, IntermediateField.coe_one]

/-- `galAutVal` is additive on `K_n`: `Пғ_a(x+y) = Пғ_a x + Пғ_a y`. -/
private theorem galAutVal_add (a : в„Ө_[p]ЛЈ) {n : в„•} {x y : в„Ӯ_[p]} (hx : x вҲҲ K p n)
    (hy : y вҲҲ K p n) : galAutVal p a n (x + y) = galAutVal p a n x + galAutVal p a n y := by
  rw [galAutVal_mem p a (add_mem hx hy), galAutVal_mem p a hx, galAutVal_mem p a hy,
    show (вҹЁx + y, add_mem hx hyвҹ© : K p n) = вҹЁx, hxвҹ© + вҹЁy, hyвҹ© from Subtype.ext rfl,
    map_add, IntermediateField.coe_add]

/-- **The closed-form `Пғ_a`-action on the cyclotomic units** (RJW В§12.4, sub-step of
`cor:cyc units gen 2`, TeX 3484): with `t = (a mod p^n).val` the cyclotomic-character value,
`Пғ_a(c_n(b)) = (Оҫ^{tВ·b} вҲ’ 1)/(Оҫ^t вҲ’ 1)`. This is the field-automorphism image of
`c_n(b) = (Оҫ^b вҲ’ 1)/(Оҫ вҲ’ 1)` under `Пғ_a(Оҫ) = Оҫ^t` (`galAutVal_zetaSys_pow`), multiplicativity
(`galAutVal_mul`/`galAutVal_inv`/`galAutVal_add`) and `Пғ_a(вҲ’1) = вҲ’1`. -/
private theorem galAutVal_cycloUnit (a : в„Ө_[p]ЛЈ) {n : в„•} (hn : 1 вүӨ n) (b : в„•) :
    galAutVal p a n (cycloUnit p b n)
      = (zetaSys p n ^ (((PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ) :
          ZMod (p ^ n)).val * b) - 1)
        / (zetaSys p n ^ ((PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ) :
          ZMod (p ^ n)).val - 1) := by
  have hОҫ : zetaSys p n вҲҲ K p n := zetaSys_mem_K p n
  rw [cycloUnit, div_eq_mul_inv, galAutVal_mul p a (sub_mem (pow_mem hОҫ b) (one_mem _))
      ((K p n).inv_mem (sub_mem hОҫ (one_mem _))),
    galAutVal_inv p a (sub_mem hОҫ (one_mem _)), вҶҗ div_eq_mul_inv]
  congr 1
  В· rw [show zetaSys p n ^ b - 1 = zetaSys p n ^ b + (-1) from by ring,
      galAutVal_add p a (pow_mem hОҫ b) (neg_mem (one_mem _)),
      galAutVal_zetaSys_pow p a hn b, galAutVal_neg_one p a]
    ring
  В· rw [show zetaSys p n - 1 = zetaSys p n ^ 1 + (-1) from by rw [pow_one]; ring,
      galAutVal_add p a (pow_mem hОҫ 1) (neg_mem (one_mem _)),
      galAutVal_zetaSys_pow p a hn 1, galAutVal_neg_one p a, mul_one]
    ring

/-- A telescoping product over a field: `вҲҸ_{i<r} e(i+1)/e(i) = e r / e 0`. -/
private theorem prod_range_div_telescope {F : Type*} [Field F] (e : в„• вҶ’ F)
    (he : вҲҖ i, e i вү  0) (r : в„•) :
    вҲҸ i вҲҲ Finset.range r, (e (i + 1) / e i) = e r / e 0 := by
  induction r with
  | zero => rw [Finset.range_zero, Finset.prod_empty, div_self (he 0)]
  | succ m ih =>
    rw [Finset.prod_range_succ, ih, div_mul_div_comm,
      mul_comm (e m) (e (m + 1)), mul_div_mul_right _ _ (he m)]

/-- The `Пғ_{a^i}`-character exponent `t_i = (a^i mod p^n).val` (a power of `t = (a mod p^n)`).
`Оҫ^{t_i}` is the cyclotomic image of `c_n`'s `Оҫ` under the `i`-fold `Пғ_a`. -/
private def charExp (a : в„Ө_[p]ЛЈ) (n i : в„•) : в„• :=
  ((PadicMeasure.unitsToZModPow p n (a ^ i) : (ZMod (p ^ n))ЛЈ) : ZMod (p ^ n)).val

/-- `(charExp i : ZMod (p^n)) = (a mod p^n)^i` (`unitsToZModPow` a `MonoidHom`, `map_pow`). -/
private theorem charExp_cast (a : в„Ө_[p]ЛЈ) {n : в„•} (i : в„•) :
    ((charExp p a n i : в„•) : ZMod (p ^ n))
      = ((PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ) : ZMod (p ^ n)) ^ i := by
  rw [charExp, ZMod.natCast_val, ZMod.cast_id, вҶҗ Units.val_pow_eq_pow_val, вҶҗ map_pow]

/-- `Оҫ^{charExp(i)} вҲ’ 1 вү  0` (`a^i mod p^n` is a unit, so `вүў 0`, and `Оҫ` has order `p^n`). -/
private theorem zetaSys_pow_charExp_sub_one_ne_zero (a : в„Ө_[p]ЛЈ) {n : в„•} (hn : 1 вүӨ n) (i : в„•) :
    zetaSys p n ^ charExp p a n i - 1 вү  0 := by
  haveI : Fact (1 < p ^ n) := вҹЁone_lt_powвӮҖ hp.out.one_lt (by omega)вҹ©
  refine sub_ne_zero_of_ne fun h => ?_
  -- `p^n вҲЈ charExp i` вҹ№ `(charExp i : ZMod (p^n)) = 0`, but it is the value of a unit
  have hz : ((charExp p a n i : в„•) : ZMod (p ^ n)) = 0 := by
    rw [ZMod.natCast_eq_zero_iff]; exact (zetaSys_primitiveRoot p n).pow_eq_one_iff_dvd _ |>.mp h
  rw [charExp, ZMod.natCast_val, ZMod.cast_id] at hz
  exact (PadicMeasure.unitsToZModPow p n (a ^ i)).ne_zero hz

/-- **The telescoping generation** (RJW `cor:cyc units gen 2`, TeX 3484вҖ“3486, sub-step (b)):
for `b вүЎ a (mod p^n)`, the product of the `Пғ_{a^i}`-translates of `c_n(b)` over `i < r`
telescopes to `c_n(b^r mod p^n)`:
`вҲҸ_{i<r} Пғ_{a^i}(c_n(b)) = (Оҫ^{(b^r mod p^n)} вҲ’ 1)/(Оҫ вҲ’ 1)`.
Each factor `Пғ_{a^i}(c_n(b)) = (Оҫ^{t_iВ·b} вҲ’ 1)/(Оҫ^{t_i} вҲ’ 1)` (`galAutVal_cycloUnit`); with
`b вүЎ a` the exponents satisfy `t_iВ·b вүЎ a^{i+1} вүЎ t_{i+1} (mod p^n)`, so the factor is
`(Оҫ^{t_{i+1}} вҲ’ 1)/(Оҫ^{t_i} вҲ’ 1)`, and the product telescopes (`prod_range_div_telescope`)
to `(Оҫ^{t_r} вҲ’ 1)/(Оҫ^{t_0} вҲ’ 1)` with `t_0 = 1`, `Оҫ^{t_r} = Оҫ^{b^r}`. -/
private theorem prod_galAutVal_cycloUnit_telescope (a : в„Ө_[p]ЛЈ) {n : в„•} (hn : 1 вүӨ n)
    {b : в„•} (hb : ((b : ZMod (p ^ n))) = (PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ))
    (r : в„•) :
    вҲҸ i вҲҲ Finset.range r, galAutVal p (a ^ i) n (cycloUnit p b n)
      = (zetaSys p n ^ (((b : ZMod (p ^ n)) ^ r).val) - 1) / (zetaSys p n - 1) := by
  -- per-factor: `Пғ_{a^i}(c_n(b)) = (Оҫ^{charExp(i+1)} вҲ’ 1)/(Оҫ^{charExp i} вҲ’ 1)`
  have hnum : вҲҖ i, zetaSys p n ^ (charExp p a n i * b) = zetaSys p n ^ charExp p a n (i + 1) := by
    intro i
    refine zetaSys_pow_eq_pow_of_modEq p ?_
    rw [вҶҗ ZMod.natCast_eq_natCast_iff, Nat.cast_mul, charExp_cast, charExp_cast, hb, pow_succ]
  have hfac : вҲҖ i, galAutVal p (a ^ i) n (cycloUnit p b n)
      = (zetaSys p n ^ charExp p a n (i + 1) - 1) / (zetaSys p n ^ charExp p a n i - 1) := by
    intro i
    rw [galAutVal_cycloUnit p (a ^ i) hn b, вҶҗ hnum i]
    rfl
  rw [Finset.prod_congr rfl fun i _ => hfac i]
  -- telescope with `e i = Оҫ^{charExp i} вҲ’ 1`
  rw [prod_range_div_telescope (fun i => zetaSys p n ^ charExp p a n i - 1)
    (fun i => zetaSys_pow_charExp_sub_one_ne_zero p a hn i) r]
  -- `Оҫ^{charExp r} = Оҫ^{(b^r mod).val}` and `Оҫ^{charExp 0} вҲ’ 1 = Оҫ вҲ’ 1`
  have hr : zetaSys p n ^ charExp p a n r = zetaSys p n ^ ((b : ZMod (p ^ n)) ^ r).val := by
    refine zetaSys_pow_eq_pow_of_modEq p ?_
    rw [вҶҗ ZMod.natCast_eq_natCast_iff, charExp_cast, hb, ZMod.natCast_val, ZMod.cast_id]
  have h0 : zetaSys p n ^ charExp p a n 0 = zetaSys p n := by
    have h := charExp_cast p a (n := n) 0
    rw [pow_zero] at h
    refine (zetaSys_pow_eq_pow_of_modEq (i := charExp p a n 0) (j := 1) p ?_).trans (pow_one _)
    rw [вҶҗ ZMod.natCast_eq_natCast_iff, h, Nat.cast_one]
  rw [hr, h0]

/-- **`Пғ_a` maps `closure(cycloGenSet n)` into itself**: for any unit `v вҲҲ closure(cycloGenSet
n)`, there is `w вҲҲ closure(cycloGenSet n)` with value `galAutVal a n v` (`= Пғ_a v` since `v`'s
value is in `K_n`). Induction over `Subgroup.closure_induction`: `Пғ_a(Оҫ_n) = Оҫ_n^t`,
`Пғ_a(вҲ’Оҫ_n) = вҲ’(Оҫ_n^t)`, `Пғ_a(Оҫ_n^bвҲ’1) = Оҫ_n^{tb}вҲ’1` are cyclotomic words (`galAut_zetaSys_pow`,
`zetaSys_pow_mem_closure_cycloGenSet`, `neg_one_mem_closure_cycloGenSet`,
`zetaSys_pow_sub_one_mem_closure_cycloGenSet`); `Пғ_a` multiplicative closes the steps. -/
private theorem galAut_mem_closure_cycloGenSet (a : в„Ө_[p]ЛЈ) {n : в„•} (hn : 1 вүӨ n)
    {v : в„Ӯ_[p]ЛЈ} (hv : v вҲҲ Subgroup.closure (cycloGenSet p n)) :
    вҲғ w : в„Ӯ_[p]ЛЈ, w вҲҲ Subgroup.closure (cycloGenSet p n) вҲ§
      (w : в„Ӯ_[p]) = galAutVal p a n (v : в„Ӯ_[p]) := by
  -- `t = (a mod p^n).val`
  have ht_dvd : вҲҖ b : в„•, 1 вүӨ b вҶ’ b вүӨ p ^ n - 1 вҶ’
      В¬ p ^ n вҲЈ ((PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ) :
        ZMod (p ^ n)).val * b := by
    intro b hb1 hb2 hdvd
    have hpn1 : 1 < p ^ n := one_lt_powвӮҖ hp.out.one_lt (by omega)
    have htb : (((((PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ) :
        ZMod (p ^ n)).val * b : в„•)) : ZMod (p ^ n)) = 0 := by
      rw [ZMod.natCast_eq_zero_iff]; exact hdvd
    rw [Nat.cast_mul, ZMod.natCast_val, ZMod.cast_id] at htb
    have hbz : ((b : в„•) : ZMod (p ^ n)) = 0 :=
      (Units.mul_right_eq_zero (PadicMeasure.unitsToZModPow p n a)).1 htb
    rw [ZMod.natCast_eq_zero_iff] at hbz
    exact absurd (Nat.eq_zero_of_dvd_of_lt hbz (by omega)) (by omega)
  induction hv using Subgroup.closure_induction with
  | mem z hz =>
      rcases hz with hОҫ | hОҫ | вҹЁb, hb1, hb2, hbvвҹ©
      В· -- `z = Оҫ_n`: `Пғ_a Оҫ_n = Оҫ_n^t`
        obtain вҹЁw, hwmem, hwvalвҹ© := zetaSys_pow_mem_closure_cycloGenSet p (n := n)
          ((PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ) : ZMod (p ^ n)).val
        refine вҹЁw, hwmem, ?_вҹ©
        have := galAutVal_zetaSys_pow p a hn 1
        rw [pow_one, mul_one] at this
        rw [hwval, hОҫ, this]
      В· -- `z = вҲ’Оҫ_n`: `Пғ_a(вҲ’Оҫ_n) = вҲ’(Оҫ_n^t)`
        obtain вҹЁw, hwmem, hwvalвҹ© := zetaSys_pow_mem_closure_cycloGenSet p (n := n)
          ((PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ) : ZMod (p ^ n)).val
        obtain вҹЁw', hw'mem, hw'valвҹ© : вҲғ w' : в„Ӯ_[p]ЛЈ,
            w' вҲҲ Subgroup.closure (cycloGenSet p n) вҲ§ (w' : в„Ӯ_[p]) = -1 :=
          вҹЁ-1, neg_one_mem_closure_cycloGenSet p hn _ rfl, by rw [Units.val_neg, Units.val_one]вҹ©
        refine вҹЁw' * w, mul_mem hw'mem hwmem, ?_вҹ©
        have hgt := galAutVal_zetaSys_pow p a hn 1
        rw [pow_one, mul_one] at hgt
        rw [Units.val_mul, hw'val, hwval, hОҫ,
          show -zetaSys p n = (-1) * zetaSys p n from by rw [neg_one_mul],
          galAutVal_mul p a (neg_mem (one_mem _)) (zetaSys_mem_K p n),
          galAutVal_neg_one p a, hgt, neg_one_mul]
      В· -- `z = Оҫ_n^b вҲ’ 1` with `1 вүӨ b вүӨ p^n вҲ’ 1`: `Пғ_a z = Оҫ_n^{tb} вҲ’ 1`
        have hbne := ht_dvd b hb1 hb2
        have hzbne : zetaSys p n
            ^ (((PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ) :
              ZMod (p ^ n)).val * b) - 1 вү  0 := by
          refine sub_ne_zero_of_ne fun h => ?_
          exact hbne ((zetaSys_primitiveRoot p n).pow_eq_one_iff_dvd _ |>.mp h)
        refine вҹЁUnits.mk0 _ hzbne, zetaSys_pow_sub_one_mem_closure_cycloGenSet p hn
          (((PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ) : ZMod (p ^ n)).val * b)
          hbne (Units.mk0 _ hzbne) (by rw [Units.val_mk0]), ?_вҹ©
        have hgb := galAut_zetaSys_pow p a hn b
        rw [Units.val_mk0, hbv,
          galAutVal_mem p a (sub_mem (pow_mem (zetaSys_mem_K p n) b) (one_mem _)),
          show (вҹЁzetaSys p n ^ b - 1,
              sub_mem (pow_mem (zetaSys_mem_K p n) b) (one_mem _)вҹ© : K p n)
              = вҹЁzetaSys p n ^ b, pow_mem (zetaSys_mem_K p n) bвҹ© - 1 from
            Subtype.ext (by rw [AddSubgroupClass.coe_sub]; rfl), map_sub,
          AddSubgroupClass.coe_sub, hgb, map_one, IntermediateField.coe_one]
  | one =>
      refine вҹЁ1, one_mem _, ?_вҹ©
      have := galAutVal_zetaSys_pow p a hn 0
      rw [pow_zero, Nat.mul_zero, pow_zero] at this
      rw [Units.val_one, this]
  | mul zвӮҒ zвӮӮ hzвӮҒ hzвӮӮ ihвӮҒ ihвӮӮ =>
      obtain вҹЁwвӮҒ, hwвӮҒmem, hwвӮҒvalвҹ© := ihвӮҒ
      obtain вҹЁwвӮӮ, hwвӮӮmem, hwвӮӮvalвҹ© := ihвӮӮ
      have h1 : (zвӮҒ : в„Ӯ_[p]) вҲҲ K p n := mem_K_of_mem_closure_cycloGenSet p hzвӮҒ
      have h2 : (zвӮӮ : в„Ӯ_[p]) вҲҲ K p n := mem_K_of_mem_closure_cycloGenSet p hzвӮӮ
      refine вҹЁwвӮҒ * wвӮӮ, mul_mem hwвӮҒmem hwвӮӮmem, ?_вҹ©
      rw [Units.val_mul, hwвӮҒval, hwвӮӮval, вҶҗ galAutVal_mul p a h1 h2, вҶҗ Units.val_mul]
  | inv z hz ih =>
      obtain вҹЁw, hwmem, hwvalвҹ© := ih
      have hzK : (z : в„Ӯ_[p]) вҲҲ K p n := mem_K_of_mem_closure_cycloGenSet p hz
      refine вҹЁwвҒ»В№, Subgroup.inv_mem _ hwmem, ?_вҹ©
      rw [Units.val_inv_eq_inv_val, hwval, вҶҗ galAutVal_inv p a hzK, вҶҗ Units.val_inv_eq_inv_val]

open scoped Classical in
/-- The units-level total `Пғ_a` map: `galAutUnit a` on `K_n`-valued units, identity elsewhere
(the unit version of `galAutVal`). -/
noncomputable def galAutValU (a : в„Ө_[p]ЛЈ) (n : в„•) (v : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]ЛЈ :=
  if h : (v : в„Ӯ_[p]) вҲҲ K p n then galAutUnit p a v h else v

private theorem galAutValU_val_mem (a : в„Ө_[p]ЛЈ) {n : в„•} {v : в„Ӯ_[p]ЛЈ}
    (h : (v : в„Ӯ_[p]) вҲҲ K p n) :
    (galAutValU p a n v : в„Ӯ_[p]) = galAutVal p a n (v : в„Ӯ_[p]) := by
  rw [galAutValU, dif_pos h, galAutUnit_val, galAutVal_mem p a h]

/-- The cyclotomic unit `c_n(b)` of `K_n` packaged as a unit of `в„Ӯ_[p]ЛЈ` (`n вүҘ 1`,
`p вҲӨ b`). -/
private noncomputable def cycloUnitU {b : в„•} (hb : В¬ (p : в„•) вҲЈ b) {n : в„•} (hn : 1 вүӨ n) :
    в„Ӯ_[p]ЛЈ :=
  Units.mk0 (cycloUnit p b n) (cycloUnit_ne_zero p hb hn)

private theorem cycloUnitU_val {b : в„•} (hb : В¬ (p : в„•) вҲЈ b) {n : в„•} (hn : 1 вүӨ n) :
    (cycloUnitU p hb hn : в„Ӯ_[p]) = cycloUnit p b n := Units.val_mk0 _

/-- **`cor:cyc units gen 2` вҖ” the units-level telescoping** (RJW TeX 3484вҖ“3486): the product
of the `Пғ_{a^i}`-translate *units* `galAutValU (a^i) (c_n(b))` over `i < r` equals the
cyclotomic unit `c_n(b')` for any `b'` with `b' вүЎ b^r (mod p^n)` (and `p вҲӨ b'`). This is the
units-level realisation of `prod_galAutVal_cycloUnit_telescope` (the value-level telescope),
exhibiting `c_n(b')` as a single product of `Пғ`-translates of the *single* generator
`c_n(b)`. -/
private theorem prod_galAutValU_cycloUnit_telescope (a : в„Ө_[p]ЛЈ) {n : в„•} (hn : 1 вүӨ n)
    {b : в„•} (hb0 : В¬ (p : в„•) вҲЈ b)
    (hb : ((b : ZMod (p ^ n))) = (PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ)) (r : в„•)
    {b' : в„•} (hb' : В¬ (p : в„•) вҲЈ b') (hbb' : ((b' : ZMod (p ^ n))) = (b : ZMod (p ^ n)) ^ r) :
    вҲҸ i вҲҲ Finset.range r, galAutValU p (a ^ i) n (cycloUnitU p hb0 hn)
      = cycloUnitU p hb' hn := by
  refine Units.ext ?_
  rw [cycloUnitU_val]
  -- the product of units coerces to the product of values
  have hcoe : ((вҲҸ i вҲҲ Finset.range r, galAutValU p (a ^ i) n (cycloUnitU p hb0 hn) : в„Ӯ_[p]ЛЈ)
      : в„Ӯ_[p])
      = вҲҸ i вҲҲ Finset.range r, galAutVal p (a ^ i) n (cycloUnit p b n) := by
    rw [Units.coe_prod]
    refine Finset.prod_congr rfl fun i _ => ?_
    have hmemK : (cycloUnitU p hb0 hn : в„Ӯ_[p]) вҲҲ K p n := by
      rw [cycloUnitU_val]; exact cycloUnit_mem_K p b hn
    rw [galAutValU_val_mem p (a ^ i) hmemK, cycloUnitU_val]
  rw [hcoe, prod_galAutVal_cycloUnit_telescope p a hn hb r, cycloUnit]
  congr 2
  refine zetaSys_pow_eq_pow_of_modEq p ?_
  rw [вҶҗ ZMod.natCast_eq_natCast_iff, ZMod.natCast_val, ZMod.cast_id, hbb']

/-- `galAutValU a` maps `cycloUnits n` into `cycloUnits n` (`closure(cycloGenSet)`-preservation
`galAut_mem_closure_cycloGenSet` + `globalUnits`-preservation `galAut_mem_Fglobal`/
`galAut_isIntegral`). -/
private theorem galAutValU_mem_cycloUnits (a : в„Ө_[p]ЛЈ) {n : в„•} (hn : 1 вүӨ n) {v : в„Ӯ_[p]ЛЈ}
    (hv : v вҲҲ cycloUnits p n) : galAutValU p a n v вҲҲ cycloUnits p n := by
  rw [cycloUnits, Subgroup.mem_inf] at hv вҠў
  obtain вҹЁhvclos, hvF, hvint, hvintinvвҹ© := hv
  have hvK : (v : в„Ӯ_[p]) вҲҲ K p n := mem_K_of_mem_closure_cycloGenSet p hvclos
  refine вҹЁ?_, ?_, ?_, ?_вҹ©
  В· -- closure of `cycloGenSet` preserved
    obtain вҹЁw, hwmem, hwvalвҹ© := galAut_mem_closure_cycloGenSet p a hn hvclos
    rwa [show galAutValU p a n v = w from
      Units.ext (by rw [hwval, galAutValU_val_mem p a hvK])]
  В· rw [galAutValU_val_mem p a hvK, galAutVal_mem p a hvK]
    exact galAut_mem_Fglobal p a hn hvF hvK
  В· rw [galAutValU_val_mem p a hvK, galAutVal_mem p a hvK]
    exact galAut_isIntegral p a hvK hvint
  В· -- `((Пғ_a v)вҒ»В№).val = Пғ_a(вҶ‘vвҒ»В№)`, integral as `Пғ_a` of the integral `вҶ‘vвҒ»В№`
    have hinveq : (((galAutValU p a n v)вҒ»В№ : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p])
        = galAutVal p a n ((v : в„Ӯ_[p])вҒ»В№) := by
      rw [Units.val_inv_eq_inv_val, galAutValU_val_mem p a hvK, вҶҗ galAutVal_inv p a hvK]
    rw [hinveq, galAutVal_mem p a ((K p n).inv_mem hvK)]
    have : ((vвҒ»В№ : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]) = (v : в„Ӯ_[p])вҒ»В№ := Units.val_inv_eq_inv_val v
    exact galAut_isIntegral p a ((K p n).inv_mem hvK) (this в–ё hvintinv)

/-- The `в„Ө[рқ’ў_n]`-translate subgroup of a single cyclotomic generator `g = c_n(b)`: the
multiplicative subgroup of `в„Ӯ_[p]ЛЈ` generated by all Galois translates `{Пғ_c(g) : c вҲҲ в„Ө_p^Г—}`
(`galAutValU c n g`). Since `рқ’ў_n` acts through `unitsToZModPow` and `Пғ` is multiplicative, this
is exactly the `в„Ө[рқ’ў_n]`-submodule generated by `g`. -/
def cycloTranslateSubgroup (n : в„•) (g : в„Ӯ_[p]ЛЈ) : Subgroup в„Ӯ_[p]ЛЈ :=
  Subgroup.closure {h : в„Ӯ_[p]ЛЈ | вҲғ c : в„Ө_[p]ЛЈ, h = galAutValU p c n g}

/-- **`cor:cyc units gen 2` (RJW TeX 3484вҖ“3486): the level-`n` single-generator cyclicity.**
Let `a` be a unit with residue `b вүЎ a (mod p^n)` a *generator* of `(в„Ө/p^nв„Ө)^Г—` (so every
`p`-coprime residue is a power `b^r`). Then the single cyclotomic generator `c_n(b)`
`в„Ө[рқ’ў_n]`-generates every cyclotomic unit: for `b'` coprime to `p` with `b' вүЎ b^r (mod p^n)`,
the unit `c_n(b')` lies in the `рқ’ў_n`-translate subgroup of `c_n(b)`
(`cycloTranslateSubgroup`). The witness is the explicit telescoping product
`c_n(b') = вҲҸ_{i<r} Пғ_{a^i}(c_n(b))` (`prod_galAutValU_cycloUnit_telescope`), each factor a
translate `Пғ_{a^i}(c_n(b)) = galAutValU (a^i) (c_n(b))` of the single generator. This realises
RJW's statement that a single `Оі_{n,aвӮҖ}` (here its `c_n`-part) generates `рқ’ҹ_n^+` as a
`в„Ө[рқ’ў_n^+]`-module вҖ” combined with `cycloUnitsPlus_eq_closure_gammas` (`рқ’ҹ_n^+ =
closure({c_n}-generators вҲӘ {вҲ’1})`). -/
theorem cycloUnit_mem_cycloTranslateSubgroup (a : в„Ө_[p]ЛЈ) {n : в„•} (hn : 1 вүӨ n)
    {b : в„•} (hb0 : В¬ (p : в„•) вҲЈ b)
    (hb : ((b : ZMod (p ^ n))) = (PadicMeasure.unitsToZModPow p n a : (ZMod (p ^ n))ЛЈ))
    {b' : в„•} (hb' : В¬ (p : в„•) вҲЈ b') {r : в„•}
    (hbb' : ((b' : ZMod (p ^ n))) = (b : ZMod (p ^ n)) ^ r) :
    cycloUnitU p hb' hn вҲҲ cycloTranslateSubgroup p n (cycloUnitU p hb0 hn) := by
  rw [вҶҗ prod_galAutValU_cycloUnit_telescope p a hn hb0 hb r hb' hbb']
  -- the product of translates lies in the closure of the translate set
  refine prod_mem fun i _ => ?_
  exact Subgroup.subset_closure вҹЁa ^ i, rflвҹ©

/-- The level value of `galNCU a u`: `(galNCU a u).elems n = galAutValU a n (u.elems n)` (the
levelwise `Пғ_a`, packaged through the units-map; matches `galNCU_elems_val`). -/
theorem galNCU_elems_eq_galAutValU (a : в„Ө_[p]ЛЈ) (u : NormCompatUnits p) (n : в„•) :
    (galNCU p a u).elems n = galAutValU p a n (u.elems n) := by
  refine Units.ext ?_
  rw [galNCU_elems_val p a u n, galAutValU_val_mem p a (Subring.mem_inf.1 (u.mem n)).1,
    galAutVal_mem p a (Subring.mem_inf.1 (u.mem n)).1]

/-- `galNCU a` commutes with powers: `galNCU a (u^k) = (galNCU a u)^k` (`galNCU_mul`/
`galNCU_one` make `galNCU a` a monoid endomorphism). -/
private theorem galNCU_pow (a : в„Ө_[p]ЛЈ) (u : NormCompatUnits p) (k : в„•) :
    galNCU p a (u ^ k) = (galNCU p a u) ^ k := by
  induction k with
  | zero => rw [pow_zero, pow_zero, galNCU_one]
  | succ m ih => rw [pow_succ, pow_succ, galNCU_mul, ih]

/-- `galNCU a` commutes with inverses: `galNCU a uвҒ»В№ = (galNCU a u)вҒ»В№` (`Пғ_a` a group
endomorphism of the commutative group `рқ’°_вҲһ`). -/
theorem galNCU_inv (a : в„Ө_[p]ЛЈ) (u : NormCompatUnits p) :
    galNCU p a uвҒ»В№ = (galNCU p a u)вҒ»В№ :=
  eq_inv_of_mul_eq_one_left (by rw [вҶҗ galNCU_mul, inv_mul_cancel, galNCU_one])

/-- At level `0` the Galois action is trivial (`K_0 = в„ҡ_p`, `Пғ_a 0 = refl`): `galAutValU a 0 = id`. -/
private theorem galAutValU_zero (a : в„Ө_[p]ЛЈ) (v : в„Ӯ_[p]ЛЈ) : galAutValU p a 0 v = v := by
  by_cases h : (v : в„Ӯ_[p]) вҲҲ K p 0
  В· refine Units.ext ?_
    rw [galAutValU_val_mem p a h, galAutVal_mem p a h,
      show galAut p a 0 = AlgEquiv.refl from by rw [galAut, dif_neg (by omega)]]
    rfl
  В· rw [galAutValU, dif_neg h]

/-- **(H2) `Пғ_{-1}` is an involution on `рқ’°_вҲһ`** (complex conjugation has order 2, `p` odd):
`galNCU (-1)` applied twice is the identity. Levelwise: `galAut (-1) n` has order `2` for `n вүҘ 1`
(`orderOf_galAut_neg_one`), and is `refl` at level `0`. -/
theorem galNCU_neg_one_involutive (hp2 : p вү  2) (u : NormCompatUnits p) :
    galNCU p (-1) (galNCU p (-1) u) = u := by
  refine NormCompatUnits.ext (funext fun n => Units.ext ?_)
  rw [galNCU_elems_eq_galAutValU, galNCU_elems_eq_galAutValU]
  rcases Nat.eq_zero_or_pos n with rfl | hn
  В· rw [galAutValU_zero, galAutValU_zero]
  В· have hmem : (u.elems n : в„Ӯ_[p]) вҲҲ K p n := (Subring.mem_inf.1 (u.mem n)).1
    have hinnerK : (galAutValU p (-1) n (u.elems n) : в„Ӯ_[p]) вҲҲ K p n := by
      rw [galAutValU_val_mem p (-1) hmem, galAutVal_mem p (-1) hmem]; exact SetLike.coe_mem _
    rw [galAutValU_val_mem p (-1) hinnerK, galAutValU_val_mem p (-1) hmem,
      galAutVal_mem p (-1) hmem, galAutVal_mem p (-1) (SetLike.coe_mem _)]
    have h2 : galAut p (-1) n * galAut p (-1) n = 1 := by
      have h := pow_orderOf_eq_one (galAut p (-1) n)
      rwa [orderOf_galAut_neg_one p hp2 hn, sq] at h
    rw [show (вҹЁ(galAut p (-1) n вҹЁ(u.elems n : в„Ӯ_[p]), hmemвҹ© : в„Ӯ_[p]), SetLike.coe_mem _вҹ© : K p n)
        = galAut p (-1) n вҹЁ(u.elems n : в„Ӯ_[p]), hmemвҹ© from Subtype.ext rfl,
      вҶҗ AlgEquiv.mul_apply, h2, AlgEquiv.one_apply]

/-- **(H3) `Пғ_{-1}`-fixed principal units are totally real**: a norm-compatible system `w` in
`рқ’°_{вҲһ,1}` fixed by complex conjugation lies in `рқ’°вҒә_{вҲһ,1}` (`mem_localUnitsOnePlus_iff_galAut_fixed`
levelwise). Used for `uВ·Пғ_{-1}(u) вҲҲ рқ’һвҒә_{вҲһ,1}` in the col_mem split. -/
theorem galNCU_neg_one_fixed_mem_unitsTower1Plus (hp2 : p вү  2) {w : NormCompatUnits p}
    (hw : w вҲҲ unitsTower1 p) (hfix : galNCU p (-1) w = w) : w вҲҲ unitsTower1Plus p := fun n hn => by
  have hone : w.elems n вҲҲ localUnitsOne p n := hw n hn
  have hmem : (w.elems n : в„Ӯ_[p]) вҲҲ K p n := (Subring.mem_inf.1 hone.1.1).1
  rw [mem_localUnitsOnePlus_iff_galAut_fixed p hp2 hn hone]
  have he : galAutValU p (-1) n (w.elems n) = w.elems n := by
    have h := congrFun (congrArg NormCompatUnits.elems hfix) n
    rwa [galNCU_elems_eq_galAutValU] at h
  have hev := congrArg (fun x : в„Ӯ_[p]ЛЈ => (x : в„Ӯ_[p])) he
  rwa [galAutValU_val_mem p (-1) hmem, galAutVal_mem p (-1) hmem] at hev

/-- **(H1) `Пғ_{-1}` preserves the cyclotomic tower** `рқ’һ_{вҲһ,1}`: the Galois action permutes the
cyclotomic units (`galAutValU_mem_cycloUnits`), preserves the local units (`galAut_mem_O`) and the
principal units (`Пғ` is an isometry, `norm_galAut`), and is continuous, so it preserves the p-adic
closure `cycloClosureOne` levelwise. -/
theorem galNCU_neg_one_mem_cycloTower1 {u : NormCompatUnits p} (hu : u вҲҲ cycloTower1 p) :
    galNCU p (-1) u вҲҲ cycloTower1 p := by
  sorry

/-! ## The TeichmГјller-corrected cyclotomic generator `wОі(aвӮҖ)` (RJW LemmaGeneratorCinfty1)

Input (I) of `col_image_cycloTower1_eq_zetaIdeal` (Main.lean): the principal generator
`wОі(aвӮҖ) вҲҲ рқ’һ_{вҲһ,1}` with `Col(wОі(aвӮҖ)) = вҲ’zetaNum aвӮҖ`, `aвӮҖ` the canonical integer topological
generator (`exists_nat_topological_generator`, a primitive root mod `pВІ`, so `aвӮҖ вүў 1 mod p`).

The cyclotomic system `cyclo aвӮҖ` has `Col(cyclo aвӮҖ) = вҲ’zetaNum aвӮҖ` (`Col_cyclo`) but is *not*
principal (`c_n(aвӮҖ) вүЎ aвӮҖ вүў 1 mod рқ”ӯ_n`). The TeichmГјller split (`Iwasawa/ResidueField.lean`,
`normCompat_eq_teichmuller_mul_principal`) divides off the `(pвҲ’1)`-torsion residue part
`v = Пү(b)`, leaving the principal `wОі(aвӮҖ) := vвҒ»В№В·cyclo aвӮҖ`, with `wОі(aвӮҖ) вүЎ 1 mod рқ”ӯ_n` the В§11
b2-note `wВ·Оі_{n,aвӮҖ} вүЎ 1` resolved. `Col(wОі(aвӮҖ)) = Col(cyclo aвӮҖ) = вҲ’zetaNum aвӮҖ` since `Col` kills
the torsion `v` (`Col_eq_zero_of_torsion`). -/

/-- The canonical integer topological generator `aвӮҖ` of `в„Ө_p^Г—` (a primitive root mod `pВІ`,
`exists_nat_topological_generator`), as a `в„•`. -/
private def a0 (hp2 : p вү  2) : в„• := (PadicMeasure.exists_nat_topological_generator p hp2).choose

private theorem a0_not_dvd (hp2 : p вү  2) : В¬ (p : в„•) вҲЈ a0 p hp2 :=
  (PadicMeasure.exists_nat_topological_generator p hp2).choose_spec.choose_spec.1

/-- The TeichmГјller split of `cyclo aвӮҖ` (RJW В§12.1, `normCompat_eq_teichmuller_mul_principal`):
`cyclo aвӮҖ = vВ·w` with `v` `(pвҲ’1)`-torsion (the residue TeichmГјller part) and `w` principal. -/
private def splitCyclo (hp2 : p вү  2) :
    {vw : NormCompatUnits p Г— NormCompatUnits p //
      vw.2 вҲҲ unitsTower1 p вҲ§ (вҲҖ n, (vw.1.elems n) ^ (p - 1) = 1)
        вҲ§ cyclo p (a0_not_dvd p hp2) hp2 = vw.1 * vw.2} := by
  choose v w hw hv heq using
    normCompat_eq_teichmuller_mul_principal p (cyclo p (a0_not_dvd p hp2) hp2)
  exact вҹЁ(v, w), hw, hv, heqвҹ©

/-- **The TeichmГјller-corrected cyclotomic generator `wОі(aвӮҖ)`** (RJW LemmaGeneratorCinfty1,
TeX 3553): the principal part of the TeichmГјller split of `cyclo aвӮҖ`. Levelwise it is
`Пү(b)вҒ»В№В·c_n(aвӮҖ)` with `Пү(b) вҲҲ Ој_{pвҲ’1}` the residue correction making `wОі(aвӮҖ) вүЎ 1 mod рқ”ӯ_n`. -/
def wGamma (hp2 : p вү  2) : NormCompatUnits p := (splitCyclo p hp2).1.2

/-- The `(pвҲ’1)`-torsion (TeichmГјller) part `v` of the split, `cyclo aвӮҖ = vВ·wОі(aвӮҖ)`. -/
private def wGammaTeich (hp2 : p вү  2) : NormCompatUnits p := (splitCyclo p hp2).1.1

/-- **`wОі(aвӮҖ) вҲҲ рқ’°_{вҲһ,1}`** (principal): immediate from the TeichmГјller split (`wОі(aвӮҖ)` is its
principal part). This is the В§11 b2-note `wВ·Оі_{n,aвӮҖ} вүЎ 1 mod рқ”ӯ_n` resolved. -/
theorem wGamma_mem_unitsTower1 (hp2 : p вү  2) : wGamma p hp2 вҲҲ unitsTower1 p :=
  (splitCyclo p hp2).2.1

private theorem wGammaTeich_torsion (hp2 : p вү  2) :
    вҲҖ n, (wGammaTeich p hp2).elems n ^ (p - 1) = 1 := (splitCyclo p hp2).2.2.1

private theorem cyclo_eq_split (hp2 : p вү  2) :
    cyclo p (a0_not_dvd p hp2) hp2 = wGammaTeich p hp2 * wGamma p hp2 :=
  (splitCyclo p hp2).2.2.2

/-- **`Col(wОі(aвӮҖ)) = вҲ’zetaNum aвӮҖ`** (RJW; the sign of `Col_cyclo`, TeX 2614/errata #12): the
TeichmГјller part `v` of the split is `(pвҲ’1)`-torsion, hence killed by `Col`
(`Col_eq_zero_of_torsion`), so `Col(wОі(aвӮҖ)) = Col(cyclo aвӮҖ) = вҲ’zetaNum aвӮҖ` (`Col_cyclo`). This
is the generator-image identity feeding `col_image_cycloTower1_eq_zetaIdeal` (input (I)). -/
theorem Col_wGamma (hp2 : p вү  2) :
    Col p (wGamma p hp2) = -PadicMeasure.zetaNum p (a0 p hp2) := by
  have htor : Col p (wGammaTeich p hp2) = 0 :=
    Col_eq_zero_of_torsion p _ (wGammaTeich_torsion p hp2)
  have hsplit : Col p (cyclo p (a0_not_dvd p hp2) hp2)
      = Col p (wGammaTeich p hp2) + Col p (wGamma p hp2) := by
    rw [cyclo_eq_split p hp2, Col_add]
  rw [Col_cyclo p (a0_not_dvd p hp2) hp2, htor, zero_add] at hsplit
  rw [вҶҗ hsplit]

/-- `Col(wОі(aвӮҖ)) = вҲ’zetaNum aвӮҖ` with `aвӮҖ` named as the canonical `.choose` (the form used by
`zetaIdeal_eq_span`/`coleman_to_kl`). `a0 p hp2` is by definition that `.choose`, so this is
`Col_wGamma`. -/
theorem Col_wGamma_choose (hp2 : p вү  2) :
    Col p (wGamma p hp2)
      = -PadicMeasure.zetaNum p (PadicMeasure.exists_nat_topological_generator p hp2).choose :=
  Col_wGamma p hp2

/-- The level units of a power: `(uбөҸ).elems n = (u.elems n)бөҸ`. -/
private theorem elems_pow' (u : NormCompatUnits p) (k n : в„•) :
    (u ^ k).elems n = (u.elems n) ^ k := by
  induction k with
  | zero => rw [pow_zero, pow_zero]; rfl
  | succ m ih => rw [pow_succ, pow_succ, вҶҗ ih]; rfl

/-- `wОі(aвӮҖ)^{pвҲ’1} = (cyclo aвӮҖ)^{pвҲ’1}` (the TeichmГјller part `v` is `(pвҲ’1)`-torsion). -/
private theorem wGamma_pow_eq_cyclo_pow (hp2 : p вү  2) :
    wGamma p hp2 ^ (p - 1) = cyclo p (a0_not_dvd p hp2) hp2 ^ (p - 1) := by
  rw [cyclo_eq_split p hp2, mul_pow]
  have hvpow : wGammaTeich p hp2 ^ (p - 1) = 1 := by
    apply NormCompatUnits.ext; funext n
    rw [elems_pow' p, wGammaTeich_torsion p hp2 n]; rfl
  rw [hvpow, one_mul]

/-- **The honest cyclotomic content** (RJW LemmaGeneratorCinfty1 modulo the deferred В§13
closure-crossing): `wОі(aвӮҖ)^{pвҲ’1} вҲҲ рқ’һ_{вҲһ,1}`. It equals `(cyclo aвӮҖ)^{pвҲ’1}` (the torsion part
`v` cancels), which is *cyclotomic* (a power of the cyclotomic `c_n(aвӮҖ)`, in the topological
closure of `рқ’ҹ_n`) and *principal* (`wОі(aвӮҖ) вҲҲ рқ’°_{вҲһ,1}`, so its `(pвҲ’1)`-th power is too). This
is the maximal fragment provable without the closure's `в„Ө_p`-module structure. -/
theorem wGamma_pow_mem_cycloTower1 (hp2 : p вү  2) : wGamma p hp2 ^ (p - 1) вҲҲ cycloTower1 p := by
  intro n hn
  have hmem : wGamma p hp2 ^ (p - 1) вҲҲ unitsTower1 p :=
    pow_mem (wGamma_mem_unitsTower1 p hp2) (p - 1)
  rw [cycloClosureOne, Subgroup.mem_inf]
  refine вҹЁ?_, hmem n hnвҹ©
  rw [cycloClosure, Subgroup.mem_inf]
  refine вҹЁ?_, ((mem_localUnitsOne_iff p).1 (hmem n hn)).1вҹ©
  -- `(c_n(aвӮҖ))^{pвҲ’1} вҲҲ topologicalClosure(cycloUnits)`
  rw [wGamma_pow_eq_cyclo_pow p hp2, elems_pow' p]
  exact pow_mem (Subgroup.le_topologicalClosure _
    (cyclo_elems_mem_cycloUnits p (a0_not_dvd p hp2) hp2 hn)) (p - 1)

/-- **`wОі(aвӮҖ) вҲҲ рқ’һ_{вҲһ,1}`** (RJW LemmaGeneratorCinfty1, TeX 3553): the TeichmГјller-corrected
cyclotomic generator lies in the cyclotomic tower. This is input (I) of
`col_image_cycloTower1_eq_zetaIdeal`.

Closed from `wGamma_mem_unitsTower1` (`wОі(aвӮҖ) вҲҲ рқ’°_{вҲһ,1}` principal) and
`wGamma_pow_mem_cycloTower1` (`wОі(aвӮҖ)^{pвҲ’1} вҲҲ рқ’һ_{вҲһ,1}`) via the В§13 `в„Ө_p`-module/closure
layer `mem_cycloClosureOne_of_pow_mem` (CyclotomicUnits): the closure `рқ’һ_{n,1}` is
`zpPow`-closed and `pвҲ’1 вҲҲ в„Ө_p^Г—`, so the unique `(pвҲ’1)`-th root `wОі(aвӮҖ).elems n` of the
closure element `(wОі(aвӮҖ).elems n)^{pвҲ’1}` lies in `рқ’һ_{n,1}`. -/
theorem wGamma_mem_cycloTower1 (hp2 : p вү  2) : wGamma p hp2 вҲҲ cycloTower1 p := by
  intro n hn
  -- `g = wОі(aвӮҖ).elems n` is principal (`вҲҲ рқ’°_{n,1}`) and `g^{pвҲ’1} вҲҲ рқ’һ_{n,1}`
  have hg : (wGamma p hp2).elems n вҲҲ localUnitsOne p n := wGamma_mem_unitsTower1 p hp2 n hn
  have hgpow : ((wGamma p hp2).elems n) ^ (p - 1) вҲҲ cycloClosureOne p n := by
    have := wGamma_pow_mem_cycloTower1 p hp2 n hn
    rwa [elems_pow' p] at this
  -- the В§13 `(pвҲ’1)`-rootedness of the closure
  exact mem_cycloClosureOne_of_pow_mem p hg hgpow

/-- **`Пғ_a` stabilises `рқ’һ_{вҲһ,1}` on the cyclotomic generator `wОі(aвӮҖ)`**: `Пғ_a(wОі(aвӮҖ)) вҲҲ
рқ’һ_{вҲһ,1}`. Levelwise, `wОі(aвӮҖ)^{pвҲ’1} = (c_n(aвӮҖ))^{pвҲ’1}` is an *honest* cyclotomic unit
(`cyclo_elems_mem_cycloUnits`, in the discrete group `рқ’ҹ_n`), and `Пғ_a` maps `рқ’ҹ_n` into `рқ’ҹ_n`
(`galAutValU_mem_cycloUnits`), so `(Пғ_a wОі)^{pвҲ’1} вҲҲ рқ’ҹ_n вҠҶ (рқ’ҹ_n)вҒ» = рқ’һ_n`; with `Пғ_a wОі`
principal (`galNCU_mem_unitsTower1`), the `(pвҲ’1)`-rootedness `mem_cycloClosureOne_of_pow_mem`
puts `Пғ_a wОі вҲҲ рқ’һ_{n,1}`. (No topological-closure preservation of `Пғ_a` is needed: the
`(pвҲ’1)`-power lands in the un-closed `рқ’ҹ_n`. This is the levelwise realisation of the
`[Пғ_a]`-scalar action stabilising the cyclic `Оӣ(рқ’ў)`-module `рқ’һ_{вҲһ,1}`, RJW TeX 3553вҖ“3578.) -/
theorem galNCU_wGamma_mem_cycloTower1 (a : в„Ө_[p]ЛЈ) (hp2 : p вү  2) :
    galNCU p a (wGamma p hp2) вҲҲ cycloTower1 p := by
  intro n hn
  -- `g = Пғ_a(wОі).elems n` is principal
  have hg : (galNCU p a (wGamma p hp2)).elems n вҲҲ localUnitsOne p n :=
    galNCU_mem_unitsTower1 p a (wGamma_mem_unitsTower1 p hp2) n hn
  refine mem_cycloClosureOne_of_pow_mem p hg ?_
  -- `g^{pвҲ’1} = Пғ_a((wОі)^{pвҲ’1}).elems n = Пғ_a((c_n(aвӮҖ))^{pвҲ’1})`, an honest cyclotomic unit
  have hpow : ((galNCU p a (wGamma p hp2)).elems n) ^ (p - 1)
      = galAutValU p a n ((cyclo p (a0_not_dvd p hp2) hp2).elems n ^ (p - 1)) := by
    rw [вҶҗ elems_pow' p, вҶҗ galNCU_pow p a (wGamma p hp2) (p - 1),
      galNCU_elems_eq_galAutValU p a _ n, wGamma_pow_eq_cyclo_pow p hp2, elems_pow' p]
  rw [hpow]
  -- `(c_n(aвӮҖ))^{pвҲ’1} вҲҲ рқ’ҹ_n`, `Пғ_a рқ’ҹ_n вҠҶ рқ’ҹ_n`, so the image is in `рқ’ҹ_n вҠҶ рқ’һ_n`; and principal
  have hcyc : (cyclo p (a0_not_dvd p hp2) hp2).elems n ^ (p - 1) вҲҲ cycloUnits p n :=
    pow_mem (cyclo_elems_mem_cycloUnits p (a0_not_dvd p hp2) hp2 hn) (p - 1)
  have hgalcyc : galAutValU p a n ((cyclo p (a0_not_dvd p hp2) hp2).elems n ^ (p - 1))
      вҲҲ cycloUnits p n := galAutValU_mem_cycloUnits p a hn hcyc
  -- principal: it is `(Пғ_a wОі).elems n ^ {pвҲ’1}`, a power of a principal unit
  have hgprin : galAutValU p a n ((cyclo p (a0_not_dvd p hp2) hp2).elems n ^ (p - 1))
      вҲҲ localUnitsOne p n := by rw [вҶҗ hpow]; exact pow_mem hg (p - 1)
  rw [cycloClosureOne, Subgroup.mem_inf, cycloClosure, Subgroup.mem_inf]
  exact вҹЁвҹЁSubgroup.le_topologicalClosure _ hgalcyc,
    ((mem_localUnitsOne_iff p).1 hgprin).1вҹ©, hgprinвҹ©

/-! ## The `wОі(aвӮҖ)`вҶ”`c_n(aвӮҖ)` bridge and level-`n` cyclicity at `aвӮҖ` (RJW LemmaGeneratorCinfty1
step (A)/(B))

These lemmas relate the *abstract* TeichmГјller-corrected generator `wОі(aвӮҖ)` (defined via the
`splitCyclo` TeichmГјller section) to the *explicit* cyclotomic units `c_n(aвӮҖ)` (`cycloUnit`),
and assemble the banked level-`n` single-generator cyclicity `cor:cyc units gen 2`
(`cycloUnit_mem_cycloTranslateSubgroup`) at the canonical topological generator `aвӮҖ`. They are
the honest, axiom-clean fragments of LemmaGeneratorCinfty1 (TeX 3553вҖ“3578) provable without the
deferred В§13 inverse-limit `Оӣ(рқ’ў)`-module structure on the unit tower. -/

/-- **(A) The `wОі(aвӮҖ)`вҶ”`c_n(aвӮҖ)` level bridge**: the `(pвҲ’1)`-power of `wОі(aвӮҖ)`'s level-`n`
coordinate is exactly `c_n(aвӮҖ)^{pвҲ’1}`. The TeichmГјller factor `v = Пү(b)` of the split
`cyclo aвӮҖ = vВ·wОі(aвӮҖ)` is `(pвҲ’1)`-torsion (`wGammaTeich_torsion`), so it cancels in the
`(pвҲ’1)`-power, exposing the explicit cyclotomic content of the abstract `wОі(aвӮҖ)`. This is the
levelwise form of `wGamma_pow_eq_cyclo_pow`. -/
theorem wGamma_elems_pow_eq_cycloUnit_pow (hp2 : p вү  2) {n : в„•} (hn : 1 вүӨ n) :
    ((wGamma p hp2).elems n : в„Ӯ_[p]) ^ (p - 1) = cycloUnit p (a0 p hp2) n ^ (p - 1) := by
  have h := congrArg (fun u : NormCompatUnits p => ((u.elems n : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]))
    (wGamma_pow_eq_cyclo_pow p hp2)
  simp only [elems_pow' p, Units.val_pow_eq_pow_val] at h
  rw [h]
  -- `(cyclo aвӮҖ).elems n = c_n(aвӮҖ)` for `n вүҘ 1`
  change (((cyclo p (a0_not_dvd p hp2) hp2).elems n : в„Ӯ_[p]ЛЈ) : в„Ӯ_[p]) ^ (p - 1) = _
  rw [show (cyclo p (a0_not_dvd p hp2) hp2).elems n
      = Units.mk0 (cycloUnit p (a0 p hp2) n) (cycloUnit_ne_zero p (a0_not_dvd p hp2) hn) from by
    change (if h : 1 вүӨ n then Units.mk0 (cycloUnit p (a0 p hp2) n) _ else 1) = _
    rw [dif_pos hn], Units.val_mk0]

/-- **(B) Level-`n` single-generator cyclicity at `aвӮҖ`** (RJW `cor:cyc units gen 2`, TeX
3484вҖ“3486, specialised to the canonical topological generator `aвӮҖ`): every cyclotomic unit
`c_n(b')` with `p вҲӨ b'` lies in the `рқ’ў_n`-translate subgroup of the single generator `c_n(aвӮҖ)`.
The canonical `aвӮҖ` (`exists_nat_topological_generator`) reduces to a *generator* of `(в„Ө/p^nв„Ө)^Г—`
at every level `n вүҘ 1` (`hgen`), so every `p`-coprime residue `b' mod p^n` is a power
`(aвӮҖ)^r`; the explicit telescoping `c_n(b') = вҲҸ_{i<r} Пғ_{aвӮҖ^i}(c_n(aвӮҖ))`
(`cycloUnit_mem_cycloTranslateSubgroup`) then exhibits `c_n(b')` as a product of `Пғ`-translates
of `c_n(aвӮҖ)`. This is the level-`n` algebraic content of LemmaGeneratorCinfty1; its lift to the
inverse limit is the deferred В§13 `Оӣ(рқ’ў)`-module input. -/
theorem cycloUnitU_a0_generates (hp2 : p вү  2) {n : в„•} (hn : 1 вүӨ n)
    {b' : в„•} (hb' : В¬ (p : в„•) вҲЈ b') :
    cycloUnitU p hb' hn
      вҲҲ cycloTranslateSubgroup p n (cycloUnitU p (a0_not_dvd p hp2) hn) := by
  -- the canonical unit `uвӮҖ` with `(uвӮҖ : в„Ө_p) = aвӮҖ` and `вҹЁunitsToZModPow n uвӮҖвҹ© = вҠӨ` at all `n`
  set uвӮҖ : в„Ө_[p]ЛЈ := (PadicMeasure.exists_nat_topological_generator p hp2).choose_spec.choose
    with huвӮҖ
  have huвӮҖspec := (PadicMeasure.exists_nat_topological_generator p hp2).choose_spec.choose_spec
  -- the residue of `aвӮҖ` mod `p^n` matches that of `uвӮҖ` (since `(uвӮҖ : в„Ө_p) = (aвӮҖ : в„Ө_p)`)
  have hval : (uвӮҖ : в„Ө_[p]) = (a0 p hp2 : в„Ө_[p]) := huвӮҖspec.2.1
  have hres : ((a0 p hp2 : в„•) : ZMod (p ^ n))
      = (PadicMeasure.unitsToZModPow p n uвӮҖ : (ZMod (p ^ n))ЛЈ) := by
    rw [PadicMeasure.unitsToZModPow_coe, hval, map_natCast]
  -- `b' вүЎ aвӮҖ^r (mod p^n)` for some `r`, since `aвӮҖ` generates `(в„Ө/p^nв„Ө)^Г—`
  have hgen : Subgroup.zpowers (PadicMeasure.unitsToZModPow p n uвӮҖ) = вҠӨ := huвӮҖspec.2.2 n
  haveI : NeZero (p ^ n) := вҹЁ(pow_pos hp.out.pos n).ne'вҹ©
  -- `b'` is a unit mod `p^n` (coprime to `p`, hence to `p^n`)
  have hb'unit : IsUnit ((b' : в„•) : ZMod (p ^ n)) := by
    rw [ZMod.isUnit_iff_coprime]
    exact hp.out.coprime_pow_of_not_dvd (m := n) hb'
  -- the residue of `b'` as a unit of the *finite* `(в„Ө/p^nв„Ө)^Г—` is a `в„•`-power of the generator
  obtain вҹЁr', hr'вҹ© : вҲғ r' : в„•,
      (PadicMeasure.unitsToZModPow p n uвӮҖ) ^ r' = hb'unit.unit := by
    have hmem : hb'unit.unit вҲҲ Subgroup.zpowers (PadicMeasure.unitsToZModPow p n uвӮҖ) :=
      hgen в–ё Subgroup.mem_top _
    rwa [вҶҗ mem_powers_iff_mem_zpowers] at hmem
  -- pull the unit-power identity to the residue equation `b' вүЎ aвӮҖ^{r'} (mod p^n)`
  have hbb' : ((b' : в„•) : ZMod (p ^ n)) = ((a0 p hp2 : в„•) : ZMod (p ^ n)) ^ r' := by
    rw [hres]
    have := congrArg (fun x : (ZMod (p ^ n))ЛЈ => (x : ZMod (p ^ n))) hr'
    simp only [Units.val_pow_eq_pow_val, IsUnit.unit_spec] at this
    rw [вҶҗ this]
  exact cycloUnit_mem_cycloTranslateSubgroup p uвӮҖ hn (a0_not_dvd p hp2) hres hb' hbb'

/-- **T1222 вҖ” level-`n` PLUS density** (RJW LemmaGeneratorCinfty1(i), TeX 3553вҖ“3572): the principal
plus cyclotomic closure `рқ’һвҒә_{n,1}` lies in the topological closure of the `рқ’ў_n`-translate subgroup
of `wОі(aвӮҖ)` at level `n`. By `cycloUnitsPlus_eq_closure_gammas` the group `рқ’ҹвҒә_n` is generated by the
`Оі_{n,b}` and `вҲ’1`; `lem:global generators 2(ii)` (`(wОі)^{pвҲ’1} = c_n(aвӮҖ)^{pвҲ’1}` generates
`(pвҲ’1)рқ’ҹвҒә_n`), `(pвҲ’1)` invertible in `в„Ө_p`, and `closure_zspan_eq_zpspan` (lem:closure) assemble the
cyclic generation; `cycloUnit_mem_cycloTranslateSubgroup`/`cycloUnitU_a0_generates` give that the
single `c_n(aвӮҖ)` `в„Ө[рқ’ў_n]`-generates the `c_n`'s. -/
