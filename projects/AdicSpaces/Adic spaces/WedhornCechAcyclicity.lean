            MvPowerSeries.coeff e (MvPowerSeries.X (0 : Fin 2))
          rw [LaurentTateAlgebra.varInclFun_apply]
          by_cases he : e = Finsupp.single (0 : Fin 2) (e 0)
          · rw [if_pos he, MvPowerSeries.coeff_X, MvPowerSeries.coeff_X]
            by_cases h0 : e 0 = 1
