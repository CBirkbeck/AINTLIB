        (D₀.coeRingHom (divByS p D₀.s)) * divByS (D₀.canonicalMap f) DB.s) =
        DB.canonicalMap (D₀.coeRingHom (divByS p D₀.s)) *
          DB.canonicalMap (D₀.canonicalMap f) := by
      rw [map_mul, hb1]; rfl
    rw [e1, hps p, map_mul, map_mul]
