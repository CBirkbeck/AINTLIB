  -- conclude
  rw [hΦ_ker]
  intro h hh
  have hh2 : Φ h = 0 := hh
  have hfun := congrFun hext h
  simp only [Function.comp_apply, hh2, map_zero] at hfun
  exact Ideal.Quotient.eq_zero_iff_mem.mp hfun.symm

