      ((((imagePieceDatum D₀ T t₁ hspan).interSamePair
      (imagePieceDatum D₀ T t₂ hspan) rfl).coeRingHom).comp
        (genPiece_relOverlap_forwardLocHom D₀ T hspan t₁ t₂)) := by
