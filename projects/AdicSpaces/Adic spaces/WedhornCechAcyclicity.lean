/-- G3a-1′ tracking. -/
private theorem globalCollapseLocHom_algebraMap (P : PairOfDefinition A) (a : A) :
    globalCollapseLocHom P (algebraMap A (Localization.Away ((globalLocData P).s)) a) =
      a := by
  rw [globalCollapseLocHom, IsLocalization.Away.lift_eq]
  rfl

