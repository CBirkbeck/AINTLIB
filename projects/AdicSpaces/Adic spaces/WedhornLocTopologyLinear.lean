    {G H : Type*} [AddCommGroup G] [AddCommGroup H]
    (f : G ‚Üí+ H) (U : AddSubgroup G) (a : G) :
    a ‚ąą U ‚äĒ f.ker ‚ÜĒ ‚ąÉ b ‚ąą U, f b = f a := by
  refine ‚ü®AddSubgroup.exists_mem_of_mem_sup_ker f U, ?_‚ü©
  rintro ‚ü®b, hb, hfb‚ü©
  rw [AddSubgroup.mem_sup']
  have hk : a - b ‚ąą f.ker := by
    rw [AddMonoidHom.mem_ker, map_sub, hfb, sub_self]
  exact ‚ü®‚ü®b, hb‚ü©, ‚ü®a - b, hk‚ü©, by simp [add_sub_cancel]‚ü©

