/-!
# Localized Tate-data derivation for `exists_dominating_unit_in_localization`

The previous file `WedhornLocalizedCor732Application.lean` (commit `863aa86`)
exposes the localized Cor 7.32 application with all localized
Wedhorn-Tate hypotheses as **explicit inputs**. This file derives the
strongest pieces of these from the global `PairOfDefinition A` plus
localization data `(T, s, hopen)`, removing them as explicit
hypotheses.

## What this file provides

1. **`locIdeal_eq_span_singleton_of_principal`** ‚ÄĒ principal-generator
   bridge: from `P.I = Ideal.span {ŌÄ}` to `(locPairOfDefinition).I =
   Ideal.span {algebraMapD ŌÄ}`. Direct via `Ideal.map_span` (or
   variants).

2. **`isTopologicallyNilpotent_algebraMapD_of_isTopologicallyNilpotent`**
   ‚ÄĒ TN transfer: from `IsTopologicallyNilpotent (P.A‚āÄ.subtype ŌÄ)`
   in `A` to TN of `(locSubring).subtype (algebraMapD ŌÄ)` in
   `Localization.Away s` under `locTopology`. Uses
   `IsTopologicallyNilpotent.map` (Mathlib) with continuity of
   `algebraMap A ‚Üí Localization.Away s` from
   `locTopology_algebraMap_continuous` (committed `fd1a66c`).

3. **`isUnit_algebraMapD_of_isUnit`** ‚ÄĒ Unit transfer: from
   `IsUnit (P.A‚āÄ.subtype ŌÄ)` in `A` to unit of `(locSubring).subtype
   (algebraMapD ŌÄ)` in `Localization.Away s`. Direct via
   `RingHom.isUnit_map`.

## Single residual

The remaining explicit hypotheses for `exists_dominating_unit_in_localization`:

* `IsLinearTopology (Localization.Away s) (Localization.Away s)` for
  `locTopology P T s hopen` ‚ÄĒ structural, requires showing the
  `locNhd`-basis can be promoted to an ideal-basis (or that the
  generated ideals form a basis). The locNhd's are AddSubgroups, not
  in general ideals of `Localization.Away s`. The cleanest route is
  probably via `IsLinearTopology.mk_of_hasBasis'` with an explicit
  SMul-closure verification on `Submodule.span (Localization.Away s)
  (locNhd P T s n)`. This is the next concrete sub-target.

* `hArch_loc` (MulArchimedean for points in localized Spa) and
  `hT_loc` (no common zero on the localized Spa) ‚ÄĒ these depend on
  the global Wedhorn-Tate setup transferring through the localization;
  out of scope for this file.

## Notes

* No root import; leaf-level file.
* No edits to committed bridge files.
* No Lane B / Cor 8.32 / Jacobson / T001 / faithful-flatness /
  final-acyclicity content. -/

namespace ValuationSpectrum

variable {A : Type*} [CommRing A] [TopologicalSpace A] [IsTopologicalRing A]

/-- **Principal generator transfer**: from `P.I = Ideal.span {ŌÄ}` for
`ŌÄ : P.A‚āÄ`, the local ideal of definition `(locPairOfDefinition P T s hopen).I`
is principally generated by `algebraMapD P T s ŌÄ : locSubring P T s`. -/
theorem locIdeal_eq_span_singleton_of_principal
    (P : PairOfDefinition A) (T : Finset A) (s : A)
    (hopen : ‚ąÉ N : ‚Ąē, ‚ąÄ b : P.A‚āÄ, b ‚ąą P.I ^ N ‚Üí
      divByS (‚ÜĎb : A) s ‚ąą locSubring P T s)
    (ŌÄ : P.A‚āÄ) (hI : P.I = Ideal.span {ŌÄ}) :
    letI : TopologicalSpace (Localization.Away s) := locTopology P T s hopen
    (locPairOfDefinition P T s hopen).I = Ideal.span {algebraMapD P T s ŌÄ} := by
  letI : TopologicalSpace (Localization.Away s) := locTopology P T s hopen
  show locIdeal P T s = Ideal.span {algebraMapD P T s ŌÄ}
  rw [locIdeal, hI, Ideal.map_span]
  congr 1
  ext x
  simp only [Set.mem_singleton_iff, Set.image_singleton]

/-- **Topologically-nilpotent transfer**: from `IsTopologicallyNilpotent
(P.A‚āÄ.subtype ŌÄ)` in `A` to TN of the local generator
`(locSubring P T s).subtype (algebraMapD P T s ŌÄ)` in `Localization.Away s`
under `locTopology P T s hopen`.

Uses `IsTopologicallyNilpotent.map` (Mathlib) with continuity of
`algebraMap A ‚Üí Localization.Away s` (`locTopology_algebraMap_continuous`,
committed `fd1a66c`). -/
theorem isTopologicallyNilpotent_algebraMapD_of_isTopologicallyNilpotent
    (P : PairOfDefinition A) (T : Finset A) (s : A)
    (hopen : ‚ąÉ N : ‚Ąē, ‚ąÄ b : P.A‚āÄ, b ‚ąą P.I ^ N ‚Üí
      divByS (‚ÜĎb : A) s ‚ąą locSubring P T s)
    (ŌÄ : P.A‚āÄ) (hŌÄ_tn : IsTopologicallyNilpotent (P.A‚āÄ.subtype ŌÄ)) :
    letI : TopologicalSpace (Localization.Away s) := locTopology P T s hopen
    IsTopologicallyNilpotent
      ((locPairOfDefinition P T s hopen).A‚āÄ.subtype (algebraMapD P T s ŌÄ)) := by
  letI : TopologicalSpace (Localization.Away s) := locTopology P T s hopen
  -- (locSubring P T s).subtype (algebraMapD P T s ŌÄ) = algebraMap A _ (P.A‚āÄ.subtype ŌÄ) by
  -- definition of algebraMapD as `(algebraMap.comp subtype).codRestrict`.
  show IsTopologicallyNilpotent
    (((locSubring P T s).subtype (algebraMapD P T s ŌÄ)) : Localization.Away s)
  have heq : ((locSubring P T s).subtype (algebraMapD P T s ŌÄ) :
      Localization.Away s) = algebraMap A (Localization.Away s) (P.A‚āÄ.subtype ŌÄ) := rfl
  rw [heq]
  exact hŌÄ_tn.map (locTopology_algebraMap_continuous P T s hopen)

/-- **Unit transfer**: from `IsUnit (P.A‚āÄ.subtype ŌÄ)` in `A` to
`IsUnit ((locSubring P T s).subtype (algebraMapD P T s ŌÄ))` in
`Localization.Away s`.

Direct via `RingHom.isUnit_map` for the ring hom `algebraMap A
(Localization.Away s)`. -/
theorem isUnit_algebraMapD_of_isUnit
    (P : PairOfDefinition A) (T : Finset A) (s : A)
    (hopen : ‚ąÉ N : ‚Ąē, ‚ąÄ b : P.A‚āÄ, b ‚ąą P.I ^ N ‚Üí
      divByS (‚ÜĎb : A) s ‚ąą locSubring P T s)
    (ŌÄ : P.A‚āÄ) (hŌÄ_unit : IsUnit (P.A‚āÄ.subtype ŌÄ)) :
    letI : TopologicalSpace (Localization.Away s) := locTopology P T s hopen
    IsUnit ((locPairOfDefinition P T s hopen).A‚āÄ.subtype (algebraMapD P T s ŌÄ)) := by
  letI : TopologicalSpace (Localization.Away s) := locTopology P T s hopen
  show IsUnit (((locSubring P T s).subtype (algebraMapD P T s ŌÄ)) :
    Localization.Away s)
  have heq : ((locSubring P T s).subtype (algebraMapD P T s ŌÄ) :
      Localization.Away s) = algebraMap A (Localization.Away s) (P.A‚āÄ.subtype ŌÄ) := rfl
  rw [heq]
  exact hŌÄ_unit.map (algebraMap A (Localization.Away s))

/-! ### T213: localized test-family nonvanishing supplier

T206's item-8 input (no-common-zero on `Spa(Loc s, ‚Āļ)` for the test
family `T_test_loc`) is the last per-cover residual after T208/T211.
T213 below produces the supplier in the **generic** form parameterised
directly by `(P, T, s, hopen)` and the per-cover-piece data
`(T_D, s_D)`, rather than the existing `RationalCovering`-specialised
`wedhorn_834_localizedTestFamily_nonvanishing_supplier`
(`Adic spaces/WedhornC1StrongSupplierBridge.lean:553`).

The proof is a clean reduction: at every `w` in the localised Spa,
return `ŌĄ := algebraMap A (Loc s) s_D` ‚ÄĒ which lies in
`localizedTestFamily s T_D s_D` by `Finset.mem_insert_self` (since
`localizedTestFamily = insert (algebraMap s_D) (T_D.image algebraMap)`)
‚ÄĒ and use the supplied per-`w` non-vanishing of `algebraMap s_D`. -/

/-- **T213 generic localized test-family nonvanishing supplier**.

From the per-`w` non-vanishing of `algebraMap A (Loc s) s_D` on
`Spa(Localization.Away s, ‚Āļ)` (under the `locTopology` /
`localizationLocSubringPlusSubring` choices), produce the
`localizedTestFamily s T_D s_D` no-common-zero condition required as
input to `Cor732.exists_dominating_unit` applied to the localised
ring.

**Inputs**:
* `(P, T, s, hopen)` ‚ÄĒ the standard `locTopology` / `locSubring` data.
* `(T_D, s_D)` ‚ÄĒ target cover-piece data (`s_D` is the cover-piece
  denominator; `T_D` is the cover-piece test family).
* `h_sD_ne` ‚ÄĒ per-`w` non-vanishing of `algebraMap A (Loc s) s_D` on
  `Spa(Loc s, ‚Āļ)` (cover-piece denominator structural condition).

**Output**: per-`w`, `‚ąÉ ŌĄ ‚ąą localizedTestFamily s T_D s_D, ¬¨ w.vle ŌĄ 0`.

**Proof**: at each `w`, return `ŌĄ := algebraMap s_D` (in
`localizedTestFamily` by `Finset.mem_insert_self`); the supplied
`h_sD_ne` discharges the non-vanishing.

**Use**: this is the generic counterpart of
`wedhorn_834_localizedTestFamily_nonvanishing_supplier`
(`WedhornC1StrongSupplierBridge.lean:553`) ‚ÄĒ the same reduction,
parameterised by `(T_D, s_D)` directly rather than by
`(C : RationalCovering A, D : RationalLocData A)`. Suitable as the
`hT_loc` input at T206-style callsites that lack a
`RationalCovering` packaging. -/
theorem localizedTestFamily_nonvanishing_of_denominator_nonvanishing
    [PlusSubring A]
    (P : PairOfDefinition A) (T : Finset A) (s : A)
    (hopen : ‚ąÉ N : ‚Ąē, ‚ąÄ b : P.A‚āÄ, b ‚ąą P.I ^ N ‚Üí
      divByS (‚ÜĎb : A) s ‚ąą locSubring P T s)
    (T_D : Finset A) (s_D : A)
    (h_sD_ne :
      letI : TopologicalSpace (Localization.Away s) :=
        locTopology P T s hopen
      letI : PlusSubring (Localization.Away s) :=
        localizationLocSubringPlusSubring P T s
      ‚ąÄ w ‚ąą Spa (Localization.Away s) (Localization.Away s)‚Āļ,
        ¬¨ w.vle (algebraMap A (Localization.Away s) s_D) 0) :
    letI : TopologicalSpace (Localization.Away s) :=
      locTopology P T s hopen
    letI : PlusSubring (Localization.Away s) :=
      localizationLocSubringPlusSubring P T s
    ‚ąÄ w ‚ąą Spa (Localization.Away s) (Localization.Away s)‚Āļ,
      ‚ąÉ ŌĄ ‚ąą localizedTestFamily s T_D s_D, ¬¨ w.vle ŌĄ 0 := by
  letI : TopologicalSpace (Localization.Away s) :=
    locTopology P T s hopen
  letI : PlusSubring (Localization.Away s) :=
    localizationLocSubringPlusSubring P T s
  letI : DecidableEq (Localization.Away s) := Classical.decEq _
  intro w hw
  refine ‚ü®algebraMap A (Localization.Away s) s_D, ?_, h_sD_ne w hw‚ü©
  unfold localizedTestFamily
  exact Finset.mem_insert_self _ _

end ValuationSpectrum
